@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>

    <script>

                     function noAccess(type) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Access Denied',
                        text: 'You do not have ' + type + ' permission for this module.',
                        confirmButtonColor: '#dc2626'
                    });
                }


$(document).ready(function () {
        console.log('✅ Professional Countries Management Loaded!');

           
        function bindEventHandlers() {
            $(document).off('click', '.editByCountryId').on('click', '.editByCountryId', function () {
                var countryId = $(this).data('edcountryid');
                loadCountryData(countryId, 'edit');
            });

            $(document).off('click', '.viewByCountryId').on('click', '.viewByCountryId', function () {
                var countryId = $(this).data('vwcountryid');
                loadCountryData(countryId, 'view');
            });

            $(document).off('click', '.deleteCountries').on('click', '.deleteCountries', function () {
                var countryId = $(this).data('dlcountryid');
                loadCountryData(countryId, 'delete');
            });
        }

        // LOAD COUNTRY DATA
        function loadCountryData(countryId, action) {
            $.ajax({
                type: "GET",
                url: '@Url.Action("GetCountries", "Country")',
                data: { CountryID: countryId },
                dataType: "json",
                success: function (response) {
                    if (response != null) {
                        var countryIdResp = response.CountryID || response.countryID;
                        var countryName = response.CountryName || response.countryName;
                        var isActive = (response.IsActive || response.isActive) == 1;

                        if (action === 'edit') {
                            $('#hdnCountryId').val(countryIdResp);
                            $('#txtEditCountryNameInput').val(countryName);
                            $('#chkActiveStatusEdit').prop('checked', isActive);
                            $('#editCountry').modal('show');
                        } else if (action === 'view') {
                            $('#lblvwCountryName').text(countryName);
                            $('#lblvwCountryId').text(countryIdResp);
                            $('#lblvwStatus').removeClass('badge-success-custom badge-danger-custom')
                                           .addClass(isActive ? 'badge-success-custom' : 'badge-danger-custom')
                                           .html(isActive ? '<i class="fas fa-check-circle mr-1"></i>Active' : '<i class="fas fa-times-circle mr-1"></i>Inactive');
                            $('#viewCountry').modal('show');
                        } else if (action === 'delete') {
                            $('#lblDelCountryName').text(countryName);
                            $('#hdnDeCountryId').val(countryIdResp);
                            $('#deleteCountry').modal('show');
                        }
                    }
                },
                error: function (xhr) {
                    console.error('Load data error:', xhr.responseText);
                    alert('Error loading country data');
                }
            });
        }

        // INITIAL BINDING
        bindEventHandlers();

        // SHOW ALL BUTTON - NOW WITH PERFECT STYLING
        $('#showAllButton').click(function () {
            $(this).html('<i class="fas fa-spinner fa-spin mr-2"></i>Loading all records...');

            $.ajax({
                url: '@Url.Action("ShowAll", "Country")',
                type: 'GET',
                success: function (data) {
                    $('#countryTable tbody').empty();
                    $('.pagination, #showAllButton').hide();

                    $.each(data, function (index, item) {
                        var countryId = item.CountryID || item.countryID;
                        var countryName = item.CountryName || item.countryName;
                        var isActive = (item.IsActive || item.isActive) == 1;
                        var statusClass = isActive ? 'badge-success-custom' : 'badge-danger-custom';
                        var statusText = isActive ? 'Active' : 'Inactive';
                        var rowClass = isActive ? 'recently-added' : '';

                        $('#countryTable tbody').append(
                            '<tr class="' + rowClass + '">' +
                            '<td>' +
                            '<div class="d-flex align-items-center">' +
                            '<div style="width: 45px; height: 45px; border-radius: 12px; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); display: flex; align-items: center; justify-content: center; margin-right: 1rem;">' +
                            '<i class="fas fa-flag text-white" style="font-size: 1.1rem;"></i>' +
                            '</div>' +
                            '<div>' +
                            '<strong style="color: var(--dark);">' + countryName + '</strong>' +
                            '<br><small style="color: var(--gray);">ID: ' + countryId + '</small>' +
                            '</div>' +
                            '</div>' +
                            '</td>' +
                            '<td>' +
                            '<span class="status-badge ' + statusClass + '">' +
                            '<i class="fas fa-' + (isActive ? 'check' : 'times') + '-circle mr-1"></i>' + statusText +
                            '</span>' +
                            '</td>' +
                            '<td>' +
                            '<div class="btn-group" role="group">' +
                            '<button class="btn btn-primary-modern btn-modern btn-sm mr-1 editByCountryId" data-edCountryId="' + countryId + '" data-toggle="modal" data-target="#editCountry" title="Edit">' +
                            '<i class="fas fa-edit"></i>' +
                            '</button> ' +
                            '<button class="btn btn-info-modern btn-modern btn-sm mr-1 viewByCountryId" data-vwCountryId="' + countryId + '" data-toggle="modal" data-target="#viewCountry" title="View">' +
                            '<i class="fas fa-eye"></i>' +
                            '</button> ' +
                            '<button class="btn btn-danger-modern btn-modern btn-sm deleteCountries" data-dlCountryId="' + countryId + '" data-toggle="modal" data-target="#deleteCountry" title="Delete">' +
                            '<i class="fas fa-trash-alt"></i>' +
                            '</button> ' +
                            '</div>' +
                            '</td></tr>'
                        );
                    });

                    bindEventHandlers();
                    console.log('✅ Show All completed with professional styling');
                },
                error: function (xhr) {
                    alert('Error loading all countries');
                    $('#showAllButton').html('<i class="fas fa-expand-arrows-alt mr-2"></i>Show All Records');
                }
            });
        });

        // ADD COUNTRY
        $('#btnCountrySave').on('click', function (e) {
            var countryName = $('#txtCountryName').val().trim();
            var isValid = validateCountryName(countryName, '#txtCountryName', '#msgAddCountryValidation');

            if (isValid) {
                var countryData = {
                    countryName: countryName,
                    isDeleted: 0,
                    isActive: $('#chkActiveStatus').is(':checked') ? 1 : 0
                };

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("Save", "Country")',
                    data: countryData,
                    dataType: "json",
                    success: function (response) {
                        if (response.toLowerCase() === "success") {
                            Swal.fire({
                                icon: 'success',
                                title: 'Success!',
                                text: 'Country added successfully!',
                                confirmButtonColor: 'var(--primary)'
                            }).then(() => {
                                location.reload();
                            });
                        } else if (response.toLowerCase() === "duplicate") {
                            Swal.fire('Error!', 'Country already exists.', 'error');
                        } else {
                            Swal.fire('Error!', response, 'error');
                        }
                    },
                    error: function (xhr) {
                        Swal.fire('Error!', 'Error saving country', 'error');
                    }
                });
            }
            e.preventDefault();
        });

        // EDIT COUNTRY
        $('#btnEditCountrySave').on('click', function (e) {
            var countryName = $('#txtEditCountryNameInput').val().trim();
            var isValid = validateCountryName(countryName, '#txtEditCountryNameInput', '#msgEditCountryValidation');

            if (isValid) {
                var countryData = {
                    countryID: parseInt($('#hdnCountryId').val()),
                    countryName: countryName,
                    isDeleted: 0,
                    isActive: $('#chkActiveStatusEdit').is(':checked') ? 1 : 0
                };

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("Edit", "Country")',
                    data: countryData,
                    dataType: "json",
                    success: function (response) {
                        if (response === "success") {
                                                       Swal.fire({
                                icon: 'success',
                                title: 'Updated!',
                                text: 'Country updated successfully!',
                                confirmButtonColor: 'var(--primary)'
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error!', response, 'error');
                        }
                    },
                    error: function (xhr) {
                        Swal.fire('Error!', 'Error updating country', 'error');
                    }
                });
            }
            e.preventDefault();
        });

        // DELETE COUNTRY
        $('#btnConfirmCountryDelete').on('click', function () {
            var countryId = $('#hdnDeCountryId').val();
            if (!countryId) {
                Swal.fire('Error!', 'Country ID not found!', 'error');
                return;
            }

            $.ajax({
                type: "GET",
                url: '@Url.Action("DeleteCountry", "Country")',
                data: { countryId: countryId },
                dataType: "json",
                success: function (response) {
                    if (response.toLowerCase() === "success") {
                        Swal.fire({
                            icon: 'success',
                            title: 'Deleted!',
                            text: 'Country deleted successfully!',
                            confirmButtonColor: 'var(--primary)'
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('Error!', 'Delete failed: ' + response, 'error');
                    }
                },
                error: function (xhr) {
                    Swal.fire('Error!', 'Error deleting country', 'error');
                }
            });
        });

        // VALIDATION FUNCTION
        function validateCountryName(name, inputId, msgId) {
            var regex = /^[a-zA-Z\s]+$/;
            var isValid = true;

            if (name === "") {
                $(inputId).addClass('error');
                $(msgId).html("Please enter Country Name");
                isValid = false;
            } else if (!regex.test(name)) {
                $(inputId).addClass('error');
                $(msgId).html("Please enter valid Country Name (letters only)");
                isValid = false;
            } else {
                $(inputId).removeClass('error');
                $(msgId).html("");
            }

            return isValid;
        }

        // REAL-TIME VALIDATION
        $("#txtCountryName, #txtEditCountryNameInput").on('input', function () {
            var value = $(this).val().trim();
            var msgId = $(this).attr('id') === 'txtCountryName' ? '#msgAddCountryValidation' : '#msgEditCountryValidation';
            var regex = /^[a-zA-Z\s]+$/;

            if (value === '' || regex.test(value)) {
                $(this).removeClass('error');
                $(msgId).html('');
            } else {
                $(this).addClass('error');
                $(msgId).html('Only letters and spaces allowed');
            }
        });

        // PREVENT NON-ALPHABETIC CHARACTERS
        $("#txtCountryName, #txtEditCountryNameInput").keypress(function (e) {
            var regex = /^[a-zA-Z\s]+$/;
            var char = String.fromCharCode(e.which);
            if (!regex.test(char) && e.which !== 8 && e.which !== 0) {
                e.preventDefault();
            }
        });

        // RESET FUNCTIONS
        $('.btnCountryReset').on('click', function () {
            $('#addCountryForm, #editCountryForm')[0].reset();
            $('.form-control-modern').removeClass('error');
            $('.validationMessage').html('');
            $('#chkActiveStatus').prop('checked', true);
        });

        // MODAL RESET ON CLOSE
        $('#addCountry, #editCountry, #deleteCountry, #viewCountry').on('hidden.bs.modal', function () {
            $(this).find('.form-control-modern').val('').removeClass('error');
            $(this).find('.validationMessage').html('');
            $('#chkActiveStatus').prop('checked', true);
            $('#chkActiveStatusEdit').prop('checked', false);
            $('#hdnDeCountryId, #hdnCountryId').val('');
            $('#lblDelCountryName, #lblvwCountryName').text('');
        });

        // POPOVER INIT (OPTIONAL)
        $('[data-toggle="popover"]').popover();

        console.log('✅ All professional features initialized perfectly!');
    });
</script>
    <script>
        // ========== COUNTRIES STATIC PAGINATION + SHOW ALL WITH ARROWS ==========
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🚀 Countries Pagination Script Loaded with Arrows!');

            // Get table elements
            const table = document.getElementById("countryTable");
            const tbody = table.querySelector("tbody");
            const allRows = Array.from(tbody.querySelectorAll("tr:not(.empty-state-row)"));
            const paginationContainer = document.getElementById("countryPagination");
            const showAllBtn = document.getElementById("showAllCountriesBtn");

            let currentPage = 1;
            const rowsPerPage = 8; // Perfect for your design

            // ========== MAIN PAGINATION FUNCTION ==========
            function showPage(pageNum) {
                currentPage = pageNum;

                // Hide all rows first
                allRows.forEach(row => row.style.display = 'none');

                // Calculate visible rows
                const startIndex = (pageNum - 1) * rowsPerPage;
                const endIndex = startIndex + rowsPerPage;
                const visibleRows = allRows.slice(startIndex, endIndex);

                // Show only visible rows
                visibleRows.forEach(row => row.style.display = '');

                // Update pagination UI
                renderPagination();
                console.log(`📄 Page ${pageNum} shown (${visibleRows.length} rows)`);
            }

            // ========== RENDER PAGINATION UI ==========
            function renderPagination() {
                const totalPages = Math.ceil(allRows.length / rowsPerPage);

                if (totalPages <= 1) {
                    paginationContainer.innerHTML = '';
                    return;
                }

                paginationContainer.innerHTML = '';

                // ========== LEFT SIDE: Previous Button with Arrow ==========
                const prevBtn = createPageButton(
                    '<i class="mdi mdi-chevron-left mr-1"></i>Previous',
                    currentPage > 1,
                    () => {
                        if (currentPage > 1) showPage(currentPage - 1);
                    }
                );
                paginationContainer.appendChild(prevBtn);

                // ========== CENTER: Page Numbers (Smart: max 7 visible) ==========
                const maxVisible = 7;
                let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
                let endPage = Math.min(totalPages, startPage + maxVisible - 1);

                // Adjust start if needed
                if (endPage - startPage + 1 < maxVisible) {
                    startPage = Math.max(1, endPage - maxVisible + 1);
                }

                // First page (if not visible)
                if (startPage > 1) {
                    paginationContainer.appendChild(createPageButton('1', true, () => showPage(1)));
                    if (startPage > 2) {
                        const dots = document.createElement('li');
                        dots.innerHTML = '<a href="#" class="page-link">...</a>';
                        dots.style.cursor = 'default';
                        paginationContainer.appendChild(dots);
                    }
                }

                // Main page buttons
                for (let i = startPage; i <= endPage; i++) {
                    const pageBtn = createPageButton(i.toString(), true, () => showPage(i));
                    if (i === currentPage) pageBtn.classList.add('active');
                    paginationContainer.appendChild(pageBtn);
                }

                // Last page (if not visible)
                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) {
                        const dots = document.createElement('li');
                        dots.innerHTML = '<a href="#" class="page-link">...</a>';
                        dots.style.cursor = 'default';
                        paginationContainer.appendChild(dots);
                    }
                    paginationContainer.appendChild(createPageButton(totalPages.toString(), true, () => showPage(totalPages)));
                }

                // ========== RIGHT SIDE: Next Button with Arrow ==========
                const nextBtn = createPageButton(
                    'Next<i class="mdi mdi-chevron-right ml-1"></i>',
                    currentPage < totalPages,
                    () => {
                        if (currentPage < totalPages) showPage(currentPage + 1);
                    }
                );
                paginationContainer.appendChild(nextBtn);
            }

            // ========== CREATE PAGE BUTTON ==========
            function createPageButton(text, enabled, onClick) {
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = '#';
                a.className = 'page-link';
                a.innerHTML = text;

                if (!enabled) {
                    li.classList.add('disabled');
                    a.style.cursor = 'not-allowed';
                } else {
                    a.addEventListener('click', function(e) {
                        e.preventDefault();
                        onClick();
                    });
                }

                li.appendChild(a);
                return li;
            }

            // ========== SHOW ALL BUTTON ==========
            showAllBtn.addEventListener('click', function() {
                // Show all rows
                allRows.forEach(row => row.style.display = '');

                // Hide pagination
                paginationContainer.innerHTML = '';
                showAllBtn.style.display = 'none';

                console.log('✅ Show All - All rows visible!');
            });

            // ========== INITIALIZE ==========
            if (allRows.length > rowsPerPage) {
                showPage(1);
            } else {
                // Less than page size - show all
                allRows.forEach(row => row.style.display = '');
            }

            console.log(`✅ Pagination Ready! ${allRows.length} rows | ${Math.ceil(allRows.length / rowsPerPage)} pages`);
        });
    </script>


