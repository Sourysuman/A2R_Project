@model IEnumerable<A2R_Project.Models.Course>
@{
    ViewBag.Title = "Courses List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">

<style>
    body {
        background: #f4f6f9;
        font-family: 'Segoe UI', sans-serif;
    }

    /* CARD */
    .card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }

    .card-title {
        font-size: 20px;
        font-weight: 600;
        color: #333;
    }

    /* BUTTONS */
    .btn-gradient-primary {
        background: linear-gradient(45deg, #4e73df, #224abe);
        border: none;
        color: #fff;
    }

        .btn-gradient-primary:hover {
            opacity: 0.9;
        }

    .btn-sm {
        border-radius: 8px;
        padding: 5px 10px;
    }

    /* TABLE */
    .table {
        border-radius: 10px;
        overflow: hidden;
    }

        .table thead {
            background: linear-gradient(45deg, #343a40, #212529);
            color: #fff;
        }

        .table tbody tr {
            transition: 0.2s;
        }

            .table tbody tr:hover {
                background: #f1f5ff;
                transform: scale(1.01);
            }

    .table-info {
        background: #ffffff !important;
    }

    /* BADGES */
    .badge {
        font-size: 12px;
        padding: 6px 10px;
        border-radius: 20px;
    }

    /* MODAL */
    .modal-content {
        border-radius: 15px;
        border: none;
        box-shadow: 0 5px 25px rgba(0,0,0,0.2);
        animation: fadeIn 0.3s ease-in-out;
    }

    .modal-header {
        border-top-left-radius: 15px;
        border-top-right-radius: 15px;
    }

    .modal-title {
        width: 100%;
        text-align: center;
        font-weight: 600;
    }

    .modal-body {
        padding: 25px;
    }

    .modal-footer {
        border-top: none;
        padding: 15px 25px;
    }

    /* INPUT */
    .form-control {
        border-radius: 8px;
        border: 1px solid #ddd;
    }

        .form-control:focus {
            border-color: #4e73df;
            box-shadow: 0 0 5px rgba(78,115,223,0.3);
        }

    /* PAGINATION */
    .pagination .page-link {
        border-radius: 8px;
        margin: 0 3px;
        color: #4e73df;
    }

    .pagination .active .page-link {
        background: #4e73df;
        border-color: #4e73df;
        color: #fff;
    }

    /* ANIMATION */
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(-10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* ICON BUTTON COLORS */
    .btn-primary {
        background: #4e73df;
        border: none;
    }

    .btn-info {
        background: #36b9cc;
        border: none;
    }

    .btn-danger {
        background: #e74a3b;
        border: none;
    }

        .btn-primary:hover,
        .btn-info:hover,
        .btn-danger:hover {
            opacity: 0.85;
        }
    /* TABLE IMPROVED */
    .table {
        border-radius: 12px;
        overflow: hidden;
        border-collapse: separate;
        border-spacing: 0 10px; /* spacing between rows */
    }

        /* HEADER */
        .table thead th {
            border: none;
            text-align: center;
            font-weight: 600;
            padding: 14px;
            font-size: 14px;
            background: linear-gradient(45deg, #4e73df, #224abe);
            color: #fff;
        }

        /* ROW STYLE */
        .table tbody tr {
            background: #ffffff;
            box-shadow: 0 3px 10px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            border-radius: 10px;
        }

            /* HOVER EFFECT (NEW COLOR 🔥) */
            .table tbody tr:hover {
                background: linear-gradient(45deg, #e3f2fd, #e8f0ff);
                transform: translateY(-3px);
                box-shadow: 0 8px 18px rgba(0,0,0,0.12);
            }

        /* CELLS */
        .table td {
            vertical-align: middle;
            text-align: center;
            padding: 14px;
            border: none;
        }

    /* COURSE NAME STYLE */
    .course-name {
        max-width: 220px;
        margin: auto;
        text-align: left;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* STATUS CENTER */
    .table td:nth-child(2) {
        text-align: center;
    }

    /* ACTION BUTTON ALIGN */
    .action-btns {
        display: flex;
        justify-content: center;
        gap: 8px;
    }

        /* BUTTON HOVER EFFECT */
        .action-btns .btn {
            transition: all 0.2s ease;
        }

            .action-btns .btn:hover {
                transform: scale(1.1);
            }

    /* BADGE STYLE */
    .badge-success {
        background: #28a745;
    }

    .badge-danger {
        background: #dc3545;
    }
    /* COURSE NAME IMPROVED */
    .course-name {
        max-width: 260px; /* little more width */
        font-size: 16px; /* bigger text */
        font-weight: 600; /* bold look */
        color: #2c3e50; /* professional dark color */

        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-align: left;
        letter-spacing: 0.3px;
    }
    /* COURSE NAME - CLEAN PROFESSIONAL */
    .course-name {
        max-width: 280px;
        font-size: 15px;
        font-weight: 500;
        color: #1f2937; /* soft dark (better than pure black) */

        line-height: 1.4;
        letter-spacing: 0.2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        padding-left: 10px;
    }

    /* HOVER TEXT EFFECT */
    .table tbody tr:hover .course-name {
        color: #224abe; /* highlight on hover */
        font-weight: 600;
    }
    /* ===== COURSE NAME IN TABLE ===== */
    .table td:first-child {
        font-size: 16px;
        font-weight: 700;
        color: #000 !important;
        letter-spacing: 0.4px;
    }

    /* HOVER EFFECT */
    .table tbody tr:hover td:first-child {
        color: #224abe !important;
    }

    /* ===== VIEW MODAL FIX (INLINE DISPLAY) ===== */
    #viewCourse .modal-body .row {
        display: flex;
        flex-wrap: wrap;
    }

    #viewCourse .modal-body .col-md-6 {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* LABEL STYLE */
    #viewCourse strong {
        font-size: 15px;
        color: #333;
        min-width: 110px;
    }

    /* VALUE STYLE */
    #viewCourse p {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
        color: #000;
    }

    /* STATUS BADGE ALIGN */
    #viewCourse .badge {
        font-size: 13px;
        padding: 6px 12px;
    }

    /* ===== MODAL TEXT IMPROVEMENT ===== */
    .modal-body {
        font-size: 15.5px;
    }

    /* ===== ADD / EDIT MODAL INPUT TEXT ===== */
    .modal input.form-control {
        font-size: 15px;
        font-weight: 500;
    }

    /* ===== BUTTONS INSIDE MODAL ===== */
    .modal-footer .btn {
        border-radius: 20px;
        padding: 6px 16px;
        font-weight: 500;
        transition: 0.3s;
    }

        .modal-footer .btn:hover {
            transform: scale(1.05);
        }
    /* ===== VIEW MODAL INLINE FIX ===== */
    #viewCourse .modal-body .row {
        display: block;
    }

    #viewCourse .modal-body .col-md-6 {
        display: flex !important;
        align-items: center;
        gap: 8px;
        width: 100%;
        margin-bottom: 10px;
    }

    /* Label */
    #viewCourse strong {
        min-width: 130px;
        font-size: 15px;
        font-weight: 600;
        color: #444;
    }

    /* Value */
    #viewCourse p {
        margin: 0;
        font-size: 17px;
        font-weight: 700;
        color: #000;
    }
    /* ===== DELETE MODAL INLINE ===== */
    #deleteCourse .modal-body {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

        #deleteCourse .modal-body p {
            margin: 0;
            font-size: 16px;
        }

    #deleteCourse #lblDelCourseName {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
    }

</style>
<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Courses List</strong>
                <button type="button" class="btn btn-gradient-primary btn-rounded btn-fw" data-toggle="modal" data-target="#addCourse">
                    <i class="fa fa-plus"></i> Add Course
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="courseTable">
                    <thead class="thead-dark">
                        <tr>
                          
                            <th>Course Name</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr data-courseid="@item.CourseID" class="table-info">
                                  
                                    <td>@item.CourseName</td>
                                    <td>
                                        @if (item.IsActive == 1)
                                        {
                                            <span class="badge badge-success p-2">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger p-2">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <!-- EDIT BUTTON -->
                                        <button type="button" class="btn btn-sm btn-primary editByCourseId"
                                                data-courseid="@item.CourseID"
                                                data-coursename="@item.CourseName"
                                                data-isactive="@item.IsActive"
                                                title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </button>

                                        <!-- VIEW BUTTON -->
                                        <button type="button" class="btn btn-sm btn-info viewByCourseId"
                                                data-courseid="@item.CourseID"
                                                data-coursename="@item.CourseName"
                                                data-isactive="@item.IsActive"
                                                title="View">
                                            <i class="fas fa-eye"></i>
                                        </button>

                                        <!-- DELETE BUTTON -->
                                        <button type="button" class="btn btn-sm btn-danger deleteCourses"
                                                data-courseid="@item.CourseID"
                                                data-coursename="@item.CourseName"
                                                title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No courses found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (ViewBag.TotalCount != null && (int)ViewBag.TotalCount > (int)ViewBag.PageSize)
            {
                <div class="row mt-4">
                    <div class="col-md-12">
                        <nav>
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("List", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })">Previous</a>
                                </li>
                                @for (int i = 1; i <= Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize); i++)
                                {
                                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("List", new { page = i, pageSize = ViewBag.PageSize })">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.CurrentPage == Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize) ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("List", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">Next</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            }
            <button id="showAllCourses" class="btn btn-success btn-sm ml-2">
                <i class="fa fa-list"></i> Show All
            </button>
        </div>
      
    </div>
</div>


<!-- ADD COURSE MODAL -->
<div class="modal fade" id="addCourse" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-plus"></i> Add New Course</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="addCourseForm">
                    <div class="form-group">
                        <label>Course Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtCourseName" placeholder="Enter course name">
                        <div class="invalid-feedback" id="msgAddCourseValidation"></div>
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="chkActiveStatus">
                            <label class="form-check-label">Active Status</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" id="btnCourseSave"><i class="fas fa-save"></i> Save</button>
            </div>
        </div>
    </div>
</div>

<!-- EDIT COURSE MODAL -->
<div class="modal fade" id="editCourse" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="fas fa-edit"></i> Edit Course</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editCourseForm">
                    <input type="hidden" id="hdnCourseId">
                    <div class="form-group">
                        <label>Course Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtEditCourseName" placeholder="Enter course name">
                        <div class="invalid-feedback" id="msgEditCourseValidation"></div>
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="chkActiveStatusEdit">
                            <label class="form-check-label">Active Status</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning" id="btnEditCourseSave"><i class="fas fa-save"></i> Update</button>
            </div>
        </div>
    </div>
</div>

<!-- VIEW COURSE MODAL -->
<div class="modal fade" id="viewCourse" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="fas fa-eye"></i> Course Details</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <strong>Course Name:</strong>
                        <p class="text-muted" id="lblVwCourseName">-</p>
                    </div>
                    <div class="col-md-6">
                        <strong>Status:</strong>
                        <p class="text-muted" id="lblVwCourseStatus">-</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-info" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- DELETE COURSE MODAL -->
<div class="modal fade" id="deleteCourse" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle"></i> Confirm Delete</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete:</p>
                <h6 class="text-danger" id="lblDelCourseName">-</h6>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btnConfirmCourseDelete">Delete</button>
            </div>
        </div>
    </div>
</div>


<script>
    @section Scripts {
    <!-- 🔥 CRITICAL: jQuery & Bootstrap CDN -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>

    <script>
    $(document).ready(function() {

        // RESET FUNCTIONS
        function resetForm(formId) {
            $(formId).find('input[type="text"], input[type="checkbox"]').val('').prop('checked', false);
            $('.validationMessage, .invalid-feedback').html('').hide();
            $('input').removeClass('is-invalid');
        }

        // MODAL RESET
        $('#addCourse, #editCourse').on('hidden.bs.modal', function() {
            resetForm('#addCourseForm');
            resetForm('#editCourseForm');
        });

        // 1. ADD COURSE ✅ FIXED
        $('#btnCourseSave').click(function(e) {
            e.preventDefault();

            let courseName = $('#txtCourseName').val().trim();
            if (!courseName) {
                $('#txtCourseName').addClass('is-invalid');
                $('#msgAddCourseValidation').html('Course name is required!').show();
                return;
            }

            let courseData = {
                CourseName: courseName,
                IsActive: $('#chkActiveStatus').is(':checked') ? 1 : 0,
                IsDeleted: 0
            };

            $.ajax({
                url: '@Url.Action("Save", "Course")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(courseData),
                success: function(response) {
                    if (response.success) {
                        alert('✅ Course added successfully!');
                        $('#addCourse').modal('hide');
                        setTimeout(() => location.reload(), 500);
                    } else {
                        alert('❌ Error: ' + (response.message || 'Failed to add course'));
                    }
                },
                error: function(xhr) {
                    console.error('Add Error:', xhr);
                    alert('❌ Failed to add course. Please try again.');
                }
            });
        });
            // ===== STATIC SHOW ALL =====
    var rowsPerPage = 5;
    var currentPage = 1;

    function getCourseRows() {
        return $('#courseTable tbody tr');
    }

    function showCoursePage(page) {
        var rows = getCourseRows();
        var totalPages = Math.ceil(rows.length / rowsPerPage);

        rows.hide();
        rows.slice((page - 1) * rowsPerPage, page * rowsPerPage).show();
    }

    // INITIAL LOAD
    showCoursePage(currentPage);

    // SHOW ALL BUTTON
    $('#showAllCourses').click(function () {
        getCourseRows().show();

        // hide pagination if needed
        $('.pagination').closest('.row').hide();

        // optional message
        console.log("Showing all courses");
    });

        // 2. EDIT COURSE ✅ FIXED - Data attributes working
        $('.editByCourseId').click(function(e) {
            e.preventDefault();
            let courseId = $(this).data('courseid');
            let courseName = $(this).data('coursename');
            let isActive = $(this).data('isactive');

            $('#hdnCourseId').val(courseId);
            $('#txtEditCourseName').val(courseName);
            $('#chkActiveStatusEdit').prop('checked', isActive == 1);

            $('#editCourse').modal('show');
        });

        $('#btnEditCourseSave').click(function(e) {
            e.preventDefault();

            let courseId = $('#hdnCourseId').val();
            let courseName = $('#txtEditCourseName').val().trim();

            if (!courseName) {
                $('#txtEditCourseName').addClass('is-invalid');
                $('#msgEditCourseValidation').html('Course name is required!').show();
                return;
            }

            let courseData = {
                CourseID: parseInt(courseId),
                CourseName: courseName,
                IsActive: $('#chkActiveStatusEdit').is(':checked') ? 1 : 0,
                IsDeleted: 0
            };

            $.ajax({
                url: '@Url.Action("Edit", "Course")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(courseData),
                success: function(response) {
                    if (response.success) {
                        alert('✅ Course updated successfully!');
                        $('#editCourse').modal('hide');
                        setTimeout(() => location.reload(), 500);
                    } else {
                        alert('❌ Update failed: ' + (response.message || 'Please try again'));
                    }
                },
                error: function(xhr) {
                    console.error('Edit Error:', xhr);
                    alert('❌ Failed to update course');
                }
            });
        });

        // 3. VIEW COURSE ✅ FIXED - Data showing correctly
        $('.viewByCourseId').click(function(e) {
            e.preventDefault();
            let courseName = $(this).data('coursename');
            let isActive = $(this).data('isactive');

            $('#lblVwCourseName').text(courseName || 'N/A');
            $('#lblVwCourseStatus').html(isActive == 1 ?
                '<span class="badge badge-success">Active</span>' :
                '<span class="badge badge-danger">Inactive</span>');

            $('#viewCourse').modal('show');
        });

        // 4. DELETE COURSE ✅ FIXED - Working perfectly
        $('.deleteCourses').click(function(e) {
            e.preventDefault();
            let courseName = $(this).data('coursename');
            let courseId = $(this).data('courseid');

            $('#lblDelCourseName').text(courseName || 'This course');
            $('#btnConfirmCourseDelete').data('courseid', courseId);
            $('#deleteCourse').modal('show');
        });

        $('#btnConfirmCourseDelete').click(function(e) {
            e.preventDefault();
            let courseId = $(this).data('courseid');

            $.ajax({
                url: '@Url.Action("DeleteCourse", "Course")',
                type: 'POST',
                data: { courseID: courseId },
                success: function(response) {
                    if (response.success) {
                        alert('✅ Course deleted successfully!');
                        $('#deleteCourse').modal('hide');
                        setTimeout(() => location.reload(), 500);
                    } else {
                        alert('❌ Delete failed: ' + (response.message || 'Please try again'));
                    }
                },
                error: function(xhr) {
                    console.error('Delete Error:', xhr);
                    alert('❌ Failed to delete course');
                }
            });
        });

        // INPUT VALIDATION
        $('#txtCourseName, #txtEditCourseName').on('input', function() {
            $(this).removeClass('is-invalid');
            $(this).next('.invalid-feedback').hide();
        });
    });
</script>
}