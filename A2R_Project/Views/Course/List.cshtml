@section Scripts {
    <script>
                function noAccess(type) {
            Swal.fire({
                icon: 'error',
                title: 'Access Denied',
                text: 'You do not have ' + type + ' permission for Course module.',
                confirmButtonColor: '#dc2626'
            });
        }
        $(document).ready(function () {

            /* ── RESET ────────────────────────────────────── */
            function resetForm(formId) {
                $(formId).find('input[type="text"], input[type="checkbox"]').val('').prop('checked', false);
                $('.validationMessage, .invalid-feedback').html('').hide();
                $('input').removeClass('is-invalid');
            }

            $('#addCourse, #editCourse').on('hidden.bs.modal', function () {
                resetForm('#addCourseForm');
                resetForm('#editCourseForm');
            });

            /* ── SHOW ALL ─────────────────────────────────── */
            var rowsPerPage = 5;
            var currentPage = 1;

            function getCourseRows() { return $('#courseTable tbody tr'); }

            function showCoursePage(page) {
                var rows = getCourseRows();
                rows.hide();
                rows.slice((page - 1) * rowsPerPage, page * rowsPerPage).show();
            }

            showCoursePage(currentPage);

            $('#showAllCourses').click(function () {
                getCourseRows().show();
                $('.pagination').closest('.row').hide();
            });

            /* ── ADD COURSE ───────────────────────────────── */
            $('#btnCourseSave').click(function (e) {
                e.preventDefault();
                var courseName = $('#txtCourseName').val().trim();
                if (!courseName) {
                    $('#txtCourseName').addClass('is-invalid');
                    $('#msgAddCourseValidation').html('Course name is required!').show();
                    return;
                }
                var courseData = {
                    CourseName: courseName,
                    IsActive: $('#chkActiveStatus').is(':checked') ? 1 : 0,
                    IsDeleted: 0
                };
                $.ajax({
                    url: '@Url.Action("Save", "Course")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(courseData),
                    success: function (response) {
                        if (response.success) {
                            alert('✅ Course added successfully!');
                            $('#addCourse').modal('hide');
                            setTimeout(() => location.reload(), 500);
                        } else {
                            alert('❌ Error: ' + (response.message || 'Failed to add course'));
                        }
                    },
                    error: function () { alert('❌ Failed to add course. Please try again.'); }
                });
            });

            /* ── EDIT — open ──────────────────────────────── */
            $('.editByCourseId').click(function (e) {
                e.preventDefault();
                $('#hdnCourseId').val($(this).data('courseid'));
                $('#txtEditCourseName').val($(this).data('coursename'));
                $('#chkActiveStatusEdit').prop('checked', $(this).data('isactive') == 1);
                $('#editCourse').modal('show');
            });

            /* ── EDIT — save ──────────────────────────────── */
            $('#btnEditCourseSave').click(function (e) {
                e.preventDefault();
                var courseId   = $('#hdnCourseId').val();
                var courseName = $('#txtEditCourseName').val().trim();
                if (!courseName) {
                    $('#txtEditCourseName').addClass('is-invalid');
                    $('#msgEditCourseValidation').html('Course name is required!').show();
                    return;
                }
                var courseData = {
                    CourseID:   parseInt(courseId),
                    CourseName: courseName,
                    IsActive:   $('#chkActiveStatusEdit').is(':checked') ? 1 : 0,
                    IsDeleted:  0
                };
                $.ajax({
                    url: '@Url.Action("Edit", "Course")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(courseData),
                    success: function (response) {
                        if (response.success) {
                            alert('✅ Course updated successfully!');
                            $('#editCourse').modal('hide');
                            setTimeout(() => location.reload(), 500);
                        } else {
                            alert('❌ Update failed: ' + (response.message || 'Please try again'));
                        }
                    },
                    error: function () { alert('❌ Failed to update course'); }
                });
            });

            /* ── VIEW ─────────────────────────────────────── */
            $('.viewByCourseId').click(function (e) {
                e.preventDefault();
                var courseName = $(this).data('coursename');
                var isActive   = $(this).data('isactive');
                $('#lblVwCourseName').text(courseName || 'N/A');
                $('#lblVwCourseStatus').html(isActive == 1
                    ? '<span class="badge badge-success">Active</span>'
                    : '<span class="badge badge-danger">Inactive</span>');
                $('#viewCourse').modal('show');
            });

            /* ── DELETE — open ────────────────────────────── */
            $('.deleteCourses').click(function (e) {
                e.preventDefault();
                $('#lblDelCourseName').text($(this).data('coursename') || 'This course');
                $('#btnConfirmCourseDelete').data('courseid', $(this).data('courseid'));
                $('#deleteCourse').modal('show');
            });

            /* ── DELETE — confirm ─────────────────────────── */
            $('#btnConfirmCourseDelete').click(function (e) {
                e.preventDefault();
                var courseId = $(this).data('courseid');
                $.ajax({
                    url: '@Url.Action("DeleteCourse", "Course")',
                    type: 'POST',
                    data: { courseID: courseId },
                    success: function (response) {
                        if (response.success) {
                            alert('✅ Course deleted successfully!');
                            $('#deleteCourse').modal('hide');
                            setTimeout(() => location.reload(), 500);
                        } else {
                            alert('❌ Delete failed: ' + (response.message || 'Please try again'));
                        }
                    },
                    error: function () { alert('❌ Failed to delete course'); }
                });
            });

            /* ── INPUT VALIDATION ─────────────────────────── */
            $('#txtCourseName, #txtEditCourseName').on('input', function () {
                $(this).removeClass('is-invalid');
                $(this).next('.invalid-feedback').hide();
            });

        });
    </script>
    <script>
        // ========== COURSES STATIC PAGINATION + SHOW ALL (SEPARATE SCRIPT) ==========
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🚀 Courses Pagination Script Loaded!');

            // Get table elements
            const table = document.getElementById("courseTable");
            const tbody = table.querySelector("tbody");
            const allRows = Array.from(tbody.querySelectorAll("tr:not(.empty-state-row)"));
            const paginationContainer = document.getElementById("coursePagination");
            const showAllBtn = document.getElementById("showAllCoursesBtn");

            let currentPage = 1;
            const rowsPerPage = 8; // Perfect for your design

            // ========== MAIN PAGINATION FUNCTION ==========
            function showPage(pageNum) {
                currentPage = pageNum;

                // Hide all rows first
                allRows.forEach(row => row.style.display = 'none');

                // Calculate visible rows
                const startIndex = (pageNum - 1) * rowsPerPage;
                const endIndex = startIndex + rowsPerPage;
                const visibleRows = allRows.slice(startIndex, endIndex);

                // Show only visible rows
                visibleRows.forEach(row => row.style.display = '');

                // Update pagination UI
                renderPagination();
                console.log(`📄 Page ${pageNum} shown (${visibleRows.length} rows)`);
            }

            // ========== RENDER PAGINATION UI ==========
            function renderPagination() {
                const totalPages = Math.ceil(allRows.length / rowsPerPage);

                if (totalPages <= 1) {
                    paginationContainer.innerHTML = '';
                    return;
                }

                paginationContainer.innerHTML = '';

                // LEFT SIDE: Previous Button with Arrow
                const prevBtn = createPageButton(
                    '<i class="mdi mdi-chevron-left mr-1"></i>Previous',
                    currentPage > 1,
                    () => {
                        if (currentPage > 1) showPage(currentPage - 1);
                    }
                );
                paginationContainer.appendChild(prevBtn);

                // CENTER: Page Numbers (Smart: max 7 visible)
                const maxVisible = 7;
                let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
                let endPage = Math.min(totalPages, startPage + maxVisible - 1);

                if (endPage - startPage + 1 < maxVisible) {
                    startPage = Math.max(1, endPage - maxVisible + 1);
                }

                // First page (if not visible)
                if (startPage > 1) {
                    paginationContainer.appendChild(createPageButton('1', true, () => showPage(1)));
                    if (startPage > 2) {
                        const dots = document.createElement('li');
                        dots.innerHTML = '<a href="#" class="page-link">...</a>';
                        dots.style.cursor = 'default';
                        paginationContainer.appendChild(dots);
                    }
                }

                // Main page buttons
                for (let i = startPage; i <= endPage; i++) {
                    const pageBtn = createPageButton(i.toString(), true, () => showPage(i));
                    if (i === currentPage) pageBtn.classList.add('active');
                    paginationContainer.appendChild(pageBtn);
                }

                // Last page (if not visible)
                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) {
                        const dots = document.createElement('li');
                        dots.innerHTML = '<a href="#" class="page-link">...</a>';
                        dots.style.cursor = 'default';
                        paginationContainer.appendChild(dots);
                    }
                    paginationContainer.appendChild(createPageButton(totalPages.toString(), true, () => showPage(totalPages)));
                }

                // RIGHT SIDE: Next Button with Arrow
                const nextBtn = createPageButton(
                    'Next<i class="mdi mdi-chevron-right ml-1"></i>',
                    currentPage < totalPages,
                    () => {
                        if (currentPage < totalPages) showPage(currentPage + 1);
                    }
                );
                paginationContainer.appendChild(nextBtn);
            }

            // ========== CREATE PAGE BUTTON ==========
            function createPageButton(text, enabled, onClick) {
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = '#';
                a.className = 'page-link';
                a.innerHTML = text;

                if (!enabled) {
                    li.classList.add('disabled');
                    a.style.cursor = 'not-allowed';
                } else {
                    a.addEventListener('click', function(e) {
                        e.preventDefault();
                        onClick();
                    });
                }

                li.appendChild(a);
                return li;
            }

            // ========== SHOW ALL BUTTON ==========
            showAllBtn.addEventListener('click', function() {
                allRows.forEach(row => row.style.display = '');
                paginationContainer.innerHTML = '';
                showAllBtn.style.display = 'none';
                console.log('✅ Show All - All rows visible!');
            });

            // ========== INITIALIZE ==========
            if (allRows.length > rowsPerPage) {
                showPage(1);
            } else {
                allRows.forEach(row => row.style.display = '');
            }

            console.log(`✅ Courses Pagination Ready! ${allRows.length} rows | ${Math.ceil(allRows.length / rowsPerPage)} pages`);
        });
    </script>
}