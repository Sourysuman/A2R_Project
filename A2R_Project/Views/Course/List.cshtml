@model IEnumerable<A2R_Project.Models.Course>
@{
    ViewBag.Title = "Courses List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/@@mdi/font@6.5.95/css/materialdesignicons.min.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fbff);
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card-title {
        font-size: 20px;
        font-weight: 700;
        color: #2c3e50;
        letter-spacing: 0.5px;
    }

    /* ═══ TABLE ═══ */
    .table {
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
        border-collapse: collapse;
        border-spacing: 0;
    }

        .table thead th {
            color: #fff !important;
            border: none !important;
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            padding: 14px;
            text-align: center !important;
        }

        .table tbody td {
            font-size: 15px;
            font-weight: 600;
            color: #34495e;
            padding: 14px;
            vertical-align: middle !important;
            text-align: center !important;
            background-color:white !important;
        }

            .table tbody td:first-child {
                text-align: center !important;
                font-weight: 700 !important;
                color: #2c3e50 !important;
                font-size: 15px !important;
            }

        

    .action-cell {
        text-align: center !important;
        white-space: nowrap;
    }

    /* ═══ TABLE ACTION BUTTONS ═══ */
    .table .btn-sm {
        width: 36px !important;
        height: 36px !important;
        border-radius: 10px !important;
        padding: 0 !important;
        margin-right: 4px;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        border: none !important;
        transition: all 0.25s ease;
    }

        .table .btn-sm i {
            font-size: 16px !important;
            line-height: 1;
        }

        .table .btn-sm:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.15);
        }

        .table .btn-sm.btn-primary {
            background: linear-gradient(135deg, #4e73df, #224abe) !important;
            color: #fff !important;
        }

        .table .btn-sm.btn-info {
            background: linear-gradient(135deg, #36b9cc, #1f8ea3) !important;
            color: #fff !important;
        }

        .table .btn-sm.btn-danger {
            background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
            color: #fff !important;
        }

    /* ═══ BADGES ═══ */
    .badge-success {
        background: linear-gradient(135deg, #1cc88a, #17a673) !important;
        padding: 7px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        color: #fff !important;
    }

    .badge-danger {
        background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
        padding: 7px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        color: #fff !important;
    }

    /* ═══ ADD BUTTON ═══ */
    .btn-gradient-primary {
        background: linear-gradient(135deg, #28a745, #20c997) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 700;
        border-radius: 25px !important;
        padding: 8px 18px !important;
        transition: all 0.25s ease;
    }

        .btn-gradient-primary:hover {
            background: linear-gradient(135deg, #218838, #17a2b8) !important;
            color: #fff !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.15);
        }

    /* ═══ PAGINATION ═══ */
    .pagination .page-link {
        border-radius: 10px;
        margin: 0 4px;
        font-weight: 600;
        color: #4e73df;
        border: none;
        cursor: pointer;
        user-select: none;
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: #fff;
        border: none;
    }

    .pagination .page-link:hover {
        background: #e8edff;
    }

    /* ═══ TOGGLE SWITCH ═══ */
    .active-status-group {
        display: flex !important;
        flex-direction: row !important;
        align-items: center !important;
        gap: 12px !important;
        margin-top: 4px;
    }

    .form-check-input {
        width: 42px !important;
        height: 22px !important;
        border-radius: 22px !important;
        appearance: none !important;
        -webkit-appearance: none !important;
        background: #ccc !important;
        cursor: pointer;
        position: relative;
        transition: background 0.3s ease;
        margin: 0 !important;
        flex-shrink: 0;
    }

        .form-check-input::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #fff;
            top: 3px;
            left: 3px;
            transition: left 0.3s ease;
            box-shadow: 0 1px 4px rgba(0,0,0,0.2);
        }

        .form-check-input:checked {
            background: linear-gradient(135deg, #4e73df, #224abe) !important;
        }

            .form-check-input:checked::after {
                left: 22px !important;
            }

    .active-status-group .form-check-label,
    .active-status-group label {
        display: inline-flex !important;
        align-items: center !important;
        margin-bottom: 0 !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        color: #2c3e50 !important;
        cursor: pointer !important;
    }

    /* ═══ VALIDATION ═══ */
    .form-control.is-invalid {
        border-color: #e74c3c !important;
    }

    .invalid-feedback {
        font-size: 12px;
        color: #e74c3c;
        margin-top: 3px;
        display: block;
    }

    /* ═══ MODAL ANIMATION ═══ */
    @@keyframes modalPop {
        from {
            transform: scale(0.93);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .modal {
        backdrop-filter: blur(4px);
    }

    /* ═══ ALL 4 MODALS - SAME SIZE ═══ */
    #addCourse .modal-dialog,
    #editCourse .modal-dialog,
    #viewCourse .modal-dialog,
    #deleteCourse .modal-dialog {
        max-width: 700px !important;
        width: 95vw !important;
        margin: 80px auto 1.75rem auto !important;
    }

    #addCourse .modal-content,
    #editCourse .modal-content,
    #viewCourse .modal-content,
    #deleteCourse .modal-content {
        border-radius: 18px !important;
        border: none !important;
        box-shadow: 0 12px 40px rgba(0,0,0,0.18) !important;
        overflow: hidden !important;
        height: auto !important;
        max-height: 90vh !important;
        animation: modalPop 0.28s ease;
    }

    /* ═══ MODAL HEADER ═══ */
    #addCourse .modal-header,
    #editCourse .modal-header,
    #viewCourse .modal-header,
    #deleteCourse .modal-header {
        background: linear-gradient(135deg, #4e73df, #224abe) !important;
        color: #fff !important;
        padding: 18px 24px !important;
        border-bottom: none !important;
        border-radius: 18px 18px 0 0 !important;
        min-height: 62px !important;
    }

    #addCourse .modal-title,
    #editCourse .modal-title,
    #viewCourse .modal-title,
    #deleteCourse .modal-title {
        color: #fff !important;
        font-size: 17px !important;
        font-weight: 700 !important;
        letter-spacing: 0.4px !important;
    }

    #addCourse .modal-header .close,
    #editCourse .modal-header .close,
    #viewCourse .modal-header .close,
    #deleteCourse .modal-header .close {
        color: #fff !important;
        opacity: 0.9 !important;
        font-size: 26px !important;
        text-shadow: none !important;
    }

        #addCourse .modal-header .close:hover,
        #editCourse .modal-header .close:hover,
        #viewCourse .modal-header .close:hover,
        #deleteCourse .modal-header .close:hover {
            opacity: 1 !important;
        }

    /* ═══ MODAL BODY ═══ */
    #addCourse .modal-body,
    #editCourse .modal-body,
    #viewCourse .modal-body,
    #deleteCourse .modal-body {
        padding: 24px 28px !important;
        background: #f9fbff !important;
        height: auto !important;
        max-height: none !important;
        overflow-y: visible !important;
    }

    /* ═══ MODAL FOOTER ═══ */
    #addCourse .modal-footer,
    #editCourse .modal-footer,
    #viewCourse .modal-footer,
    #deleteCourse .modal-footer {
        background: #fff !important;
        border-top: 1px solid #eee !important;
        padding: 14px 24px !important;
        display: flex !important;
        justify-content: flex-end !important;
        gap: 10px !important;
        border-radius: 0 0 18px 18px !important;
        min-height: 62px !important;
    }

        #addCourse .modal-footer .btn,
        #editCourse .modal-footer .btn,
        #viewCourse .modal-footer .btn,
        #deleteCourse .modal-footer .btn {
            border-radius: 10px !important;
            padding: 9px 22px !important;
            font-weight: 600 !important;
            font-size: 14px !important;
            border: none !important;
            min-width: 90px;
            transition: all 0.25s ease !important;
        }

            #addCourse .modal-footer .btn:hover,
            #editCourse .modal-footer .btn:hover,
            #viewCourse .modal-footer .btn:hover,
            #deleteCourse .modal-footer .btn:hover {
                transform: translateY(-2px) !important;
                box-shadow: 0 6px 16px rgba(0,0,0,0.15) !important;
            }

        #addCourse .modal-footer .btn-secondary,
        #editCourse .modal-footer .btn-secondary,
        #viewCourse .modal-footer .btn-secondary,
        #deleteCourse .modal-footer .btn-secondary {
            background: #6c757d !important;
            color: #fff !important;
        }

        #addCourse .modal-footer .btn-success {
            background: linear-gradient(135deg, #28a745, #20c997) !important;
            color: #fff !important;
        }

        #editCourse .modal-footer .btn-warning {
            background: linear-gradient(135deg, #f6c23e, #e0a800) !important;
            color: #000 !important;
        }

        #viewCourse .modal-footer .btn-info {
            background: linear-gradient(135deg, #36b9cc, #1f8ea3) !important;
            color: #fff !important;
        }

        #deleteCourse .modal-footer .btn-danger {
            background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
            color: #fff !important;
        }

    /* ═══ FORM INSIDE MODAL ═══ */
    .modal .form-group {
        margin-bottom: 18px;
        display: block !important;
    }

        .modal .form-group label {
            font-size: 13px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 6px;
            display: block;
            width: auto !important;
        }

    .modal .form-control {
        height: 42px;
        border-radius: 10px;
        border: 1.5px solid #dce3f0;
        font-size: 14px;
        font-weight: 600;
        padding: 8px 12px;
        transition: all 0.25s ease;
        flex: none !important;
    }

        .modal .form-control:focus {
            border-color: #4e73df;
            box-shadow: 0 0 0 3px rgba(78,115,223,0.15);
            background: #fff;
        }

    /* ═══ VIEW MODAL ═══ */
    #viewCourse .view-label {
        font-size: 13px;
        font-weight: 700;
        color: #374151;
        margin-bottom: 5px;
        display: block;
    }

    #viewCourse .view-value {
        font-size: 15px;
        font-weight: 600;
        color: #111827;
        background: linear-gradient(135deg, #fff, #f8fbff);
        border: 1.5px solid #e8f0fe;
        border-radius: 10px;
        padding: 10px 14px;
        min-height: 42px;
        display: flex;
        align-items: center;
        margin-bottom: 0;
    }

    /* ═══ DELETE MODAL ═══ */
    #deleteCourse .modal-body {
        text-align: center !important;
    }

    #deleteCourse .del-icon-wrap {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(231,74,59,0.1);
        margin: 0 auto 16px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        #deleteCourse .del-icon-wrap i {
            font-size: 2rem;
            color: #e74a3b;
        }

    #deleteCourse .del-title {
        font-size: 17px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 8px;
    }

    #deleteCourse .del-subtitle {
        font-size: 14px;
        color: #6c757d;
        margin-bottom: 0;
    }

    /* ═══ MODAL BACKDROP ═══ */
    .modal-backdrop {
        opacity: 0.25 !important;
    }

    /* ═══ RESPONSIVE ═══ */
    @@media (max-width: 768px) {
        #addCourse .modal-dialog,
        #editCourse .modal-dialog,
        #viewCourse .modal-dialog,
        #deleteCourse .modal-dialog {
            width: calc(100vw - 20px) !important;
            margin: 10px auto !important;
        }
    }
    /* ===== STATIC PAGINATION (Copy from Countries) ===== */
    .static-pagination-wrapper {
        padding: 15px 20px;
        background: #f8fafc;
        border-top: 1px solid #e2e8f0;
        border-radius: 0 0 14px 14px;
    }

    .pagination-modern {
        display: flex;
        gap: 8px;
        list-style: none;
        margin: 0;
        padding: 0;
        justify-content: center;
    }

        .pagination-modern li {
            cursor: pointer;
        }

            .pagination-modern li a {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 8px 14px;
                border-radius: 10px;
                background: #f1f5f9;
                color: #475569;
                font-weight: 600;
                font-size: 14px;
                text-decoration: none;
                transition: all 0.25s ease;
                border: 1px solid #e2e8f0;
                min-width: 44px;
                justify-content: center;
            }

                .pagination-modern li a:hover {
                    background: #3b82f6;
                    color: #fff;
                    border-color: #3b82f6;
                    transform: translateY(-1px);
                }

            .pagination-modern li.active a {
                background: linear-gradient(135deg, #3b82f6, #1d4ed8);
                color: #fff;
                border-color: #3b82f6;
                box-shadow: 0 4px 12px rgba(59,130,246,0.3);
            }

            .pagination-modern li.disabled a {
                opacity: 0.5;
                cursor: not-allowed;
                transform: none !important;
            }

    #showAllCoursesBtn {
        background: linear-gradient(135deg, #10b981, #059669) !important;
        color: #fff !important;
        font-weight: 600 !important;
        padding: 10px 20px !important;
        border-radius: 10px !important;
        border: none !important;
        transition: 0.25s !important;
    }

        #showAllCoursesBtn:hover {
            transform: scale(1.05) !important;
            box-shadow: 0 6px 20px rgba(16,185,129,0.4) !important;
        }
</style>

<!-- ═══ MAIN TABLE ═══ -->
<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Courses List</strong>
                @if (ViewBag.CanInsert == true)
                {
                    <button type="button" class="btn btn-gradient-primary btn-rounded btn-fw"
                            data-toggle="modal" data-target="#addCourse">
                        <i class="fa fa-plus mr-1"></i> Add Course
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-secondary btn-rounded btn-fw"
                            onclick="noAccess('Insert')">
                        <i class="fa fa-plus mr-1"></i> Add Course
                    </button>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="courseTable">
                    <thead class="thead-dark">
                        <tr>
                            <th>Course Name</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr data-courseid="@item.CourseID">
                                    <td>@item.CourseName</td>
                                    <td>
                                        @if (item.IsActive == 1)
                                        {
                                            <span class="badge badge-success p-2">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger p-2">Inactive</span>
                                        }
                                    </td>
                                    
                                    <td class="action-cell">

                                        @* EDIT *@
                                        @if (ViewBag.CanUpdate == true)
                                        {
                                            <button type="button" class="btn btn-sm btn-primary editByCourseId"
                                                    data-courseid="@item.CourseID"
                                                    data-coursename="@item.CourseName"
                                                    data-isactive="@item.IsActive"
                                                    title="Edit">
                                                <i class="mdi mdi-pencil"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-secondary"
                                                    title="No Edit Permission"
                                                    onclick="noAccess('Update')">
                                                <i class="mdi mdi-pencil"></i>
                                            </button>
                                        }

                                        @* VIEW — always visible *@
                                        <button type="button" class="btn btn-sm btn-info viewByCourseId"
                                                data-courseid="@item.CourseID"
                                                data-coursename="@item.CourseName"
                                                data-isactive="@item.IsActive"
                                                title="View">
                                            <i class="mdi mdi-eye"></i>
                                        </button>

                                        @* DELETE *@
                                        @if (ViewBag.CanDelete == true)
                                        {
                                            <button type="button" class="btn btn-sm btn-danger deleteCourses"
                                                    data-courseid="@item.CourseID"
                                                    data-coursename="@item.CourseName"
                                                    title="Delete">
                                                <i class="mdi mdi-delete"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-secondary"
                                                    title="No Delete Permission"
                                                    onclick="noAccess('Delete')">
                                                <i class="mdi mdi-delete"></i>
                                            </button>
                                        }

                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">No courses found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- ✅ REPLACE THIS OLD PAGINATION with STATIC PAGINATION -->
            <div class="static-pagination-wrapper">
                <div class="d-flex justify-content-between align-items-center">
                    <button id="showAllCoursesBtn" class="btn btn-gradient-primary">
                        <i class="mdi mdi-view-grid mr-2"></i>Show All
                    </button>
                    <ul class="pagination pagination-modern mb-0" id="coursePagination"></ul>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- ═══ ADD COURSE MODAL ═══ -->
<div class="modal fade" id="addCourse" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-plus-circle mr-2"></i>Add New Course
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="addCourseForm">
                    <div class="form-group">
                        <label>Course Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtCourseName"
                               placeholder="Enter course name">
                        <div class="invalid-feedback" id="msgAddCourseValidation"></div>
                    </div>
                    <div class="form-group mb-0">
                        <div class="active-status-group">
                            <label style="margin-bottom:0; font-size:14px; font-weight:700; color:#2c3e50;">
                                Active Status:
                            </label>
                            <input type="checkbox" class="form-check-input" id="chkActiveStatus" checked>
                            <label class="form-check-label" for="chkActiveStatus" style="margin-bottom:0;">
                                Active
                            </label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-success" id="btnCourseSave">
                    <i class="fas fa-save mr-1"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>


<!-- ═══ EDIT COURSE MODAL ═══ -->
<div class="modal fade" id="editCourse" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-edit mr-2"></i>Edit Course
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editCourseForm">
                    <input type="hidden" id="hdnCourseId">
                    <div class="form-group">
                        <label>Course Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtEditCourseName"
                               placeholder="Enter course name">
                        <div class="invalid-feedback" id="msgEditCourseValidation"></div>
                    </div>
                    <div class="form-group mb-0">
                        <div class="active-status-group">
                            <label style="margin-bottom:0; font-size:14px; font-weight:700; color:#2c3e50;">
                                Active Status:
                            </label>
                            <input type="checkbox" class="form-check-input" id="chkActiveStatusEdit">
                            <label class="form-check-label" for="chkActiveStatusEdit" style="margin-bottom:0;">
                                Active
                            </label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-warning" id="btnEditCourseSave">
                    <i class="fas fa-save mr-1"></i> Update
                </button>
            </div>
        </div>
    </div>
</div>


<!-- ═══ VIEW COURSE MODAL ═══ -->
<div class="modal fade" id="viewCourse" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-eye mr-2"></i>Course Details
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center mb-3" style="gap:16px;">
                    <label class="view-label" style="min-width:130px; margin-bottom:0;">Course Name</label>
                    <p class="view-value mb-0" id="lblVwCourseName" style="flex:1;">-</p>
