                GSTNo: $('#txtGST').val().trim().toUpperCase(),
                PTTaxNo: $('#txtPT').val().trim(),
                Email: $('#txtEmail').val().trim(),
                ContactNo: $('#txtContactNo').val().trim(),
                IsActive: $('#chkActiveStatusAdd').is(':checked') ? 1 : 0
            };

            $.ajax({
                type: "POST",
