            backdrop-filter: blur(3px);
        }

    .modal-content {
        border-radius: 18px;
        border: none;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        animation: popIn 0.25s ease-in-out;
    }

    @@keyframes popIn {
        from {
            transform: scale(0.8);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .modal-header {
        background: linear-gradient(135deg, #5b55e6, #7b74ff);
