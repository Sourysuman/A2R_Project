        $(document).on('click', '#btnBranchSave', function (e) {
            e.preventDefault();
            if (!validateAddForm()) return false;

            var branchData = {
                BranchId: 0,
                CompanyID: parseInt($('#ddlCompanyId').val()) || 0,
                BranchName: $('#txtBranchName').val().trim(),
                BranchAddress1: $('#txtBranchAddress1').val().trim(),
                City: $('#txtCity').val().trim(),
                Pincode: $('#txtPincode').val().trim(),
                BranchStateId: parseInt($('#ddlStateId').val()) || 0,
