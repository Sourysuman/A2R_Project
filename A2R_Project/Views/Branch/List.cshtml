    }

        .modal-header .close:hover {
            opacity: 1;
        }

    .modal-body {
        padding: 20px;
        background: #f9faff;
    }

    .form-control:hover, .custom-select:hover {
        border-color: #7b74ff;
        box-shadow: 0 3px 10px rgba(123, 116, 255, 0.15);
    }

    /* BUTTON STYLES */
    .btn-modern {
        border-radius: 8px;
        padding: 6px 14px;
        border: none;
        transition: 0.2s;
    }

        .btn-modern:hover {
            transform: scale(1.05);
            opacity: 0.9;
        }

    .btn-primary-modern {
        background: linear-gradient(135deg, #4e73df, #224abe) !important;
        color: #fff !important;
    }

    .btn-info-modern {
        background: linear-gradient(135deg, #36b9cc, #1f8ea3) !important;
        color: #fff !important;
    }

    .btn-danger-modern {
        background: linear-gradient(135deg, #ef4444, #b91c1c) !important;
        color: #fff !important;
    }

    .btn-warning-modern {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: #fff;
    }

    .btn-success-modern {
        background: linear-gradient(135deg, #10b981, #047857);
        color: #fff;
    }

    /* TOGGLE SWITCH */
    .toggle-wrapper {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

    .switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: #ccc;
        transition: 0.4s;
        border-radius: 34px;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background: white;
            transition: 0.4s;
            border-radius: 50%;
        }

    .switch input:checked + .slider {
        background: linear-gradient(135deg, #10b981, #059669);
        box-shadow: 0 0 10px rgba(16,185,129,0.5);
    }

        .switch input:checked + .slider:before {
            transform: translateX(24px);
        }

    .switch input:disabled + .slider {
        opacity: 0.75;
        cursor: not-allowed;
    }

    .toggle-label {
        font-weight: 600;
        color: #333;
    }

