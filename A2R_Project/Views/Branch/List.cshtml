                    var ptVal  = response.PTTaxNo || response.ptTaxNo || response.PtTaxNo || response.pttaxno || response.PTTAXNO
                               || response.PTNo || response.ptNo || response.PT || response.pt
                               || response.BranchPttaxNo || response.branchPttaxNo
                               || response.ProfessionalTax || response.professionalTax || '';
                    $('#lblvwPT').val(ptVal.toString());

                    // ACTIVE STATUS TOGGLE + BADGE
                    var rawActive = response.IsActive || response.isActive || response.is_active || response.Active || response.active;
