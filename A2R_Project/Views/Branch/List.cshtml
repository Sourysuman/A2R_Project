@model A2R_Project.Models.BranchViewModel

@{
    ViewBag.Title = "Branch List";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Adjust as per your layout
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
    /* ================= GLOBAL ================= */
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fbff);
        font-family: 'Segoe UI', sans-serif;
    }

    /* ================= CARD ================= */
    .card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
    }

    .card-title {
        font-size: 20px;
        font-weight: 600;
        color: #4b49ac;
    }

    /* ================= TABLE ================= */
    #branchTable {
        border-radius: 12px;
        overflow: hidden;
        background: #ffffff;
    }

        #branchTable thead {
            background: linear-gradient(135deg, #4b49ac, #6c63ff);
            color: #fff;
            text-transform: uppercase;
            font-size: 13px;
            letter-spacing: 0.5px;
        }

            #branchTable thead th {
                border: none;
                padding: 12px;
                text-align: center;
            }

        #branchTable tbody td {
            font-size: 14px;
            font-weight: 600;
            color: #333;
            padding: 12px;
            vertical-align: middle;
        }

        /* Row Colors */
        #branchTable tbody tr {
            transition: all 0.3s ease;
            background: #f9fbff;
        }

            #branchTable tbody tr:nth-child(even) {
                background: #f1f4ff;
            }

            /* Hover Effect */
            #branchTable tbody tr:hover {
                background: #e0e7ff !important;
                transform: scale(1.01);
                box-shadow: 0 6px 15px rgba(0,0,0,0.08);
                cursor: pointer;
            }

    /* Highlight cells */
    .table-primary {
        color: #4b49ac !important;
        font-weight: 600;
    }

    .table-warning {
        color: #ff9800 !important;
        font-weight: 600;
    }

    /* ================= BADGE ================= */
    .badge-success {
        background: linear-gradient(135deg, #28a745, #5dd39e);
        padding: 6px 10px;
        font-size: 12px;
        border-radius: 8px;
    }

    .badge-danger {
        background: linear-gradient(135deg, #dc3545, #ff6b6b);
        padding: 6px 10px;
        font-size: 12px;
        border-radius: 8px;
    }

    /* ================= BUTTONS ================= */
    .btn {
        border-radius: 25px !important;
        font-size: 13px;
        padding: 6px 14px;
        transition: all 0.3s ease;
    }

        .btn i {
            font-size: 14px;
        }

    /* Gradient Buttons */
    .btn-gradient-primary {
        background: linear-gradient(135deg, #4b49ac, #6c63ff);
        color: #fff;
        border: none;
    }

        .btn-gradient-primary:hover {
            background: linear-gradient(135deg, #3a38a0, #5a52ff);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(75, 73, 172, 0.3);
        }

    .btn-gradient-dark {
        background: linear-gradient(135deg, #343a40, #6c757d);
        color: #fff;
        border: none;
    }

        .btn-gradient-dark:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }

    .btn-gradient-warning {
        background: linear-gradient(135deg, #ff9800, #ffc107);
        color: #fff;
        border: none;
    }

        .btn-gradient-warning:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(255,152,0,0.3);
        }

    /* ================= ACTION BUTTON GROUP ================= */
    td .btn {
        margin-right: 5px;
    }

    /* ================= PAGINATION ================= */
    .pagination .page-link {
        border-radius: 8px;
        margin: 0 3px;
        color: #4b49ac;
        font-weight: 600;
    }

    .pagination .page-item.active .page-link {
        background: #4b49ac;
        color: #fff;
        border: none;
    }

    .pagination .page-link:hover {
        background: #e0e7ff;
    }

    /* ================= MODAL ================= */
    .modal-content {
        border-radius: 18px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.2);
    }

    .modal-header {
        border-radius: 18px 18px 0 0;
    }

    .form-control {
        border-radius: 10px;
        font-size: 13px;
        padding: 8px 10px;
    }

        .form-control:focus {
            border-color: #6c63ff;
            box-shadow: 0 0 5px rgba(108,99,255,0.3);
        }

    /* ================= CHECKBOX ================= */
    .rounded-checkbox {
        transform: scale(1.2);
        margin-right: 5px;
    }

</style>
<style>

