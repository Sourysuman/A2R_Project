                    $('#lblvwBranchState').val(response.StateName || response.stateName || response.State_Name || '');
                    $('#lblvwBranchCountry').val(response.CountryName || response.countryName || response.Country_Name || '');
                    // ROW 2
                    $('#lblvwBranchCity').val(response.City || response.city || response.BranchCity || response.branchCity || '');
                    $('#lblvwPincode').val(response.Pincode || response.pincode || response.PinCode || response.pinCode || response.BranchPincode || response.branchPincode || '');
                    $('#lblvwCompanyName').val(response.CompanyName || response.companyName || response.Company_Name || '');
                    $('#lblvwVAT').val(response.VATNo || response.vatNo || response.VatNo || response.vATNo || response.BranchVatNo || response.branchVatNo || response.VAT || response.vat || '');
                    // ROW 3
                    $('#lblvwContactNo').val(response.ContactNo || response.contactNo || response.ContactNumber || response.contactNumber || response.BranchContactNo || response.branchContactNo || '');
                    $('#lblvwBranchEmail').val(response.Email || response.email || response.BranchEmail || response.branchEmail || response.EmailId || response.emailId || '');
                    // ROW 3 - PAN & TAN (most likely cause of blank)
                    var panVal = response.PANNo || response.panNo || response.PanNo || response.panno || response.PANNO
                               || response.PAN || response.pan || response.BranchPanNo || response.branchPanNo
                               || response.PANNumber || response.panNumber || '';
                    $('#lblvwPAN').val(panVal.toString().toUpperCase());

                    var tanVal = response.TANNo || response.tanNo || response.TanNo || response.tanno || response.TANNO
                               || response.TAN || response.tan || response.BranchTanNo || response.branchTanNo
                               || response.TANNumber || response.tanNumber || '';
                    $('#lblvwTAN').val(tanVal.toString().toUpperCase());
                    // ROW 4 - GST & PT (most likely cause of blank)
                    var gstVal = response.GSTNo || response.gstNo || response.GstNo || response.gstno || response.GSTNO
                               || response.GST || response.gst || response.BranchGstNo || response.branchGstNo
                               || response.GSTNumber || response.gstNumber || response.GSTRegistrationNo || '';
