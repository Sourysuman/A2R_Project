        // =============================================
        // LOAD EDIT DATA
        // =============================================
        function loadBranchForEdit(branchId) {
            $.ajax({
                type: "GET",
                url: '/Branch/GetBranch?branchId=' + branchId,
                dataType: "json",
                success: function (response) {
                    if (response) {
                        $('#editBranchForm .form-control, #editBranchForm select').removeClass('input-validation-error input-success');
                        $('.validationMessage[id^="msgEdit"]').text('');

                        $('#hdnBranchId').val(response.BranchId || response.branchId);
                        $('#txtEditBranchName').val(response.BranchName || response.branchName);
                        $('#txtEditBranchAddress1').val(response.Address1 || response.address1 || response.BranchAddress1);
                        $('#txtEditCity').val(response.City || response.city || response.BranchCity);
                        $('#ddlEditStateId').val(response.BranchStateId || response.branchStateId);
                        $('#ddlEditCountryId').val(response.BranchCountryId || response.branchCountryId);
                        $('#ddlEditCompanyId').val(response.CompanyID || response.companyID);
                        $('#txtEditPincode').val(response.Pincode || response.pincode || response.BranchPincode);
                        $('#txtEditPAN').val((response.PANNo || response.panNo || response.BranchPanNo || '').toUpperCase());
                        $('#txtEditTAN').val((response.TANNo || response.tanNo || response.BranchTanNo || '').toUpperCase());
                        $('#txtEditVAT').val(response.VATNo || response.vatNo || response.BranchVatNo);
                        $('#txtEditGST').val((response.GSTNo || response.gstNo || response.BranchGstNo || '').toUpperCase());
                        $('#txtEditPT').val(response.PTTaxNo || response.ptTaxNo || response.BranchPttaxNo);
                        $('#txtEditEmail').val(response.Email || response.email || response.BranchEmail);
                        $('#txtEditContactNo').val(response.ContactNo || response.contactNo || response.BranchContactNo);
                        $('#chkEditActiveStatus').prop('checked', (response.IsActive == 1 || response.isActive === true));
                        $('#editBranch').modal('show');
                    }
                },
                error: function (xhr) {
                    console.error('EDIT LOAD ERROR:', xhr.responseText);
                }
            });
        }

