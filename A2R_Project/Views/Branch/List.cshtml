<script>
$(document).ready(function () {

    // ================= COMMON FUNCTIONS =================

    function setError(input, messageId, message) {
        $(input).addClass("input-validation-error").removeClass("input-success");
        $("#" + messageId).text(message);
    }

    function setSuccess(input, messageId) {
        $(input).removeClass("input-validation-error").addClass("input-success");
        $("#" + messageId).text("");
    }

    function isValidEmail(email) {
        return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
    }

    function isValidPhone(phone) {
        return /^[6-9]\d{9}$/.test(phone);
    }

    function isValidPincode(pin) {
        return /^\d{6}$/.test(pin);
    }

    // ================= ADD VALIDATION =================

    function validateAddForm() {
        let isValid = true;

        let name = $("#txtBranchName").val().trim();
        let address = $("#txtBranchAddress1").val().trim();
        let city = $("#txtCity").val().trim();
        let pincode = $("#txtPincode").val().trim();
        let state = $("#ddlStateId").val();
        let country = $("#ddlCountryId").val();
        let company = $("#ddlCompanyId").val();
        let email = $("#txtEmail").val().trim();
        let phone = $("#txtContactNo").val().trim();

        if (name === "") {
