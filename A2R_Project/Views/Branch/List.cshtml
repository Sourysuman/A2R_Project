<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Branch List</strong>
                @if (ViewBag.CanInsert == true)
                {
                    <button type="button" class="btn btn-gradient-primary btn-rounded btn-fw"
                            data-toggle="modal" data-target="#addBranch">
                        <i class="fa fa-plus"></i> Add
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-secondary btn-rounded btn-fw"
                            onclick="noAccess('Insert')">
                        <i class="fa fa-plus"></i> Add
                    </button>
                }
            </div>
            <table class="table table-bordered" id="branchTable">
                <thead>
                    <tr>
                        <th>Branch Name</th>
                        <th>Company Name</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Country</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.branches != null && Model.branches.Count() > 0)
                    {
                        foreach (var branch in Model.branches)
                        {
                            <tr class="table-info">
                                <td class="table-primary">@branch.BranchName</td>
                                <td class="table-primary">@branch.CompanyName</td>
                                <td class="table-warning">@branch.Address1</td>
                                <td class="table-primary">@branch.City</td>
                                <td class="table-warning">@branch.StateName</td>
                                <td class="table-primary">@branch.CountryName</td>
                                <td class="table-warning">
                                    @if (branch.IsActive == 1)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @* EDIT *@
                                    @if (ViewBag.CanUpdate == true)
                                    {
                                        <button type="button" class="btn btn-sm editByBranchId"
                                                data-edbranchId="@branch.BranchId"
                                                data-toggle="modal" data-target="#editBranch"
                                                title="Edit">
                                            <i class="mdi mdi-pencil"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-secondary"
                                                title="No Edit Permission"
                                                onclick="noAccess('Update')">
                                            <i class="mdi mdi-pencil"></i>
                                        </button>
                                    }

                                    @* VIEW — always visible *@
                                    <button type="button" class="btn btn-sm viewByBranchId"
                                            data-vwBranchId="@branch.BranchId"
                                            data-toggle="modal" data-target="#viewBranch"
                                            title="View">
                                        <i class="mdi mdi-eye"></i>
                                    </button>

                                    @* DELETE *@
                                    @if (ViewBag.CanDelete == true)
                                    {
                                        <button type="button" class="btn btn-sm deleteBranches"
                                                data-dlbranchId="@branch.BranchId"
                                                data-toggle="modal" data-target="#deleteBranch"
                                                title="Delete">
                                            <i class="mdi mdi-delete"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-secondary"
                                                title="No Delete Permission"
                                                onclick="noAccess('Delete')">
                                            <i class="mdi mdi-delete"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center">No branches found</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="static-pagination-wrapper">
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <button class="btn-showall-modern" id="btnShowAll">
                        <i class="mdi mdi-view-grid"></i> Show All
                    </button>
                    <ul class="pagination modern-pagination mb-0" id="pagination"></ul>
                </div>
            </div>
        </div>
    </div>
</div>

