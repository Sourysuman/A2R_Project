<script>
    // ✅ OUTSIDE $(document).ready — global scope
    function noAccess(type) {
        Swal.fire({
            icon: 'error',
            title: 'Access Denied',
            text: 'You do not have ' + type + ' permission for Branch module.',
            confirmButtonColor: '#dc2626'
        });
    }
    $(document).ready(function () {

        // =============================================
        // COMMON VALIDATION HELPERS
        // =============================================
        function setError(inputId, messageId, message) {
            $(inputId).addClass("input-validation-error").removeClass("input-success");
            $("#" + messageId).text(message);
        }

        function setSuccess(inputId, messageId) {
            $(inputId).removeClass("input-validation-error").addClass("input-success");
            $("#" + messageId).text("");
        }

        function clearField(inputId, messageId) {
            $(inputId).removeClass("input-validation-error input-success");
            $("#" + messageId).text("");
        }

        // =============================================
        // REGEX PATTERNS
        // =============================================
        function isValidEmail(email) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@Z]+$/.test(email);
        }

        function isValidPhone(phone) {
            return /^[6-9]\d{9}$/.test(phone);
        }

        function isValidPincode(pin) {
            return /^\d{6}$/.test(pin);
        }

        function isValidPAN(pan) {
            return /^[A-Z]{5}[0-9]{4}[A-Z]{1}$/.test(pan.toUpperCase());
        }

        function isValidTAN(tan) {
            return /^[A-Z]{4}[0-9]{5}[A-Z]{1}$/.test(tan.toUpperCase());
        }

        function isValidGST(gst) {
            return /^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$/.test(gst.toUpperCase());
        }

        function isValidVAT(vat) {
            return vat.trim().length >= 3;
        }

        function isValidPT(pt) {
            return pt.trim().length >= 3;
        }

        // =============================================
        // ADD FORM - LIVE VALIDATION
        // =============================================
        $("#txtBranchName").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtBranchName", "msgAddBranchNameValidation", "Branch name is required.");
            else if (val.length < 2) setError("#txtBranchName", "msgAddBranchNameValidation", "Minimum 2 characters required.");
            else setSuccess("#txtBranchName", "msgAddBranchNameValidation");
        });

        $("#txtBranchAddress1").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtBranchAddress1", "msgAddress1Validation", "Address is required.");
            else if (val.length < 5) setError("#txtBranchAddress1", "msgAddress1Validation", "Enter a valid address (min 5 chars).");
            else setSuccess("#txtBranchAddress1", "msgAddress1Validation");
        });

        $("#txtCity").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtCity", "msgAddCityValidation", "City is required.");
            else if (!/^[a-zA-Z\s]+$/.test(val)) setError("#txtCity", "msgAddCityValidation", "City must contain letters only.");
            else setSuccess("#txtCity", "msgAddCityValidation");
        });

        $("#txtPincode").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtPincode", "msgAddPinCodeValidation", "Pin code is required.");
            else if (!isValidPincode(val)) setError("#txtPincode", "msgAddPinCodeValidation", "Enter a valid 6-digit pin code.");
            else setSuccess("#txtPincode", "msgAddPinCodeValidation");
        });

        $("#ddlStateId").on("change", function () {
            if (!$(this).val()) setError("#ddlStateId", "msgAddStateValidation", "Please select a state.");
            else setSuccess("#ddlStateId", "msgAddStateValidation");
        });

        $("#ddlCountryId").on("change", function () {
            if (!$(this).val()) setError("#ddlCountryId", "msgAddCountryValidation", "Please select a country.");
            else setSuccess("#ddlCountryId", "msgAddCountryValidation");
        });

        $("#ddlCompanyId").on("change", function () {
            if (!$(this).val()) setError("#ddlCompanyId", "msgAddCompanyValidation", "Please select a company.");
            else setSuccess("#ddlCompanyId", "msgAddCompanyValidation");
        });

        $("#txtVAT").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtVAT", "msgAddVatValidation", "VAT number is required.");
            else if (!isValidVAT(val)) setError("#txtVAT", "msgAddVatValidation", "Enter a valid VAT number (min 3 chars).");
            else setSuccess("#txtVAT", "msgAddVatValidation");
        });

        $("#txtContactNo").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtContactNo", "msgAddContactNoValidation", "Contact number is required.");
            else if (!isValidPhone(val)) setError("#txtContactNo", "msgAddContactNoValidation", "Enter a valid 10-digit mobile number (starts with 6-9).");
            else setSuccess("#txtContactNo", "msgAddContactNoValidation");
        });

        $("#txtEmail").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEmail", "msgAddEmailValidation", "Email is required.");
            else if (!isValidEmail(val)) setError("#txtEmail", "msgAddEmailValidation", "Enter a valid email address.");
            else setSuccess("#txtEmail", "msgAddEmailValidation");
        });

        $("#txtPAN").on("blur input", function () {
            var val = $(this).val().trim().toUpperCase();
            $(this).val(val);
            if (val === "") setError("#txtPAN", "msgAddPanValidation", "PAN is required.");
            else if (!isValidPAN(val)) setError("#txtPAN", "msgAddPanValidation", "Invalid PAN. Format: ABCDE1234F");
            else setSuccess("#txtPAN", "msgAddPanValidation");
        });

        $("#txtTAN").on("blur input", function () {
            var val = $(this).val().trim().toUpperCase();
            $(this).val(val);
            if (val === "") setError("#txtTAN", "msgAddTanValidation", "TAN is required.");
            else if (!isValidTAN(val)) setError("#txtTAN", "msgAddTanValidation", "Invalid TAN. Format: ABCD12345E");
            else setSuccess("#txtTAN", "msgAddTanValidation");
        });

        $("#txtGST").on("blur input", function () {
            var val = $(this).val().trim().toUpperCase();
            $(this).val(val);
            if (val === "") setError("#txtGST", "msgAddGstValidation", "GST number is required.");
            else if (!isValidGST(val)) setError("#txtGST", "msgAddGstValidation", "Invalid GST. Format: 22AAAAA0000A1Z5");
            else setSuccess("#txtGST", "msgAddGstValidation");
        });

        $("#txtPT").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtPT", "msgAddPtValidation", "PT number is required.");
            else if (!isValidPT(val)) setError("#txtPT", "msgAddPtValidation", "Enter a valid PT number (min 3 chars).");
            else setSuccess("#txtPT", "msgAddPtValidation");
        });

        // =============================================
        // EDIT FORM - LIVE VALIDATION
        // =============================================
        $("#txtEditBranchName").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEditBranchName", "msgEditBranchNameValidation", "Branch name is required.");
            else if (val.length < 2) setError("#txtEditBranchName", "msgEditBranchNameValidation", "Minimum 2 characters required.");
            else setSuccess("#txtEditBranchName", "msgEditBranchNameValidation");
        });

        $("#txtEditBranchAddress1").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEditBranchAddress1", "msgEditAddress1Validation", "Address is required.");
            else if (val.length < 5) setError("#txtEditBranchAddress1", "msgEditAddress1Validation", "Enter a valid address (min 5 chars).");
            else setSuccess("#txtEditBranchAddress1", "msgEditAddress1Validation");
        });

        $("#txtEditCity").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEditCity", "msgEditCityValidation", "City is required.");
            else if (!/^[a-zA-Z\s]+$/.test(val)) setError("#txtEditCity", "msgEditCityValidation", "City must contain letters only.");
            else setSuccess("#txtEditCity", "msgEditCityValidation");
        });

        $("#txtEditPincode").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEditPincode", "msgEditPinCodeValidation", "Pin code is required.");
            else if (!isValidPincode(val)) setError("#txtEditPincode", "msgEditPinCodeValidation", "Enter a valid 6-digit pin code.");
            else setSuccess("#txtEditPincode", "msgEditPinCodeValidation");
        });

        $("#ddlEditStateId").on("change", function () {
            if (!$(this).val()) setError("#ddlEditStateId", "msgEditStateValidation", "Please select a state.");
            else setSuccess("#ddlEditStateId", "msgEditStateValidation");
        });

        $("#ddlEditCountryId").on("change", function () {
            if (!$(this).val()) setError("#ddlEditCountryId", "msgEditCountryValidation", "Please select a country.");
            else setSuccess("#ddlEditCountryId", "msgEditCountryValidation");
        });

        $("#ddlEditCompanyId").on("change", function () {
            if (!$(this).val()) setError("#ddlEditCompanyId", "msgEditCompanyValidation", "Please select a company.");
            else setSuccess("#ddlEditCompanyId", "msgEditCompanyValidation");
        });

        $("#txtEditVAT").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEditVAT", "msgEditVatValidation", "VAT number is required.");
            else if (!isValidVAT(val)) setError("#txtEditVAT", "msgEditVatValidation", "Enter a valid VAT number (min 3 chars).");
            else setSuccess("#txtEditVAT", "msgEditVatValidation");
        });

        $("#txtEditContactNo").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEditContactNo", "msgEditContactNoValidation", "Contact number is required.");
            else if (!isValidPhone(val)) setError("#txtEditContactNo", "msgEditContactNoValidation", "Enter a valid 10-digit mobile number (starts with 6-9).");
            else setSuccess("#txtEditContactNo", "msgEditContactNoValidation");
        });

        $("#txtEditEmail").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEditEmail", "msgEditEmailValidation", "Email is required.");
            else if (!isValidEmail(val)) setError("#txtEditEmail", "msgEditEmailValidation", "Enter a valid email address.");
            else setSuccess("#txtEditEmail", "msgEditEmailValidation");
        });

        $("#txtEditPAN").on("blur input", function () {
            var val = $(this).val().trim().toUpperCase();
            $(this).val(val);
            if (val === "") setError("#txtEditPAN", "msgEditPanValidation", "PAN is required.");
            else if (!isValidPAN(val)) setError("#txtEditPAN", "msgEditPanValidation", "Invalid PAN. Format: ABCDE1234F");
            else setSuccess("#txtEditPAN", "msgEditPanValidation");
        });

        $("#txtEditTAN").on("blur input", function () {
            var val = $(this).val().trim().toUpperCase();
            $(this).val(val);
            if (val === "") setError("#txtEditTAN", "msgEditTanValidation", "TAN is required.");
            else if (!isValidTAN(val)) setError("#txtEditTAN", "msgEditTanValidation", "Invalid TAN. Format: ABCD12345E");
            else setSuccess("#txtEditTAN", "msgEditTanValidation");
        });

        $("#txtEditGST").on("blur input", function () {
            var val = $(this).val().trim().toUpperCase();
            $(this).val(val);
            if (val === "") setError("#txtEditGST", "msgEditGstValidation", "GST number is required.");
            else if (!isValidGST(val)) setError("#txtEditGST", "msgEditGstValidation", "Invalid GST. Format: 22AAAAA0000A1Z5");
            else setSuccess("#txtEditGST", "msgEditGstValidation");
        });

        $("#txtEditPT").on("blur input", function () {
            var val = $(this).val().trim();
            if (val === "") setError("#txtEditPT", "msgEditPtValidation", "PT number is required.");
            else if (!isValidPT(val)) setError("#txtEditPT", "msgEditPtValidation", "Enter a valid PT number (min 3 chars).");
            else setSuccess("#txtEditPT", "msgEditPtValidation");
        });

        // =============================================
        // FULL ADD FORM VALIDATION (on Submit)
        // =============================================
        function validateAddForm() {
            var isValid = true;

            var name = $("#txtBranchName").val().trim();
            if (name === "") { setError("#txtBranchName", "msgAddBranchNameValidation", "Branch name is required."); isValid = false; }
            else if (name.length < 2) { setError("#txtBranchName", "msgAddBranchNameValidation", "Minimum 2 characters required."); isValid = false; }
            else setSuccess("#txtBranchName", "msgAddBranchNameValidation");

            var address = $("#txtBranchAddress1").val().trim();
            if (address === "") { setError("#txtBranchAddress1", "msgAddress1Validation", "Address is required."); isValid = false; }
            else if (address.length < 5) { setError("#txtBranchAddress1", "msgAddress1Validation", "Enter a valid address (min 5 chars)."); isValid = false; }
            else setSuccess("#txtBranchAddress1", "msgAddress1Validation");

            var city = $("#txtCity").val().trim();
            if (city === "") { setError("#txtCity", "msgAddCityValidation", "City is required."); isValid = false; }
            else if (!/^[a-zA-Z\s]+$/.test(city)) { setError("#txtCity", "msgAddCityValidation", "City must contain letters only."); isValid = false; }
            else setSuccess("#txtCity", "msgAddCityValidation");

            var pincode = $("#txtPincode").val().trim();
            if (pincode === "") { setError("#txtPincode", "msgAddPinCodeValidation", "Pin code is required."); isValid = false; }
            else if (!isValidPincode(pincode)) { setError("#txtPincode", "msgAddPinCodeValidation", "Enter a valid 6-digit pin code."); isValid = false; }
            else setSuccess("#txtPincode", "msgAddPinCodeValidation");

            if (!$("#ddlStateId").val()) { setError("#ddlStateId", "msgAddStateValidation", "Please select a state."); isValid = false; }
            else setSuccess("#ddlStateId", "msgAddStateValidation");

            if (!$("#ddlCountryId").val()) { setError("#ddlCountryId", "msgAddCountryValidation", "Please select a country."); isValid = false; }
            else setSuccess("#ddlCountryId", "msgAddCountryValidation");

            if (!$("#ddlCompanyId").val()) { setError("#ddlCompanyId", "msgAddCompanyValidation", "Please select a company."); isValid = false; }
            else setSuccess("#ddlCompanyId", "msgAddCompanyValidation");

            var vat = $("#txtVAT").val().trim();
            if (vat === "") { setError("#txtVAT", "msgAddVatValidation", "VAT number is required."); isValid = false; }
            else if (!isValidVAT(vat)) { setError("#txtVAT", "msgAddVatValidation", "Enter a valid VAT number (min 3 chars)."); isValid = false; }
            else setSuccess("#txtVAT", "msgAddVatValidation");

            var phone = $("#txtContactNo").val().trim();
            if (phone === "") { setError("#txtContactNo", "msgAddContactNoValidation", "Contact number is required."); isValid = false; }
            else if (!isValidPhone(phone)) { setError("#txtContactNo", "msgAddContactNoValidation", "Enter a valid 10-digit mobile number (starts with 6-9)."); isValid = false; }
            else setSuccess("#txtContactNo", "msgAddContactNoValidation");

            var email = $("#txtEmail").val().trim();
            if (email === "") { setError("#txtEmail", "msgAddEmailValidation", "Email is required."); isValid = false; }
