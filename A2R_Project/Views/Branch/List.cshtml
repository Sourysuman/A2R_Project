<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Branch List</strong>
                <button type="button" class="btn btn-gradient-primary btn-rounded btn-fw" data-toggle="modal" data-target="#addBranch">
                    <i class="fa fa-plus"></i> Add
                </button>
            </div>
            <table class="table table-bordered" id="branchTable">
                <thead>
                    <tr>
                        <th>Branch Name</th>
                        <th>Company Name</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Country</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.branches != null && Model.branches.Count() > 0)
                    {
                        foreach (var branch in Model.branches)
                        {
                            <tr class="table-info">
                                <td class="table-primary">@branch.BranchName</td>
                                <td class="table-primary">@branch.CompanyName</td>
                                <td class="table-warning">@branch.Address1</td>
                                <td class="table-primary">@branch.City</td>
                                <td class="table-warning">@branch.StateName</td>
                                <td class="table-primary">@branch.CountryName</td>
                                <td class="table-warning">
                                    @if (branch.IsActive == 1)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <!-- Edit button -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-primary btn-rounded btn-course-list editByBranchId"
                                            data-edbranchId='@branch.BranchId' title="Edit" data-toggle="modal" data-target="#editBranch">
                                        <i class="mdi mdi-pencil"></i>
                                    </button>

                                    <!-- View button -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-dark btn-rounded btn-course-list viewByBranchId"
                                            data-vwBranchId='@branch.BranchId' title="View" data-toggle="modal" data-target="#viewBranch">
                                        <i class="mdi mdi-eye"></i>
                                    </button>

                                    <!-- Delete button -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-warning btn-rounded btn-course-list deleteBranches"
                                            data-dlbranchId='@branch.BranchId' title="Delete" data-toggle="modal" data-target="#deleteBranch">
                                        <i class="mdi mdi-delete"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center">No branches found</td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- STATIC PAGINATION CONTROLS -->
            <div class="static-pagination-wrapper">

                <div class="d-flex justify-content-between align-items-center mt-3">

                    <!-- SHOW ALL -->
                    <button class="btn-showall-modern" id="btnShowAll">
                        <i class="mdi mdi-view-grid"></i> Show All
                    </button>

                    <!-- PAGINATION -->
                    <ul class="pagination modern-pagination mb-0" id="pagination"></ul>

                </div>
            </div>

           
        </div>
    </div>
</div>

<!-- Add Branch Modal -->
<div class="modal fade" id="addBranch" tabindex="-1" role="dialog" aria-labelledby="addBranchModalLabel" aria-hidden="true">
