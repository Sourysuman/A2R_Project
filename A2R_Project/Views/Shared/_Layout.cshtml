       <script>
    $(document).ready(function() {
        console.log('🔥 DROPDOWN FIX LOADED');

        // 1. SIDEBAR COLLAPSE
        $('#sidebarCollapse').off('click').on('click', function() {
            $('#sidebar').toggleClass('active');
        });

        // 2. USER PROFILE DROPDOWN (TOPBAR)
        $('.user_profile_dd > li > a.dropdown-toggle').off('click').on('click', function(e) {
            e.preventDefault();
            $(this).next('.dropdown-menu').toggleClass('show');
            $(this).toggleClass('show');
        });

        // 3. SIDEBAR DROPDOWNS (Organization, Account, etc.)
        $('.components .dropdown-toggle').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            $(this).next('.collapse').collapse('toggle');
        });

        // 4. CLOSE ALL DROPDOWNS ON OUTSIDE CLICK
        $(document).off('click.dropdown').on('click.dropdown', function(e) {
            if (!$(e.target).closest('.dropdown, .user_profile_dd, #sidebar').length) {
                $('.dropdown-menu, .collapse').removeClass('show');
                $('.dropdown-toggle').removeClass('show');
            }
        });

        // 5. PERFECT SCROLLBAR
        new PerfectScrollbar('#sidebar');

        // 6. YEAR
        $('#year').text(new Date().getFullYear());

        console.log('✅ ALL DROPDOWNS FIXED!');
    });
                $('.components .dropdown-toggle').off('click').on('click', function(e) {
                e.preventDefault();

                let sidebar = $('#sidebar');
                let submenu = $(this).next('.collapse');

                // 👉 If sidebar is collapsed → expand it first
                if (sidebar.hasClass('active')) {
                    sidebar.removeClass('active');

                    // Small delay so animation completes
                    setTimeout(() => {
                        submenu.collapse('show');
                    }, 200);

                } else {
                    // 👉 Normal behavior
                    submenu.collapse('toggle');
                }
            });
</script>

