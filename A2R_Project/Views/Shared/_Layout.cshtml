    <style>
        .logo_section img.logo_icon {
            margin: 0;
            text-align: center;
            padding: 2px 2px;
            height: 80px;
            width: 80px;
        }
        /* ================= ADMIN FOOTER CLEAN ================= */
        .admin-footer {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            color: #f1f5f9;
            text-align: center;
            padding: 14px 10px;
            font-size: 16px; /* 🔥 slightly bigger */
            font-weight: 600;
            letter-spacing: 0.6px;
            border-top: 2px solid #6366f1;
            box-shadow: 0 -3px 10px rgba(0,0,0,0.15);
        }

            /* highlight institute name */
            .admin-footer .brand {
                color: #38bdf8;
                font-weight: 700;
            }

            /* smooth hover */
            .admin-footer:hover {
                background: linear-gradient(135deg, #334155, #1e293b);
                transition: 0.3s ease;
            }
        /* ================= SIDEBAR COLLAPSE FIX ================= */

        /* Default sidebar width */
        #sidebar {
            width: 250px;
            transition: all 0.3s ease;
        }

            /* Collapsed sidebar */
            #sidebar.active {
                width: 80px;
            }

                /* Hide text when collapsed */
                #sidebar.active .components li a span {
                    display: none;
                }

                /* Center icons when collapsed */
                #sidebar.active .components li a {
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    padding: 15px 0;
                }

            /* Icon size improve */
            #sidebar .components li a i {
                font-size: 18px;
                min-width: 25px;
                text-align: center;
            }

            /* Fix submenu hiding in collapsed mode */
            #sidebar.active .collapse {
                display: none !important;
            }

            /* Optional: hover show submenu (advanced UX) */
            #sidebar.active .components li:hover .collapse {
                display: block !important;
                position: absolute;
                left: 80px;
                background: #1e293b;
                min-width: 180px;
                z-index: 999;
            }

            /* Fix dashboard icon alignment */
            #sidebar .components li a {
                display: flex;
                align-items: center;
                gap: 12px;
            }

                /* Active menu highlight */
                #sidebar .components li a:hover {
                    background: rgba(255,255,255,0.1);
                    border-radius: 8px;
                }
                /* Prevent menu text from breaking into 2 lines */
                #sidebar .components li a span {
                    white-space: nowrap; /* 🔥 key fix */
                    overflow: hidden;
                    text-overflow: ellipsis; /* optional: adds ... if too long */
                }

            /* Ensure proper alignment */
            #sidebar .components li a {
                display: flex;
                align-items: center;
                gap: 12px;
            }

        /* Optional: slightly increase sidebar width for better fit */
        #sidebar {
            width: 260px; /* was 250px */
        }

        .admin-footer {
            background: #ffffff; /* white bg */
            color: #111827; /* strong black text */
            text-align: center;
            padding: 14px 10px;
            font-size: 16px;
            font-weight: 700; /* bold */
            letter-spacing: 0.5px;
            border-top: 2px solid #e5e7eb;
            box-shadow: 0 -2px 8px rgba(0,0,0,0.08);
        }

            /* brand highlight */
            .admin-footer .brand {
                color: #000000;
                font-weight: 800;
            }

            /* hover (clean subtle) */
            .admin-footer:hover {
                background: #f9fafb;
                transition: 0.3s ease;
            }

    </style>



</head>
