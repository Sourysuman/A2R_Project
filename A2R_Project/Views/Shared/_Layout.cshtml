    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">

    <style>
        /* ================= LAYOUT ================= */
        html, body {
            height: 100%;
        }

        .full_container {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        #content {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ================= MAIN CONTENT ================= */
        .main-content {
            flex: 1;
            padding: 3px;
            margin-top: 3px;
        }

        /* ================= FOOTER ================= */
        .footer-wrapper {
            margin-top: auto;
        }

        .admin-footer {
            background: #ffffff;
            color: #111827;
            text-align: center;
            padding: 14px 10px;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 0.5px;
            border-top: 2px solid #e5e7eb;
            box-shadow: 0 -2px 8px rgba(0,0,0,0.08);
        }

            .admin-footer .brand {
                color: #000000;
                font-weight: 800;
            }

            .admin-footer:hover {
                background: #f9fafb;
                transition: 0.3s ease;
            }

        /* ================= LOGO ================= */
        .logo_section img.logo_icon {
            margin: 0;
            text-align: center;
            padding: 2px;
            height: 80px;
            width: 80px;
        }

        /* ================= SIDEBAR ================= */
        #sidebar {
            width: 260px;
            transition: width 0.3s ease;
        }

            #sidebar.active {
                width: 80px;
            }

                #sidebar.active .components li a span {
                    display: none;
                }

                #sidebar.active .components li a {
                    display: flex;
                    justify-content: center;
                    align-items: center;
                    padding: 15px 0;
                }

                #sidebar.active .collapse {
                    display: none !important;
                }

                #sidebar.active .components li:hover .collapse {
                    display: block !important;
                    position: absolute;
                    left: 80px;
                    background: #1e293b;
                    min-width: 180px;
                    z-index: 999;
                }

            #sidebar .components li a {
                display: flex;
                align-items: center;
                gap: 12px;
            }

                #sidebar .components li a span {
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                    font-size: 15px;
                    font-weight: 600;
                    letter-spacing: 0.3px;
                }

                #sidebar .components li a:hover {
                    background: rgba(255,255,255,0.1);
                    border-radius: 8px;
                }

                #sidebar .components li a i {
                    font-size: 18px;
                    min-width: 30px;
                    text-align: center;
                    border-radius: 8px;
                    padding: 8px;
                    transition: all 0.3s ease;
                }

                #sidebar .components li a:hover i {
                    transform: scale(1.1);
                }

        #dynamic-sidebar ul li {
            margin-bottom: 8px;
            animation: slideIn 0.2s ease forwards;
            opacity: 0;
            transform: translateY(-10px);
        }

            #dynamic-sidebar ul li:nth-child(1) {
                animation-delay: 0ms;
            }

            #dynamic-sidebar ul li:nth-child(2) {
                animation-delay: 30ms;
            }

            #dynamic-sidebar ul li:nth-child(3) {
                animation-delay: 60ms;
            }

            #dynamic-sidebar ul li:nth-child(4) {
                animation-delay: 90ms;
            }

            #dynamic-sidebar ul li:nth-child(5) {
                animation-delay: 120ms;
            }

        @@keyframes slideIn {
            to

        {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* ================= SPINNER ================= */
        #loading-section {
            display: block !important;
            min-height: 100px;
        }

        .spinner-wrapper {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            gap: 12px !important;
        }

        .colorful-spinner {
            width: 48px !important;
            height: 48px !important;
            border: 4px solid #f8f9fa !important;
            border-top: 4px solid #667eea !important;
            border-radius: 50% !important;
            animation: spin 0.8s linear infinite, colorShift 1.5s ease-in-out infinite !important;
            box-shadow: 0 4px 20px rgba(102,126,234,0.4) !important;
        }

        .spinner-text {
            color: #6c757d !important;
            font-weight: 500 !important;
            font-size: 12px !important;
        }

        @@keyframes spin {
            0%

        {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }

        }

        @@keyframes colorShift {
            0%, 100%

        {
            border-top-color: #667eea;
        }

        20% {
            border-top-color: #764ba2;
        }

        40% {
            border-top-color: #f093fb;
        }

        60% {
            border-top-color: #f5576c;
        }

        80% {
            border-top-color: #4facfe;
        }

        }

        /* ================= MEDIA ================= */
        @@media (min-width: 1200px) {
            #sidebar.active .logo_section

        {
            padding: 0;
            margin-bottom: 10px;
            background-color: black !important;
            width: 100%;
        }

        }

        #logoutForm button.dropdown-item,
        #logoutForm button.dropdown-item span,
        #logoutForm button.dropdown-item i {
            color: #000000 !important;
            background: none !important;
        }

            #logoutForm button.dropdown-item:hover,
            #logoutForm button.dropdown-item:hover span,
            #logoutForm button.dropdown-item:hover i {
                color: #000000 !important;
                background: #f8f9fa !important;
            }

            #logoutForm button.dropdown-item,
            #logoutForm button.dropdown-item span,
            #logoutForm button.dropdown-item i {
                color: #000000 !important;
                background: #ffffff !important;
                font-size: 15px !important;
                font-weight: 600 !important;
            }

                #logoutForm button.dropdown-item:hover,
                #logoutForm button.dropdown-item:hover span,
                #logoutForm button.dropdown-item:hover i {
                    color: #ffffff !important;
                    background: #000000 !important;
                }
        
            </style>
</head>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert"
         style="position:fixed;top:70px;right:20px;z-index:9999;max-width:400px;">
        @TempData["Error"]
        <button type="button" class="close" data-dismiss="alert">×</button>
    </div>
}

<body class="dashboard dashboard_1">
    <div class="full_container">
        <div class="inner_container">

            <!-- Sidebar -->
