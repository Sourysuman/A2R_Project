    <!-- jQuery -->
    <script src="~/cotains/pluto-1.0.0/js/jquery.min.js"></script>
    <script src="~/cotains/pluto-1.0.0/js/popper.min.js"></script>
    <script src="~/cotains/pluto-1.0.0/js/bootstrap.min.js"></script>
    <!-- wow animation -->
    <script src="~/cotains/pluto-1.0.0/js/animate.js"></script>
    <!-- select country -->
    <script src="~/cotains/pluto-1.0.0/js/bootstrap-select.js"></script>
    <!-- owl carousel -->
    <script src="~/cotains/pluto-1.0.0/js/owl.carousel.js"></script>
    <!-- chart js -->
    <script src="~/cotains/pluto-1.0.0/js/Chart.min.js"></script>
    <script src="~/cotains/pluto-1.0.0/js/Chart.bundle.min.js"></script>
    <script src="~/cotains/pluto-1.0.0/js/utils.js"></script>
    <script src="~/cotains/pluto-1.0.0/js/analyser.js"></script>
    <!-- nice scrollbar -->
    <script src="~/cotains/pluto-1.0.0/js/perfect-scrollbar.min.js"></script>
    <script>
        var ps = new PerfectScrollbar('#sidebar');
    </script>
    <!-- custom js -->
    <script src="~/cotains/pluto-1.0.0/js/custom.js"></script>
    <script src="~/cotains/pluto-1.0.0/js/chart_custom_style1.js"></script>
  
   
    <script>
        $(document).ready(function () {

            // 1. SIDEBAR COLLAPSE
            $('#sidebarCollapse').off('click').on('click', function () {
                $('#sidebar').toggleClass('active');
            });

            // 2. USER PROFILE DROPDOWN
            $('.user_profile_dd > li > a.dropdown-toggle').off('click').on('click', function (e) {
                e.preventDefault();
                $(this).next('.dropdown-menu').toggleClass('show');
                $(this).toggleClass('show');
            });

            // 3. SIDEBAR DROPDOWNS
            $('.components .dropdown-toggle').off('click').on('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                let sidebar = $('#sidebar');
                let submenu = $(this).next('.collapse');

                if (sidebar.hasClass('active')) {
                    sidebar.removeClass('active');
                    setTimeout(() => { submenu.collapse('show'); }, 200);
                } else {
                    submenu.collapse('toggle');
                }
            });

            // 4. CLOSE ON OUTSIDE CLICK
            $(document).off('click.dropdown').on('click.dropdown', function (e) {
                if (!$(e.target).closest('.dropdown, .user_profile_dd, #sidebar').length) {
                    $('.dropdown-menu, .collapse').removeClass('show');
                    $('.dropdown-toggle').removeClass('show');
                }
            });

            // 5. PERFECT SCROLLBAR
            new PerfectScrollbar('#sidebar');

            // 6. YEAR
            $('#year').text(new Date().getFullYear());

            // 7. LOAD DYNAMIC SIDEBAR
            const username = '@ViewBag.Username';
            if (username && username !== 'Guest') {
                loadDynamicSidebar(username);
            }
        });

        async function loadDynamicSidebar(username) {
            try {
                const response = await fetch(`/AccessControl/GetDynamicSidebar?username=${encodeURIComponent(username)}`);
                const data = await response.json();
                const menus = data.menus || [];

                let html = `
                    <li style="margin-bottom:8px;">
                        <a href="@Url.Action("Index", "Dashboard")">
                            <i class="fas fa-tachometer-alt fa-fw" style="color:${getMenuColor('Dashboard')}"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>`;

                menus.forEach((menu, index) => {
                    const menuId = `menu_${index}_${menu.menuName.replace(/[^a-zA-Z0-9]/g, '')}`;
                    html += `
                        <li style="margin-bottom:8px;">
                            <a href="#${menuId}" data-toggle="collapse" aria-expanded="false" class="dropdown-toggle">
                                <i class="fas fa-${menu.icon} fa-fw" style="color:${getMenuColor(menu.menuName)}"></i>
                                <span>${menu.menuName}</span>
                            </a>
                            <ul class="collapse list-unstyled" id="${menuId}">`;

                    menu.subMenus.forEach((sub, subIndex) => {
                        const subColors = ['text-success', 'text-warning', 'text-secondary', 'text-danger', 'text-info'];

                        let finalController = sub.controller;
                        let finalAction = sub.action;
                        let finalName = sub.name;
                        let finalIcon = getSubmenuIcon(sub.name);

                        if (sub.controller === 'AdminLogin' && sub.action === 'List') {
                            finalController = 'UserManagement';
                            finalAction = 'List';
                            finalName = 'User Management List';
                            finalIcon = 'users-cog';
                        }

                        const url = `/${finalController}/${finalAction}`;
                        html += `
                            <li>
                                <a href="${url}">
                                    <i class="fas fa-${finalIcon} fa-fw ${subColors[subIndex % subColors.length]}"></i>
                                    <span>${finalName}</span>
                                </a>
                            </li>`;
                    });

                    html += `</ul></li>`;
                });

                $('#dynamic-sidebar ul').html(html);

            } catch (error) {
                $('#dynamic-sidebar ul').html(`
                    <li class="text-center py-4 text-muted">
                        <i class="fas fa-exclamation-triangle fa-lg mb-2"></i>
                        Menu load failed
                    </li>`);
            }
        }

        function getMenuColor(name) {
            const colors = {
                'Dashboard':          '#2563eb',
                'Organization':       '#7c3aed',
                'Account Management': '#16a34a',
                'Student Management': '#ea580c',
                'Fees Collection':    '#eab308',
                'Users':              '#dc2626',
                'Roles':              '#0d9488'
            };
            return colors[name] || '#6366f1';
        }

        function getSubmenuIcon(name) {
            const icons = {
                'Country':          'globe',
                'State':            'map-marker-alt',
                'Company':          'industry',
                'Branch':           'code-branch',
                'Courses':          'graduation-cap',
                'Course':           'graduation-cap',
                'Expense Category': 'tags',
                'Expense':          'receipt',
                'Expense Reports':  'chart-line',
                'Inquiry Form':     'question-circle',
                'Inquiry List':     'list-alt',
                'Admission List':   'clipboard-check',
                'Fees Collection':  'money-bill-wave',
                'User List':        'users',
                'UserManagement':   'users-cog',
                'Access List':      'lock-open',
                'Role Type':        'user-tag'
            };
            return icons[name] || 'arrow-right';
        }
                 // ✅ SIDEBAR DROPDOWN + EXPAND LOGIC
        $(document).on('click', '.components .dropdown-toggle', function (e) {
            e.preventDefault();
            e.stopPropagation();

            let sidebar = $('#sidebar');
            let submenu = $(this).next('.collapse');

            if (sidebar.hasClass('active')) {
                // Sidebar is collapsed → expand it first
                sidebar.removeClass('active');
                // Wait for CSS transition to finish then show submenu
                setTimeout(function () {
                    submenu.addClass('show');
                }, 300);
            } else {
                // Sidebar already expanded → just toggle submenu
                if (submenu.hasClass('show')) {
                    submenu.removeClass('show');
                } else {
                    // Close all other open submenus first
                    $('.components .collapse.show').removeClass('show');
                    submenu.addClass('show');
                }
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

