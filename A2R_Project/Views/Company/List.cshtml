@model A2R_Project.Models.CompanyViewModel

@{
    ViewBag.Title = "List";
}
<style>
    /* ================= GLOBAL ================= */
    body {
        background: #f4f7fb;
        font-family: 'Segoe UI', sans-serif;
        color: #000;
    }

    /* ================= CARD ================= */
    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        background: #ffffff;
    }

    .card-title {
        font-size: 22px;
        font-weight: 700;
        color: #000;
    }

    /* ================= TABLE ================= */
    #companyTable {
        border-radius: 12px;
        overflow: hidden;
        width: 100%;
        border-collapse: collapse;
    }

        /* HEADER (FIELD NAME COLOR CHANGE) */
        #companyTable thead {
            background: linear-gradient(45deg, #1e3c72, #2a5298);
            color: #fff;
            text-align: center;
        }

            #companyTable thead th {
                padding: 14px;
                font-size: 15px;
                font-weight: 700;
                border: none;
                letter-spacing: 0.5px;
            }

        /* TABLE TEXT STRONG BLACK */
        #companyTable td {
            font-size: 15px;
            font-weight: 600;
            color: #000;
            vertical-align: middle;
            border: 1px solid #eee;
            text-align: center;
        }

        /* ROW DESIGN */
        #companyTable tbody tr {
            transition: all 0.3s ease;
        }

            #companyTable tbody tr:nth-child(even) {
                background: #f8fbff;
            }

            #companyTable tbody tr:nth-child(odd) {
                background: #ffffff;
            }

            /* HOVER EFFECT */
            #companyTable tbody tr:hover {
                background: #dbeafe !important;
                transform: scale(1.01);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

    /* ================= BADGES ================= */
    .badge-success {
        background: #22c55e;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-danger {
        background: #ef4444;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    /* ================= BUTTONS ================= */
    .btn {
        border-radius: 30px;
        font-size: 14px;
        font-weight: 600;
        padding: 6px 14px;
        transition: all 0.3s ease;
    }

    /* ADD BUTTON */
    .btn-gradient-primary {
        background: linear-gradient(45deg, #4facfe, #00f2fe);
        color: #fff;
        border: none;
    }

    /* VIEW BUTTON */
    .btn-gradient-dark {
        background: linear-gradient(45deg, #434343, #000000);
        color: #fff;
        border: none;
    }

    /* DELETE BUTTON */
    .btn-gradient-warning {
        background: linear-gradient(45deg, #ff416c, #ff4b2b);
        color: #fff;
        border: none;
    }

    /* HOVER BUTTON */
    .btn:hover {
        transform: translateY(-3px) scale(1.05);
        box-shadow: 0 6px 15px rgba(0,0,0,0.2);
    }

    /* BUTTON SPACING */
    td .btn {
        margin: 3px;
    }

    /* ================= FORM ELEMENTS ================= */
    .form-control {
        border-radius: 10px;
        border: 1px solid #ddd;
        padding: 10px;
        font-size: 14px;
        font-weight: 600;
        color: #000;
    }

        .form-control:focus {
            border-color: #4facfe;
            box-shadow: 0 0 8px rgba(79,172,254,0.5);
        }

    label {
        font-weight: 700;
        font-size: 13px;
        color: #000;
    }

    .mandatoryfield {
        color: red;
    }

    /* ================= IMAGE STYLING ================= */
    #logoPreview,
    #editLogoPreview,
    #image_upload_previewEmployeeView,
    #image_upload_previewCompanyDel {
        width: 100%;
        height: 140px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px solid #ddd;
        background: #fff;
        transition: 0.3s;
    }

        #logoPreview:hover,
        #editLogoPreview:hover {
            border-color: #4facfe;
            transform: scale(1.05);
        }

    /* ================= CHECKBOX ================= */
    .rounded-checkbox {
        transform: scale(1.2);
        margin-right: 5px;
    }

    /* ================= PAGINATION ================= */
    .pagination .page-item .page-link {
        border-radius: 50px;
        margin: 3px;
        color: #1e3c72;
        font-weight: 600;
    }

    .pagination .page-item.active .page-link {
        background: #1e3c72;
        border-color: #1e3c72;
        color: #fff;
    }

    /* ================= SHOW ALL BUTTON ================= */
    #showAllButton {
        background: linear-gradient(45deg, #00c6ff, #0072ff);
        border: none;
        color: white;
        border-radius: 25px;
        padding: 8px 20px;
        font-weight: 600;
    }

        #showAllButton:hover {
            transform: scale(1.08);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

    /* ================= ADD & EDIT POPUP ONLY ================= */
    #addCompany .modal-content,
    #editCompany .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 25px 70px rgba(0,0,0,0.35);
        overflow: hidden;
        animation: smoothPopup 0.35s ease;
    }

    /* ANIMATION */
    @@keyframes smoothPopup {
        from

    {
        transform: translateY(-30px) scale(0.95);
        opacity: 0;
    }

    to {
        transform: translateY(0) scale(1);
        opacity: 1;
    }

    }

    /* ================= HEADER ================= */
    #addCompany .modal-header {
        background: linear-gradient(45deg, #0072ff, #00c6ff);
        color: #fff;
        border: none;
    }

    #editCompany .modal-header {
        background: linear-gradient(45deg, #00c853, #64dd17);
        color: #fff;
        border: none;
    }

    .modal-title {
        font-weight: 700;
        font-size: 20px;
    }

    /* ================= BODY ================= */
    #addCompany .modal-body,
    #editCompany .modal-body {
        background: #f8fbff;
        padding: 25px;
    }

    /* REMOVE SCROLL COMPLETELY */
    #addCompany .modal-body,
    #editCompany .modal-body {
        max-height: unset !important;
        overflow: visible !important;
    }

    /* ================= FORM GRID CLEAN ================= */
    #addCompany .row,
    #editCompany .row {
        margin-bottom: 8px;
    }

    /* ================= INPUT ================= */
    #addCompany .form-control,
    #editCompany .form-control {
        border-radius: 12px;
        border: 1px solid #ddd;
        font-weight: 600;
        transition: 0.3s;
    }

        /* FOCUS EFFECT */
        #addCompany .form-control:focus,
        #editCompany .form-control:focus {
            border-color: #00c6ff;
            box-shadow: 0 0 10px rgba(0,198,255,0.4);
            transform: scale(1.02);
        }

    /* ================= IMAGE ================= */
    #logoPreview,
    #editLogoPreview {
        width: 100%;
        height: 130px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px dashed #00c6ff;
        padding: 4px;
    }

    /* ================= FOOTER ================= */
    #addCompany .modal-footer,
    #editCompany .modal-footer {
        border-top: none;
        background: #fff;
    }

    /* ================= BUTTONS ================= */
    #addCompany .btn-success {
        background: linear-gradient(45deg, #00c853, #64dd17);
        border: none;
    }

    #editCompany .btn-primary {
        background: linear-gradient(45deg, #0072ff, #00c6ff);
        border: none;
    }

    #addCompany .btn-warning,
    #editCompany .btn-warning {
        background: linear-gradient(45deg, #f7971e, #ffd200);
        border: none;
        color: #000;
    }

    /* HOVER */
    #addCompany .btn:hover,
    #editCompany .btn:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    }

    @@media (min-width: 576px) {
        .modal-dialog

    {
        max-width: 1000px;
        margin: 1.75rem auto;
    }
    }
    /* ================= DROPDOWN MODERN ================= */
    #addCompany select,
    #editCompany select {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background: #fff url("data:image/svg+xml;utf8,<svg fill='%230072ff' height='20' viewBox='0 0 24 24' width='20' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/></svg>") no-repeat right 12px center;
        border-radius: 12px;
        border: 1px solid #ddd;
        padding: 10px 35px 10px 10px;
        font-weight: 600;
        cursor: pointer;
    }

    /* REMOVE BOOTSTRAP EXTRA ICON */
    .input-group-append {
        display: none !important;
    }
    /* ================= DROPDOWN IMPROVED ================= */
    #addCompany select,
    #editCompany select {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background: #fff url("data:image/svg+xml;utf8,<svg fill='%230072ff' height='22' viewBox='0 0 24 24' width='22' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/></svg>") no-repeat right 14px center;
        border-radius: 12px;
        border: 1px solid #ddd;
        /* 🔥 IMPROVEMENTS */
        padding: 12px 40px 12px 12px; /* more space */
        font-size: 15px; /* bigger text */
        font-weight: 600;
        line-height: 1.5;
        height: 45px; /* fixed height */
        cursor: pointer;
    }

        /* HOVER */
        #addCompany select:hover,
        #editCompany select:hover {
            border-color: #00c6ff;
        }

        /* FOCUS */
        #addCompany select:focus,
        #editCompany select:focus {
            border-color: #0072ff;
            box-shadow: 0 0 10px rgba(0,114,255,0.3);
        }
    /* ================= ISACTIVE SWITCH ================= */
    #addCompany .form-check,
    #editCompany .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* HIDE DEFAULT CHECKBOX */
    #addCompany .form-check-input,
    #editCompany .form-check-input {
        appearance: none;
        width: 45px;
        height: 22px;
        background: #ccc;
        border-radius: 50px;
        position: relative;
        cursor: pointer;
        transition: 0.3s;
    }

        /* CIRCLE */
        #addCompany .form-check-input::before,
        #editCompany .form-check-input::before {
            content: "";
            width: 18px;
            height: 18px;
            background: #fff;
            position: absolute;
            top: 2px;
            left: 3px;
            border-radius: 50%;
            transition: 0.3s;
        }

        /* ACTIVE */
        #addCompany .form-check-input:checked,
        #editCompany .form-check-input:checked {
            background: linear-gradient(45deg, #00c853, #64dd17);
        }

            /* MOVE CIRCLE */
            #addCompany .form-check-input:checked::before,
            #editCompany .form-check-input:checked::before {
                transform: translateX(22px);
            }

    /* LABEL */
    #addCompany .form-check-label,
    #editCompany .form-check-label {
        font-weight: 600;
    }
    /* ================= FILE UPLOAD STYLISH ================= */
    #addCompany .form-control-file,
    #editCompany .form-control-file {
        width: 100%;
        padding: 8px;
        border: 2px dashed #00c6ff;
        border-radius: 12px;
        background: #f8fbff;
        cursor: pointer;
        transition: 0.3s;
        font-weight: 600;
    }

        /* HOVER EFFECT */
        #addCompany .form-control-file:hover,
        #editCompany .form-control-file:hover {
            background: #e6f7ff;
            border-color: #0072ff;
            transform: scale(1.02);
        }

    /* FILE BUTTON STYLE */
    #addCompany input[type="file"]::file-selector-button,
    #editCompany input[type="file"]::file-selector-button {
        border: none;
        padding: 8px 15px;
        border-radius: 8px;
        background: linear-gradient(45deg, #0072ff, #00c6ff);
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        margin-right: 10px;
    }

        /* BUTTON HOVER */
        #addCompany input[type="file"]::file-selector-button:hover,
        #editCompany input[type="file"]::file-selector-button:hover {
            background: linear-gradient(45deg, #005bea, #00c6ff);
        }

    .validationMessage {
        color: red;
        font-size: 12px;
        font-weight: 600;
    }
    /* ================= MODERN POPUP BASE ================= */
    #viewCompany .modal-content,
    #deleteCompany .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 25px 70px rgba(0,0,0,0.3);
        overflow: hidden;
        animation: popupSmooth 0.4s ease;
    }

    @@keyframes popupSmooth {
        from

    {
        transform: translateY(-25px) scale(0.95);
        opacity: 0;
    }

    to {
        transform: translateY(0) scale(1);
        opacity: 1;
    }
    }
    /* VIEW → DARK PREMIUM */
    #viewCompany .modal-header {
        background: linear-gradient(45deg, #1f1f1f, #000);
        color: #fff;
    }

    /* DELETE → BLUE (as you asked) */
    #deleteCompany .modal-header {
        background: linear-gradient(45deg, #0072ff, #00c6ff);
        color: #fff;
    }
    /* ================= COMPANY NAME ================= */
    #lblvwCompanyName,
    #lblDelCompanyName {
        font-size: 20px;
        font-weight: 800;
        color: #0072ff;
        letter-spacing: 1px;
        animation: glowText 1.5s ease-in-out infinite alternate;
    }

    @@keyframes glowText {
        from

    {
        text-shadow: 0 0 5px #0072ff;
    }

    to {
        text-shadow: 0 0 15px #00c6ff;
    }
    }
    /* ================= FIELD ROW ================= */
    #viewCompany .form-group,
    #deleteCompany .form-group {
        display: flex;
        align-items: center;
        margin-bottom: 10px;
    }

        /* LABEL */
        #viewCompany .form-group label,
        #deleteCompany .form-group label {
            min-width: 130px;
            font-weight: 600;
            color: #555;
            font-size: 13px;
        }

            /* VALUE */
            #viewCompany .form-group label + label,
            #deleteCompany .form-group label + label {
                font-weight: 700;
                color: #000;
                font-size: 14px;
                word-break: break-word;
            }
    /* ================= LOGO CARD ================= */
    #viewCompany .card,
    #deleteCompany .card {
        border-radius: 18px;
        border: none;
        background: linear-gradient(135deg, #f8fbff, #eef5ff);
        box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        padding: 10px;
        text-align: center;
    }

    /* IMAGE */
    #image_upload_previewEmployeeView,
    #image_upload_previewCompanyDel {
        border-radius: 15px;
        object-fit: cover;
        height: 180px;
        width: 100%;
        border: 2px solid #e0e0e0;
        transition: 0.4s;
    }

        /* HOVER EFFECT */
        #image_upload_previewEmployeeView:hover,
        #image_upload_previewCompanyDel:hover {
            transform: scale(1.05);
            border-color: #00c6ff;
            box-shadow: 0 10px 25px rgba(0,198,255,0.4);
        }
    /* ================= BUTTON ================= */
    #viewCompany .btnClose {
        background: linear-gradient(45deg, #434343, #000);
        color: #fff;
        border: none;
    }

    #deleteCompany .btn-danger {
        background: linear-gradient(45deg, #0072ff, #00c6ff);
        border: none;
    }

    /* HOVER */
    #viewCompany .btn,
    #deleteCompany .btn {
        border-radius: 25px;
        transition: 0.3s;
    }

        #viewCompany .btn:hover,
        #deleteCompany .btn:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }
    /* ================= RESPONSIVE ================= */
    @@media (max-width: 768px) {
        #viewCompany .form-group, #deleteCompany .form-group

    {
        flex-direction: column;
        align-items: flex-start;
    }

    #viewCompany .form-group label,
    #deleteCompany .form-group label {
        min-width: auto;
    }
    }
    /* REMOVE ANY YELLOW BACKGROUND */
    #viewCompany .modal-body {
        background: #ffffff !important;
    }

    /* OPTIONAL NICE COLOR */
    #viewCompany .modal-header {
        background: linear-gradient(45deg, #ffcc00, #ff9900);
        color: #000;
    }
    /* FIELD ROW FIX */
    #viewCompany .form-group,
    #deleteCompany .form-group {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
    }

        /* LABEL */
        #viewCompany .form-group label:first-child,
        #deleteCompany .form-group label:first-child {
            min-width: 150px;
            font-weight: 700;
            color: #333;
        }

        /* VALUE */
        #viewCompany .form-group label:last-child,
        #deleteCompany .form-group label:last-child {
            margin-left: 10px;
            font-weight: 600;
            color: #000;
        }

        /* ADD ":" AUTOMATIC */
        #viewCompany .form-group label:first-child::after,
        #deleteCompany .form-group label:first-child::after {
            content: " :";
            margin-left: 5px;
        }
    /* ================= CLEAN FIELD STYLE ================= */
    .clean-field {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
    }

        /* LABEL */
        .clean-field .label {
            min-width: 160px; /* keeps alignment same */
            font-weight: 700;
            color: #333;
        }

            /* ADD ":" PROPERLY */
            .clean-field .label::after {
                content: " :";
                margin-left: 5px;
            }

        /* VALUE */
        .clean-field .value {
            margin-left: 15px; /* 🔥 GAP AFTER ":" */
            font-weight: 600;
            color: #000;
        }

        /* OPTIONAL HOVER */
        .clean-field:hover .value {
            color: #007bff;
        }
    /* ================= MODAL BOX ================= */
    #viewCompany .modal-content,
    #deleteCompany .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        overflow: hidden;
    }

    /* BODY */
    #viewCompany .modal-body,
    #deleteCompany .modal-body {
        padding: 25px;
        background: #f8fbff;
    }
    /* ================= IMAGE CARD ================= */
    #viewCompany .card,
    #deleteCompany .card {
        border-radius: 18px;
        border: none;
        background: #ffffff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        padding: 10px;
    }

    /* IMAGE FIXED SIZE */
    #image_upload_previewEmployeeView,
    #image_upload_previewCompanyDel {
        width: 100%;
        height: 180px; /* 🔥 fixed height */
        object-fit: cover; /* 🔥 fit image properly */
        border-radius: 12px;
        border: 2px solid #e0e0e0;
        background: #fff;
    }

        /* HOVER EFFECT */
        #image_upload_previewEmployeeView:hover,
        #image_upload_previewCompanyDel:hover {
            transform: scale(1.04);
            transition: 0.3s;
        }
    /* ================= FIELD STYLE ================= */
    .clean-field {
        display: flex;
        align-items: center;
        margin-bottom: 14px;
        padding: 6px 0;
        border-bottom: 1px solid #eaeaea;
    }

        /* LABEL */
        .clean-field .label {
            min-width: 170px;
            font-weight: 700;
            color: #333;
            font-size: 14px;
        }

            /* ":" */
            .clean-field .label::after {
                content: " :";
                margin-left: 5px;
                color: #777;
            }

        /* VALUE BOX */
        .clean-field .value {
            margin-left: 15px;
            padding: 6px 12px;
            background: #ffffff;
            border-radius: 8px;
            border: 1px solid #e0e6f0;
            font-weight: 600;
            color: #000;
            min-width: 140px;
        }

        /* HOVER */
        .clean-field:hover .value {
            background: #e6f0ff;
            transition: 0.3s;
        }
    /* ================= COMPANY NAME ================= */
    #lblvwCompanyName,
    #lblDelCompanyName {
        display: block;
        text-align: center;
        font-size: 26px;
        font-weight: 800;
        color: #0072ff;
        margin-bottom: 15px;
        letter-spacing: 1px;
    }
    /* ================= BUTTONS ================= */
    #viewCompany .btnClose,
    #deleteCompany .btn {
        border-radius: 25px;
        padding: 6px 18px;
        font-weight: 600;
    }

    /* DELETE BUTTON */
    #deleteCompany .btn-danger {
        background: linear-gradient(45deg, #0072ff, #00c6ff);
        border: none;
    }

    /* HOVER */
    #viewCompany .btn:hover,
    #deleteCompany .btn:hover {
        transform: scale(1.05);
        transition: 0.3s;
    }
    /* ================= VIEW TITLE ================= */
    .view-section-title {
        text-align: center;
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        position: relative;
        margin: 10px 0 20px;
        letter-spacing: 0.5px;
    }

        /* LINE LEFT + RIGHT */
        .view-section-title::before,
        .view-section-title::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 30%;
            height: 2px;
            background: linear-gradient(45deg, #facc15, #f59e0b);
        }

        .view-section-title::before {
            left: 0;
        }

        .view-section-title::after {
            right: 0;
        }

    /* SMALL SUBTEXT STYLE */
    .view-subtitle {
        text-align: center;
        font-size: 13px;
        color: #64748b;
        margin-top: -10px;
        margin-bottom: 15px;
    }
</style>
<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Company List</strong>
                <button type="button" class="btn btn-gradient-primary btn-rounded btn-fw" data-toggle="modal" data-target="#addCompany">
                    <i class="fa fa-plus"></i> Add
                </button>
            </div>
            <table class="table table-bordered" id="companyTable">
                <thead>
                    <tr>
                        <th>Company Name</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Country</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.companies.Count() > 0)
                    {
                        foreach (var company in Model.companies)
                        {
                            <tr class="table-info">
                                <td class="table-primary">@company.CompanyName</td>
                                <td class="table-warning">@company.Address1</td>
                                <td class="table-primary">@company.City</td>
                                <td class="table-warning">@company.StateName</td>
                                <td class="table-primary">@company.CountryName</td>
                                <td class="table-warning">
                                    @if (company.IsActive == 1)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>
                                <td>
