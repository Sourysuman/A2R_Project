    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const table = document.getElementById("companyTable");
            if (!table) return;

            const rows = table.querySelectorAll("tbody tr");
            const pagination = document.getElementById("pagination");
            const showAllBtn = document.getElementById("showAllButton");

            let currentPage = 1;
            const pageSize = 5; // 🔥 change if needed
            const totalRows = rows.length;
            const totalPages = Math.ceil(totalRows / pageSize);

            // ===============================
            // SHOW PAGE
            // ===============================
            function showPage(page) {

                currentPage = page;

                rows.forEach((row, index) => {
                    const start = (page - 1) * pageSize;
                    const end = start + pageSize;

                    row.style.display = (index >= start && index < end) ? "" : "none";
                });

                renderPagination();
            }

            // ===============================
            // RENDER PAGINATION
            // ===============================
            function renderPagination() {

                if (!pagination) return;

                pagination.innerHTML = "";

                // PREVIOUS
                const prev = document.createElement("li");
                prev.className = "page-item " + (currentPage === 1 ? "disabled" : "");
                prev.innerHTML = '<a class="page-link" href="#">Previous</a>';
                prev.onclick = function (e) {
                    e.preventDefault();
                    if (currentPage > 1) showPage(currentPage - 1);
                };
                pagination.appendChild(prev);

                // PAGE NUMBERS
                for (let i = 1; i <= totalPages; i++) {
                    const li = document.createElement("li");
                    li.className = "page-item " + (i === currentPage ? "active" : "");
                    li.innerHTML = '<a class="page-link" href="#">' + i + '</a>';

                    li.onclick = function (e) {
                        e.preventDefault();
                        showPage(i);
                    };

                    pagination.appendChild(li);
                }

                // NEXT
                const next = document.createElement("li");
                next.className = "page-item " + (currentPage === totalPages ? "disabled" : "");
                next.innerHTML = '<a class="page-link" href="#">Next</a>';
                next.onclick = function (e) {
                    e.preventDefault();
                    if (currentPage < totalPages) showPage(currentPage + 1);
                };
                pagination.appendChild(next);
            }

            // ===============================
            // SHOW ALL BUTTON
            // ===============================
            if (showAllBtn) {
                showAllBtn.addEventListener("click", function () {

                    rows.forEach(row => row.style.display = "");

                    if (pagination) pagination.innerHTML = "";
                    this.style.display = "none";
                });
            }

            // ===============================
            // INIT
            // ===============================
            if (rows.length > 0) {
                showPage(1);
            }

        });
    </script>
    <script>
document.addEventListener("DOMContentLoaded", function () {

    console.log("✅ Validation Script Loaded");

    // ================= COMMON FUNCTIONS =================
    function showError(field, message) {
        if (!field) return;
        field.style.border = "1px solid red";

        let msg = field.parentElement.nextElementSibling;
        if (msg) msg.textContent = message;
    }

    function clearError(field) {
        if (!field) return;
        field.style.border = "1px solid #ddd";

        let msg = field.parentElement.nextElementSibling;
        if (msg) msg.textContent = "";
    }

    function validateEmail(email) {
        return /^\S+@@\S+\.\S+$/.test(email);
    }

    function validatePhone(phone) {
        return /^[0-9]{10}$/.test(phone);
    }

    function validatePin(pin) {
        return /^[0-9]{6}$/.test(pin);
    }

    function validatePAN(pan) {
        return /^[A-Z]{5}[0-9]{4}[A-Z]{1}$/.test(pan);
    }

    // ================= ADD VALIDATION =================
    function validateAddForm() {
        let isValid = true;

        const fields = {
            txtCompanyName: "Company Name",
            txtCompanyAddress1: "Address",
            txtCity: "City",
            ddlStateId: "State",
            ddlCountryId: "Country",
            txtPincode: "PIN",
            txtEmail: "Email",
            txtContactNo: "Contact"
        };

        Object.keys(fields).forEach(id => {
            const field = document.getElementById(id);
            if (!field || !field.value.trim()) {
                showError(field, fields[id] + " is required");
                isValid = false;
            } else {
                clearError(field);
            }
        });

        // Email
        const email = document.getElementById("txtEmail");
        if (email.value && !validateEmail(email.value)) {
            showError(email, "Invalid email");
            isValid = false;
        }

        // Phone
        const phone = document.getElementById("txtContactNo");
        if (phone.value && !validatePhone(phone.value)) {
            showError(phone, "10 digit number required");
            isValid = false;
        }

        // PIN
        const pin = document.getElementById("txtPincode");
        if (pin.value && !validatePin(pin.value)) {
            showError(pin, "Invalid PIN");
            isValid = false;
        }

        // PAN
        const pan = document.getElementById("txtPAN");
        if (pan.value && !validatePAN(pan.value)) {
            showError(pan, "Invalid PAN");
            isValid = false;
        }

        return isValid;
    }

    // ================= EDIT VALIDATION =================
    function validateEditForm() {
        let isValid = true;

        const fields = {
            txtEditCompanyName: "Company Name",
            txtEditCompanyAddress1: "Address",
            txtEditCity: "City",
            ddlEditStateId: "State",
            ddlEditCountryId: "Country",
            txtEditPincode: "PIN",
            txtEditEmail: "Email",
            txtEditContactNo: "Contact"
        };

        Object.keys(fields).forEach(id => {
            const field = document.getElementById(id);
            if (!field || !field.value.trim()) {
                showError(field, fields[id] + " is required");
                isValid = false;
            } else {
                clearError(field);
            }
        });

        // Email
        const email = document.getElementById("txtEditEmail");
        if (email.value && !validateEmail(email.value)) {
            showError(email, "Invalid email");
            isValid = false;
        }

        // Phone
        const phone = document.getElementById("txtEditContactNo");
        if (phone.value && !validatePhone(phone.value)) {
            showError(phone, "Invalid number");
            isValid = false;
        }

        // PIN
        const pin = document.getElementById("txtEditPincode");
        if (pin.value && !validatePin(pin.value)) {
            showError(pin, "Invalid PIN");
            isValid = false;
        }

        return isValid;
    }

    // ================= HOOK INTO BUTTONS =================
    document.querySelectorAll(".add-submit").forEach(btn => {
        btn.addEventListener("click", function (e) {
            if (!validateAddForm()) {
                e.stopImmediatePropagation();
                console.log("❌ ADD VALIDATION FAILED");
            } else {
                console.log("✅ ADD VALIDATION PASSED");
            }
        }, true);
    });

    document.querySelectorAll(".edit-submit").forEach(btn => {
        btn.addEventListener("click", function (e) {
            if (!validateEditForm()) {
                e.stopImmediatePropagation();
                console.log("❌ EDIT VALIDATION FAILED");
            } else {
                console.log("✅ EDIT VALIDATION PASSED");
            }
        }, true);
    });

});
</script>


