@model A2R_Project.Models.CompanyViewModel

@{
    ViewBag.Title = "List";
}
<style>
    /* ================= GLOBAL ================= */
    body {
        background: #f4f7fb;
        font-family: 'Segoe UI', sans-serif;
        color: #000;
    }

    /* ================= CARD ================= */
    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        background: #ffffff;
    }

    .card-title {
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: #111827;
    }

    /* ================= TABLE ================= */
    #companyTable {
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
        border-collapse: collapse;
        border-spacing: 0;
        width: 100%;
    }

        #companyTable thead {
            background: #3f454c;
        }

            #companyTable thead th {
                color: #fff !important;
                border: none !important;
                font-size: 14px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.6px;
                padding: 14px;
                text-align: center !important;
                white-space: nowrap;
            }

        #companyTable tbody td {
            font-size: 15px;
            font-weight: 600;
            color: #34495e;
            padding: 14px;
            vertical-align: middle !important;
            text-align: center !important;
            background-color: white !important;
            border: none !important;
        }

            #companyTable tbody td:first-child {
                font-weight: 700 !important;
                color: #2c3e50 !important;
                font-size: 15px !important;
            }

        #companyTable tbody tr {
            transition: all 0.25s ease;
        }

        /* ===== TABLE ACTION BUTTONS ===== */
        #companyTable .btn-sm {
            width: 36px !important;
            height: 36px !important;
            border-radius: 10px !important;
            padding: 0 !important;
            margin: 0 2px !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            border: none !important;
            transition: all 0.25s ease;
        }

            #companyTable .btn-sm i {
                font-size: 16px !important;
                line-height: 1;
            }

            #companyTable .btn-sm:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }

        #companyTable .btn-gradient-primary {
            background: linear-gradient(135deg, #4e73df, #224abe) !important;
            color: #fff !important;
            border-radius: 10px !important;
        }

        #companyTable .btn-gradient-dark {
            background: linear-gradient(135deg, #36b9cc, #1f8ea3) !important;
            color: #fff !important;
            border-radius: 10px !important;
            border: none !important;
        }

        #companyTable .btn-gradient-warning {
            background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
            color: #fff !important;
            border-radius: 10px !important;
            border: none !important;
        }

        #companyTable tbody td:last-child {
            text-align: center !important;
            vertical-align: middle !important;
            display: table-cell !important;
            white-space: nowrap;
        }

            #companyTable tbody td:last-child .btn-group {
                display: inline-flex !important;
                align-items: center !important;
                justify-content: center !important;
                gap: 5px;
                flex-wrap: nowrap;
            }

    /* ================= BADGES ================= */
    .badge-success {
        background: #16a34a !important;
        color: #fff !important;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        white-space: nowrap;
    }

    .badge-danger {
        background: #dc2626 !important;
        color: #fff !important;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        white-space: nowrap;
    }

    /* ================= BUTTONS ================= */
    .btn {
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        padding: 6px 14px;
        transition: all 0.3s ease;
    }

        .btn:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }

    .btn-gradient-primary {
        background: linear-gradient(135deg, #10b981, #059669) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 600;
        border-radius: 10px !important;
        padding: 8px 18px !important;
        transition: 0.2s;
    }

        .btn-gradient-primary:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(16,185,129,0.4);
            color: #fff !important;
        }

    .btn-gradient-dark {
        background: linear-gradient(45deg, #434343, #000000);
        color: #fff;
        border: none;
    }

    .btn-gradient-warning {
        background: linear-gradient(45deg, #ff416c, #ff4b2b);
        color: #fff;
        border: none;
    }

    td .btn {
        margin: 2px;
    }

    /* ================= SHOW ALL BUTTON ================= */
    #showAllButton {
        background: linear-gradient(135deg, #10b981, #059669) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 600;
        border-radius: 10px !important;
        padding: 8px 20px !important;
        transition: 0.2s;
    }

        #showAllButton:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(16,185,129,0.4);
        }

    /* ================= PAGINATION ================= */
    .pagination .page-item .page-link {
        border-radius: 8px;
        margin: 0 4px;
        color: #4f46e5;
        font-weight: 500;
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #fff;
        border: none;
    }

    /* ================= FORM ELEMENTS ================= */
    .form-control {
        border-radius: 10px;
        border: 1px solid #ddd;
        padding: 10px;
        font-size: 14px;
        font-weight: 600;
        color: #000;
        width: 100%;
    }

        .form-control:focus {
            border-color: #4facfe;
            box-shadow: 0 0 8px rgba(79,172,254,0.5);
        }

    label {
        font-weight: 700;
        font-size: 13px;
        color: #000;
    }

    .mandatoryfield {
        color: red;
    }

    .validationMessage {
        color: red;
        font-size: 12px;
        font-weight: 600;
    }

    /* ================= IMAGE ================= */
    #logoPreview, #editLogoPreview {
        width: 100%;
        max-width: 130px;
        height: 100px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px dashed #00c6ff;
        background: #fff;
        padding: 4px;
        transition: 0.3s;
    }

        #logoPreview:hover, #editLogoPreview:hover {
            border-color: #4facfe;
            transform: scale(1.05);
        }

    #image_upload_previewEmployeeView {
        max-width: 100px !important;
        max-height: 64px !important;
        height: auto !important;
        border: 2px dashed #00c6ff !important;
        border-radius: 12px !important;
        padding: 4px;
        object-fit: cover;
        transition: 0.3s;
    }

    #image_upload_previewCompanyDel {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px solid #e0e0e0;
        background: #fff;
        transition: 0.3s;
    }

    /* ================= CHECKBOX ================= */
    .rounded-checkbox {
        transform: scale(1.2);
        margin-right: 5px;
    }

    /* ================= MODAL BACKDROP ================= */
    .modal-backdrop {
        opacity: 0.25 !important;
    }

    /* ================= CLEAN FIELD (DELETE MODAL) ================= */
    .clean-field {
        display: flex;
        align-items: center;
        margin-bottom: 14px;
        padding: 6px 0;
        border-bottom: 1px solid #eaeaea;
        flex-wrap: wrap;
        gap: 8px;
    }

        .clean-field .label {
            min-width: 140px;
            font-weight: 700;
            color: #333;
            font-size: 14px;
        }

            .clean-field .label::after {
                content: " :";
                margin-left: 5px;
                color: #777;
            }

        .clean-field .value {
            margin-left: 10px;
            padding: 6px 12px;
            background: #ffffff;
            border-radius: 8px;
            border: 1px solid #e0e6f0;
            font-weight: 600;
            color: #000;
            min-width: 120px;
            word-break: break-word;
        }

        .clean-field:hover .value {
            background: #e6f0ff;
            transition: 0.3s;
        }

    #lblDelCompanyName {
        display: block;
        text-align: center;
        font-size: 22px;
        font-weight: 800;
        color: #0072ff;
        margin-bottom: 15px;
        letter-spacing: 1px;
        word-break: break-word;
    }

    /* ================= MODAL ANIMATION ================= */
    @@keyframes smoothPopup {
        from {
            transform: translateY(-20px) scale(0.97);
            opacity: 0;
        }

        to {
            transform: translateY(0) scale(1);
            opacity: 1;
        }
    }

    /* =================================================================
           BASE MODAL — ADD / EDIT / VIEW
           ✅ ALL 3 SAME FIXED SIZE + SCROLLBAR ALWAYS WORKS
        ================================================================= */
    #addCompany .modal-dialog,
    #editCompany .modal-dialog,
    #viewCompany .modal-dialog {
        margin: auto !important;
        display: flex !important;
        align-items: center !important;
        width: 94vw !important;
        max-width: 1100px !important;
        min-height: calc(100vh - 40px) !important;
    }

    /* ✅ KEY FIX — fixed height same for all 3, no auto */
    #addCompany .modal-content,
    #editCompany .modal-content,
    #viewCompany .modal-content {
        display: flex !important;
        flex-direction: column !important;
        width: 100% !important;
        height: 82vh !important; /* ✅ ALL 3 SAME FIXED HEIGHT */
        min-height: 82vh !important; /* ✅ ALL 3 SAME MIN */
        max-height: 82vh !important; /* ✅ ALL 3 SAME MAX */
        border-radius: 20px !important;
        border: none !important;
        box-shadow: 0 25px 70px rgba(0,0,0,0.35) !important;
        overflow: hidden !important;
        animation: smoothPopup 0.35s ease;
    }

    /* ================= ALL MODAL HEADERS ================= */
    #addCompany .modal-header,
    #editCompany .modal-header,
    #viewCompany .modal-header,
    #deleteCompany .modal-header {
        background: linear-gradient(135deg, #2563eb, #1e40af) !important;
        color: #fff !important;
        border: none !important;
        flex-shrink: 0 !important; /* ✅ header never shrinks */
        padding: 16px 22px !important;
        height: 60px !important; /* ✅ fixed header height */
        box-sizing: border-box !important;
    }

        #addCompany .modal-header .modal-title,
        #addCompany .modal-header .close,
        #editCompany .modal-header .modal-title,
        #editCompany .modal-header .close,
        #viewCompany .modal-header .modal-title,
        #viewCompany .modal-header .close,
        #deleteCompany .modal-header .modal-title,
        #deleteCompany .modal-header .close {
            color: #fff !important;
        }

    .modal-title {
        font-weight: 700;
        font-size: 18px;
    }

    /* ================= ALL MODAL BODIES — SCROLLABLE ================= */
    #addCompany .modal-body,
    #editCompany .modal-body,
    #viewCompany .modal-body {
        background: #f8fbff !important;
        padding: 20px 25px !important;
        flex: 1 1 auto !important; /* ✅ takes all remaining space */
        overflow-y: auto !important; /* ✅ SCROLLBAR ALWAYS ON */
        overflow-x: hidden !important;
        min-height: 0 !important; /* ✅ CRITICAL for flex scroll */
        box-sizing: border-box !important;
    }

        /* ✅ Scrollbar — styled and always visible */
        #addCompany .modal-body::-webkit-scrollbar,
        #editCompany .modal-body::-webkit-scrollbar,
        #viewCompany .modal-body::-webkit-scrollbar {
            width: 6px;
        }

        #addCompany .modal-body::-webkit-scrollbar-track,
        #editCompany .modal-body::-webkit-scrollbar-track,
        #viewCompany .modal-body::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        #addCompany .modal-body::-webkit-scrollbar-thumb,
        #editCompany .modal-body::-webkit-scrollbar-thumb,
        #viewCompany .modal-body::-webkit-scrollbar-thumb {
            background: #2563eb;
            border-radius: 10px;
        }

            #addCompany .modal-body::-webkit-scrollbar-thumb:hover,
            #editCompany .modal-body::-webkit-scrollbar-thumb:hover,
            #viewCompany .modal-body::-webkit-scrollbar-thumb:hover {
                background: #1e40af;
            }

    #addCompany .row,
    #editCompany .row,
    #viewCompany .row {
        margin-bottom: 8px;
    }

    /* ================= ALL MODAL FOOTERS ================= */
    #addCompany .modal-footer,
    #editCompany .modal-footer,
    #viewCompany .modal-footer {
        flex-shrink: 0 !important; /* ✅ footer never shrinks */
        background: #fff !important;
        border-top: 1px solid #eee !important;
        padding: 12px 20px !important;
        display: flex !important;
        justify-content: flex-end !important;
        gap: 10px !important;
        flex-wrap: wrap !important;
        height: 60px !important; /* ✅ fixed footer height */
        box-sizing: border-box !important;
    }

    /* ================= ADD & EDIT FORM CONTROLS ================= */
    #addCompany .form-control,
    #editCompany .form-control {
        border-radius: 12px;
        border: 1px solid #ddd;
        font-weight: 300;
        transition: 0.3s;
        width: 100%;
    }

        #addCompany .form-control:focus,
        #editCompany .form-control:focus {
            border-color: #00c6ff;
            box-shadow: 0 0 10px rgba(0,198,255,0.4);
        }

    /* ================= DROPDOWN ================= */
    #addCompany select,
    #editCompany select {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background: #fff url("data:image/svg+xml;utf8,<svg fill='%230072ff' height='22' viewBox='0 0 24 24' width='22' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/></svg>") no-repeat right 14px center;
        border-radius: 12px;
        border: 1px solid #ddd;
        padding: 10px 36px 10px 12px;
        font-size: 14px;
        font-weight: 500;
        height: 44px;
        cursor: pointer;
        width: 100%;
    }

    .input-group-append {
        display: none !important;
    }

    /* ================= ISACTIVE SWITCH ================= */
    #addCompany .form-check,
    #editCompany .form-check,
    #viewCompany .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 8px;
    }

    #addCompany .form-check-input,
    #editCompany .form-check-input,
    #viewCompany .form-check-input {
        appearance: none;
        -webkit-appearance: none;
        width: 45px;
        height: 22px;
        background: #ccc;
        border-radius: 50px;
        position: relative;
        transition: 0.3s;
        flex-shrink: 0;
    }

    #addCompany .form-check-input {
        cursor: pointer;
    }

    #editCompany .form-check-input {
        cursor: pointer;
    }

    #viewCompany .form-check-input {
        cursor: default;
    }

        #addCompany .form-check-input::before,
        #editCompany .form-check-input::before,
        #viewCompany .form-check-input::before {
            content: "";
            width: 18px;
            height: 18px;
            background: #fff;
            position: absolute;
            top: 2px;
            left: 3px;
            border-radius: 50%;
            transition: 0.3s;
        }

        #addCompany .form-check-input:checked,
        #editCompany .form-check-input:checked,
        #viewCompany .form-check-input:checked {
            background: linear-gradient(45deg, #00c853, #64dd17);
        }

            #addCompany .form-check-input:checked::before,
            #editCompany .form-check-input:checked::before,
            #viewCompany .form-check-input:checked::before {
                transform: translateX(22px);
            }

    #addCompany .form-check-label,
    #editCompany .form-check-label,
    #viewCompany .form-check-label {
        font-weight: 600;
    }

    /* ================= FILE UPLOAD ================= */
    #addCompany .form-control-file,
    #editCompany .form-control-file {
        width: 100%;
        padding: 8px;
        border: 2px dashed #00c6ff;
        border-radius: 12px;
        background: #f8fbff;
        cursor: pointer;
        transition: 0.3s;
        font-weight: 600;
    }

    #addCompany input[type="file"]::file-selector-button,
    #editCompany input[type="file"]::file-selector-button {
        border: none;
        padding: 6px 12px;
        border-radius: 8px;
        background: linear-gradient(45deg, #0072ff, #00c6ff);
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        margin-right: 8px;
        font-size: 13px;
    }

    /* ================= VIEW MODAL READONLY ================= */
    #viewCompany .form-control[readonly] {
        background-color: #ffffff !important;
        border: 1px solid #ddd !important;
        border-radius: 12px !important;
        font-weight: 300 !important;
        color: #000 !important;
        cursor: default;
        opacity: 1 !important;
    }

    /* ================= DELETE MODAL ================= */
    #deleteCompany .modal-content {
        border-radius: 20px;
        border: none;
        box-shadow: 0 25px 70px rgba(0,0,0,0.3);
        overflow: hidden;
        animation: smoothPopup 0.35s ease;
    }

    #deleteCompany .modal-body {
        padding: 20px;
        background: #ffffff;
    }

    #deleteCompany .card {
        border-radius: 18px;
        border: none;
        background: #ffffff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        padding: 10px;
    }

    /* =================================================================
           RESPONSIVE BREAKPOINTS
        ================================================================= */

    /* LARGE DESKTOP 1200px+ */
    @@media (min-width: 1200px) {
        #addCompany .modal-dialog,
        #editCompany .modal-dialog,
        #viewCompany .modal-dialog {
            width: 90vw !important;
            max-width: 1100px !important;
        }

        #addCompany .modal-content,
        #editCompany .modal-content,
        #viewCompany .modal-content {
            height: 82vh !important;
            min-height: 82vh !important;
            max-height: 82vh !important;
        }
    }

    /* ✅ LAPTOP TOUCH 950px - 1199px — YOUR EXACT PROBLEM SIZE */
    @@media (min-width: 950px) and (max-width: 1199px) {
        #addCompany .modal-dialog,
        #editCompany .modal-dialog,
        #viewCompany .modal-dialog {
            width: 96vw !important;
            max-width: 96vw !important;
        }

        #addCompany .modal-content,
        #editCompany .modal-content,
        #viewCompany .modal-content {
            height: 86vh !important; /* ✅ same all 3 */
            min-height: 86vh !important; /* ✅ same all 3 */
            max-height: 86vh !important; /* ✅ same all 3 */
        }

        #addCompany .modal-body,
        #editCompany .modal-body,
        #viewCompany .modal-body {
            overflow-y: auto !important; /* ✅ scrollbar shows */
            padding: 16px 18px !important;
        }
    }

    /* TABLET LANDSCAPE 768px - 949px */
    @@media (min-width: 768px) and (max-width: 949px) {
        #addCompany .modal-dialog,
        #editCompany .modal-dialog,
        #viewCompany .modal-dialog {
            width: 97vw !important;
            max-width: 97vw !important;
        }

        #addCompany .modal-content,
        #editCompany .modal-content,
        #viewCompany .modal-content {
            height: 88vh !important;
            min-height: 88vh !important;
            max-height: 88vh !important;
        }

        #addCompany .modal-body .col-md-3,
        #editCompany .modal-body .col-md-3,
        #viewCompany .modal-body .col-md-3 {
            flex: 0 0 50% !important;
            max-width: 50% !important;
        }

        #companyTable thead th,
        #companyTable tbody td {
            padding: 10px 8px !important;
            font-size: 13px !important;
        }
    }

    /* SMALL 576px - 767px */
    @@media (min-width: 576px) and (max-width: 767px) {
        #addCompany .modal-dialog,
        #editCompany .modal-dialog,
        #viewCompany .modal-dialog {
            width: 98vw !important;
            max-width: 98vw !important;
            margin: 8px auto !important;
            min-height: calc(100vh - 16px) !important;
        }

        #addCompany .modal-content,
        #editCompany .modal-content,
        #viewCompany .modal-content {
            height: 92vh !important;
            min-height: 92vh !important;
            max-height: 92vh !important;
            border-radius: 16px !important;
        }

        #addCompany .modal-body .col-md-3,
        #editCompany .modal-body .col-md-3,
        #viewCompany .modal-body .col-md-3 {
            flex: 0 0 100% !important;
            max-width: 100% !important;
        }

        #addCompany .modal-body,
        #editCompany .modal-body,
        #viewCompany .modal-body {
            padding: 15px !important;
        }

        .card-body {
            overflow-x: auto;
        }

        #companyTable {
            min-width: 600px;
        }

        .pagination .page-link {
            padding: 4px 8px;
            font-size: 13px;
        }
    }

    /* MOBILE max 575px */
    @@media (max-width: 575px) {
        #addCompany .modal-dialog,
        #editCompany .modal-dialog,
        #viewCompany .modal-dialog {
            width: 100vw !important;
            max-width: 100vw !important;
            margin: 0 !important;
            min-height: 100vh !important;
            align-items: flex-end !important;
        }

        #addCompany .modal-content,
        #editCompany .modal-content,
        #viewCompany .modal-content {
            height: 95vh !important;
            min-height: 95vh !important;
            max-height: 95vh !important;
            border-radius: 18px 18px 0 0 !important;
        }

        #addCompany .modal-body .col-md-3,
        #editCompany .modal-body .col-md-3,
        #viewCompany .modal-body .col-md-3 {
            flex: 0 0 100% !important;
            max-width: 100% !important;
        }

        #addCompany .modal-body,
        #editCompany .modal-body,
        #viewCompany .modal-body {
            padding: 12px !important;
        }

        #addCompany .modal-footer,
        #editCompany .modal-footer,
        #viewCompany .modal-footer {
            justify-content: center !important;
        }

            #addCompany .modal-footer .btn,
            #editCompany .modal-footer .btn,
            #viewCompany .modal-footer .btn {
                flex: 1 1 auto !important;
                min-width: 80px !important;
            }

        .modal-title {
            font-size: 16px !important;
        }

        .card-body {
            overflow-x: auto;
        }

        #companyTable {
            min-width: 550px;
        }

        .row.mt-3 {
            flex-direction: column;
            gap: 10px;
        }

            .row.mt-3 .col-md-6 {
                width: 100% !important;
            }

        #pagination.justify-content-end {
            justify-content: center !important;
        }

        #deleteCompany .col-md-4 {
            flex: 0 0 100% !important;
            max-width: 95% !important;
            margin-bottom: 12px;
        }

        .clean-field {
            flex-direction: column;
            align-items: flex-start;
        }

            .clean-field .value {
                margin-left: 0;
                width: 100%;
            }
    }

    /* ================= BOOTSTRAP MODAL MAX-WIDTH OVERRIDE ================= */
    @@media (min-width: 576px) {
        .modal-dialog {
            max-width: 1100px;
            margin: 1.75rem auto;
        }
    }
</style>
<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Company List</strong>
                @if (ViewBag.CanInsert == true)
                {
                    <button type="button" class="btn btn-gradient-primary btn-rounded btn-fw"
                            data-toggle="modal" data-target="#addCompany">
                        <i class="fa fa-plus"></i> Add
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-secondary btn-rounded btn-fw"
                            onclick="noAccess('Insert')">
                        <i class="fa fa-plus"></i> Add
                    </button>
                }
            </div>
            <table class="table table-bordered" id="companyTable">
                <thead>
                    <tr>
                        <th>Company Name</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Country</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.companies.Count() > 0)
                    {
                        foreach (var company in Model.companies)
                        {
                            <tr class="table-info">
                                <td class="table-primary">@company.CompanyName</td>
                                <td class="table-warning">@company.Address1</td>
                                <td class="table-primary">@company.City</td>
                                <td class="table-warning">@company.StateName</td>
                                <td class="table-primary">@company.CountryName</td>
                                <td class="table-warning">
                                    @if (company.IsActive == 1)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @* EDIT *@
                                    @if (ViewBag.CanUpdate == true)
                                    {
                                        <button type="button" class="btn btn-sm btn-custom btn-gradient-primary btn-rounded editByCompanyId"
                                                data-company-id="@company.CompanyID"
                                                data-toggle="modal" data-target="#editCompany"
                                                title="Edit">
                                            <i class="mdi mdi-pencil"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-secondary btn-rounded"
                                                title="No Edit Permission"
                                                onclick="noAccess('Update')">
                                            <i class="mdi mdi-pencil"></i>
                                        </button>
                                    }

                                    @* VIEW — always visible *@
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-dark btn-rounded viewByCompanyId"
                                            data-company-id="@company.CompanyID"
                                            data-toggle="modal" data-target="#viewCompany"
                                            title="View">
                                        <i class="mdi mdi-eye"></i>
                                    </button>

                                    @* DELETE *@
                                    @if (ViewBag.CanDelete == true)
                                    {
                                        <button type="button" class="btn btn-sm btn-custom btn-gradient-warning btn-rounded deleteCompanies"
                                                data-company-id="@company.CompanyID"
                                                data-toggle="modal" data-target="#deleteCompany"
                                                title="Delete">
                                            <i class="mdi mdi-delete"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-secondary btn-rounded"
                                                title="No Delete Permission"
                                                onclick="noAccess('Delete')">
                                            <i class="mdi mdi-delete"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
            <div class="row mt-3">
                <div class="col-md-6">
                    <button id="showAllButton" class="btn btn-gradient-primary">
                        Show All
                    </button>
                </div>

                <div class="col-md-6 text-right">
                    <ul id="pagination" class="pagination justify-content-end"></ul>
                </div>
            </div>
        </div>
    </div>
</div>

