@model IEnumerable<A2R_Project.Models.Role>
@{
    ViewBag.Title = "Roles Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/@@mdi/font@6.5.95/css/materialdesignicons.min.css" rel="stylesheet">
<style>

    :root {
        --primary: #4e73df;
        --primary-dark: #224abe;
        --success: #16a34a;
        --danger: #dc2626;
        --warning: #f59e0b;
        --dark: #111827;
        --light: #f9fafb;
        --white: #ffffff;
        --gray: #6b7280;
    }

    body {
        background: #f3f4f6;
        font-family: 'Segoe UI', sans-serif;
    }

    /* ===== ALL 4 MODALS - SAME SIZE AS USER MANAGEMENT ===== */
    .modal-dialog {
        max-width: 700px !important;
        margin-top: 80px !important;
    }

    /* ===== MODAL CONTENT ===== */
    .modal-content {
        border-radius: 18px !important;
        border: none !important;
        box-shadow: 0 12px 40px rgba(0,0,0,0.18) !important;
        overflow: hidden;
        animation: fadeInScale 0.3s ease;
    }

    @@keyframes fadeInScale {
        from

    {
        opacity: 0;
        transform: scale(0.93);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }

    }

    /* ===== MODAL HEADER - ALL SAME GRADIENT AS USER MANAGEMENT ===== */
    #addRole .modal-header,
    #editRole .modal-header,
    #viewRole .modal-header,
    #deleteRole .modal-header {
        background: linear-gradient(135deg, #4e73df, #224abe) !important;
        color: #fff !important;
        border-bottom: none !important;
        border-radius: 18px 18px 0 0 !important;
        padding: 16px 22px !important;
    }

    #addRole .modal-title,
    #editRole .modal-title,
    #viewRole .modal-title,
    #deleteRole .modal-title {
        color: #fff !important;
        font-size: 18px !important;
        font-weight: 700 !important;
        letter-spacing: 0.4px !important;
    }

    #addRole .modal-header .close,
    #editRole .modal-header .close,
    #viewRole .modal-header .close,
    #deleteRole .modal-header .close {
        color: #fff !important;
        opacity: 1 !important;
        font-size: 22px !important;
        font-weight: 700 !important;
        line-height: 1 !important;
        background: transparent !important;
        border: none !important;
        cursor: pointer;
        padding: 0 4px !important;
        margin: 0 !important;
        text-shadow: none !important;
    }

        #addRole .modal-header .close:hover,
        #editRole .modal-header .close:hover,
        #viewRole .modal-header .close:hover,
        #deleteRole .modal-header .close:hover {
            opacity: 0.85 !important;
        }

    /* ===== MODAL BODY ===== */
    .modal-body {
        background: #f9fbff !important;
        padding: 24px 26px !important;
        font-size: 15px;
    }

    /* ===== MODAL FOOTER ===== */
    .modal-footer {
        background: #fff !important;
        border-top: 1px solid #eee !important;
        border-radius: 0 0 18px 18px !important;
        padding: 14px 22px !important;
    }

        .modal-footer .btn {
            border-radius: 25px !important;
            padding: 7px 20px !important;
            font-weight: 600 !important;
            font-size: 14px !important;
            transition: all 0.25s ease;
            border: none !important;
        }

            .modal-footer .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }

        /* Save / Update */
        .modal-footer .btn-primary-modern {
            background: linear-gradient(135deg, #4e73df, #224abe) !important;
            color: #fff !important;
        }

        /* Reset */
        .modal-footer .btn-warning-modern {
            background: linear-gradient(135deg, #f6c23e, #e0a800) !important;
            color: #000 !important;
        }

        /* Cancel */
        .modal-footer .btn-secondary {
            background: #6c757d !important;
            color: #fff !important;
        }

        /* Delete */
        .modal-footer .btn-danger-modern {
            background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
            color: #fff !important;
        }

    /* ===== MODAL BACKDROP ===== */
    .modal-backdrop {
        opacity: 0.25 !important;
        background-color: #000;
    }

    /* ===== CARD ===== */
    .card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card-header-custom {
        background-color: white;
        color: black;
        border-radius: 15px 15px 0 0;
        padding: 18px 20px;
    }

    .card-title {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: 0.5px;
        color: #2c3e50;
    }

    /* ===== TABLE ===== */
    .table {
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
        border-collapse: collapse;
        border-spacing: 0;
    }

        .table thead {
            background: #3f454c;
        }

            .table thead th {
                color: #fff !important;
                border: none !important;
                font-size: 14px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.6px;
                padding: 14px;
                text-align: center !important;
            }

        .table tbody td {
            font-size: 15px;
            font-weight: 600;
            color: #34495e;
            padding: 14px;
            vertical-align: middle !important;
            text-align: center !important;
            background-color:white !important;
        }

            .table tbody td:first-child {
                text-align: left !important;
            }

        .table tbody tr {
            transition: all 0.25s ease;
        }

          

        /* ===== ACTION BUTTONS ===== */
        .table .btn-sm {
            width: 36px !important;
            height: 36px !important;
            border-radius: 10px !important;
            padding: 0 !important;
            margin-right: 4px;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            border: none !important;
            transition: all 0.25s ease;
        }

            .table .btn-sm i {
                font-size: 16px !important;
                line-height: 1;
            }

            .table .btn-sm:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }

    .btn-group {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

    /* Edit button */
    .editByRoleId {
        background: linear-gradient(135deg, #4e73df, #224abe) !important;
        color: #fff !important;
    }

    /* View button */
    .viewByRoleId {
        background: linear-gradient(135deg, #36b9cc, #1f8ea3) !important;
        color: #fff !important;
    }

    /* Delete button */
    .deleteRoles {
        background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
        color: #fff !important;
    }

    /* ===== ADD ROLE BUTTON ===== */
    .add-role-btn {
        background: linear-gradient(135deg, #28a745, #20c997) !important;
        color: #fff;
        font-weight: 700;
        padding: 8px 18px;
        border-radius: 25px !important;
        border: none;
        transition: all 0.25s ease;
    }

        .add-role-btn:hover {
            background: linear-gradient(135deg, #218838, #17a2b8) !important;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.15);
        }

    /* ===== SHOW ALL BUTTON ===== */
    .show-all-btn {
        background: linear-gradient(135deg, #36b9cc, #1f8ea3) !important;
        color: #fff;
        font-weight: 700;
        padding: 6px 16px;
        border-radius: 25px !important;
        border: none;
        transition: all 0.25s ease;
    }

        .show-all-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            color: #fff;
        }

    /* ===== STATUS BADGES ===== */
    .status-badge {
        padding: 7px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .badge-success-custom {
        background: linear-gradient(135deg, #1cc88a, #17a673) !important;
        color: #fff;
    }

    .badge-danger-custom {
        background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
        color: #fff;
    }

    /* ===== EMPTY STATE ===== */
    .empty-state {
        text-align: center;
        padding: 40px;
        color: #6b7280;
    }

        .empty-state i {
            font-size: 40px;
            margin-bottom: 10px;
            color: #9ca3af;
        }

    /* ===== PAGINATION ===== */
    .pagination-modern .page-link {
        border-radius: 10px;
        margin: 0 4px;
        font-weight: 600;
        color: #4e73df;
        border: none;
    }

    .pagination-modern .active .page-link {
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: #fff;
        border: none;
    }

    .pagination-modern .page-link:hover {
        background: #e8edff;
    }

    /* ===== FORM CONTROLS ===== */
    .form-control,
    .form-control-modern {
        border-radius: 10px;
        border: 1px solid #dce3f0;
        padding: 8px 12px;
        font-weight: 600;
        color: #111 !important;
        transition: all 0.3s ease;
    }

        .form-control:focus,
        .form-control-modern:focus {
            border-color: #4e73df;
            box-shadow: 0 0 0 3px rgba(78,115,223,0.15);
            outline: none;
        }

    label {
        font-weight: 600;
        color: #2c3e50;
    }

    /* ===== VIEW BOX (matches user page) ===== */
    .view-box {
        background: #f1f4ff;
        border-radius: 8px;
        padding: 8px 12px;
        font-weight: 600;
        color: #2c3e50;
        min-height: 38px;
        display: flex;
        align-items: center;
    }

    /* ===== VIEW MODAL ROWS ===== */
    .view-row {
        display: flex;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
        gap: 16px;
    }

        .view-row.mb-0 {
            border-bottom: none;
        }

    .view-label {
        width: 130px;
        font-size: 14px;
        font-weight: 700;
        color: #2c3e50;
        flex-shrink: 0;
    }

    .view-value {
        font-size: 14px;
        font-weight: 600;
        color: #111827;
        flex: 1;
    }

    /* ===== CUSTOM SWITCH ===== */
    .custom-switch {
        padding-left: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .custom-switch .custom-control-label {
            padding-left: 52px;
            line-height: 24px;
            font-size: 13px;
            font-weight: 600;
            color: #dc2626;
            cursor: pointer;
        }

        .custom-switch .custom-control-input:checked ~ .custom-control-label {
            color: #10b981;
        }

        .custom-switch .custom-control-label::before {
            width: 44px;
            height: 24px;
            border-radius: 24px;
            background-color: #dc2626;
            border: none;
            top: 0;
            left: 0;
            transition: background-color 0.25s ease;
        }

        .custom-switch .custom-control-label::after {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background-color: #fff;
            top: 3px;
            left: 3px;
            transition: transform 0.25s ease;
            box-shadow: 0 1px 4px rgba(0,0,0,0.2);
        }

        .custom-switch .custom-control-input:checked ~ .custom-control-label::before {
            background-color: #10b981;
        }

        .custom-switch .custom-control-input:checked ~ .custom-control-label::after {
            transform: translateX(20px);
        }

        .custom-switch .custom-control-input:focus ~ .custom-control-label::before {
            box-shadow: 0 0 0 3px rgba(16,185,129,0.25);
        }

    /* ===== DELETE MODAL BODY ===== */
    #deleteRole .modal-body {
        text-align: center;
        padding: 30px !important;
        background: #fff !important;
    }

    /* ===== VALIDATION ===== */
    .mandatoryfield {
        color: red;
    }

    .validationMessage {
        color: red;
        font-size: 12px;
        display: block;
        margin-top: 4px;
    }

    .is-invalid {
        border-color: #ef4444 !important;
    }

    /* ===== PAGE INFO SPAN ===== */
    #pageInfo {
        background: #eef2ff;
        color: #2c3e50;
        font-weight: 700;
        font-size: 14px;
        padding: 5px 14px;
        border-radius: 20px;
    }

    @@media (max-width: 768px) {
        .table th, .table td

    {
        font-size: 12px;
        padding: 8px;
    }

    .modal-dialog {
        max-width: 95% !important;
        margin: 10px auto;
    }

    .btn {
        font-size: 12px;
    }

    }
    /* ===== STATUS INLINE FIX ===== */
    .form-group-inline {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 20px;
    }

        /* keep label and toggle in one row */
        .form-group-inline label {
            margin-bottom: 0;
            min-width: 80px;
        }

    /* fix switch alignment */
    .custom-switch {
        display: flex !important;
        align-items: center !important;
        margin: 0 !important;
    }

    .table thead {
        background: #3b4248; /* dark bluish-gray (matches your image) */
    }

        .table thead th {
            color: #e5e7eb !important; /* soft white (not pure white) */
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            font-size: 14px;
            border: none !important;
            padding: 14px;
        }
    /* ===== ALL MODALS - UNIFORM SIZE ===== */
    .modal-content {
        min-height: 420px !important;
    }

    .modal-body {
        min-height: 300px !important;
        max-height: 300px !important;
        overflow-y: auto !important;
    }

    /* Delete modal - center content vertically */
    #deleteRole .modal-body {
        min-height: 300px !important;
        max-height: 300px !important;
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
    }

    /* View modal - same height */
    #viewRole .modal-body {
        min-height: 300px !important;
        max-height: 300px !important;
    }

    .modal-body .form-group {
        margin-bottom: 20px !important;
    }

    .modal-body .row {
        margin-bottom: 15px !important;
    }

    .modal-body {
        padding: 28px 30px !important;
    }

    .view-box {
        background: transparent !important; /* no color */
        border-radius: 8px;
        padding: 8px 12px;
        font-weight: 600;
        color: #2c3e50;
        min-height: 38px;
        display: flex;
        align-items: center;
    }
    /* Add spacing below header for Add/Edit forms */
    #addRole .modal-body form,
    #editRole .modal-body form {
        margin-top: 10px;
    }

    .view-row {
        display: flex;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
        gap: 16px;
    }

    .view-label {
        width: 130px;
        font-weight: 700;
        color: #2c3e50;
    }

    .view-value {
        flex: 1;
        font-weight: 600;
        color: #111827;
    }

    .view-row {
        display: flex;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
        gap: 16px;
    }

    .view-label {
        width: 130px;
        font-weight: 700;
        color: #2c3e50;
    }

    .view-value {
        flex: 1;
        font-weight: 600;
        color: #111827;
    }

    .view-label {
        width: 140px; /* slightly wider for better alignment */
    }

    .view-value {
        margin-left: 10px; /* small extra spacing */
    }
    </style>

<div class="container-fluid px-4 mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header-custom">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                        <div>
                            <h5 class="card-title mb-1">
                                Roles List
                            </h5>
                            <small>Total: <strong id="totalCount">@(ViewBag.TotalCount ?? 0)</strong></small>
                        </div>
                        @if (ViewBag.CanInsert == true)
                        {
                            <button type="button" class="btn add-role-btn" data-toggle="modal" data-target="#addRole">
                                <i class="fa fa-plus mr-1"></i> Add Role
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn add-role-btn"
                                    style="background:linear-gradient(135deg,#6b7280,#4b5563)!important;"
                                    onclick="noAccess('Insert')">
                                <i class="fa fa-plus mr-1"></i> Add Role
                            </button>
                        }
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped mb-0" id="roleTable">
                            <thead class="thead-dark">
                                <tr>
                                    <th>Role Name</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td style="text-align: left !important;">
                                                <div class="d-flex align-items-center" style="padding-left:10px;">
                                                    
                                                    <div>
                                                        <strong style="color:#2c3e50;">@item.Role_Name</strong>
                                                     
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                @if (item.IsActive == 1)
                                                {
                                                    <span class="status-badge badge-success-custom">
                                                        <i class="fas fa-check-circle mr-1"></i>Active
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge badge-danger-custom">
                                                        <i class="fas fa-times-circle mr-1"></i>Inactive
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm" role="group">

                                                    @* EDIT *@
                                                    @if (ViewBag.CanUpdate == true)
                                                    {
                                                        <button type="button" class="btn btn-sm editByRoleId"
                                                                data-edRoleId="@item.Role_ID"
                                                                data-toggle="modal" data-target="#editRole" title="Edit">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary"
                                                                title="No Edit Permission"
                                                                onclick="noAccess('Update')">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </button>
                                                    }

                                                    @* VIEW — always visible *@
                                                    <button type="button" class="btn btn-sm viewByRoleId"
                                                            data-vwRoleId="@item.Role_ID"
                                                            data-toggle="modal" data-target="#viewRole" title="View">
                                                        <i class="mdi mdi-eye"></i>
                                                    </button>

                                                    @* DELETE *@
                                                    @if (ViewBag.CanDelete == true)
                                                    {
                                                        <button type="button" class="btn btn-sm deleteRoles"
                                                                data-dlRoleId="@item.Role_ID"
                                                                data-toggle="modal" data-target="#deleteRole" title="Delete">
                                                            <i class="mdi mdi-delete"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary"
                                                                title="No Delete Permission"
                                                                onclick="noAccess('Delete')">
                                                            <i class="mdi mdi-delete"></i>
                                                        </button>
                                                    }

                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="empty-state">
                                            <i class="fas fa-user-shield"></i>
                                            <h5>No Roles Found</h5>
                                            <p class="mb-0">Click "Add Role" to get started</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination Controls -->
                    <div class="d-flex justify-content-between align-items-center mt-3 px-4 pb-4 flex-wrap">
                        <div style="display:flex; gap:8px;">
                            <button type="button" id="btnShowPage"
                                    style="background:linear-gradient(135deg,#36b9cc,#1f8ea3)!important;color:#fff;border:none;border-radius:25px;font-weight:700;padding:6px 16px;">
                                <i class="fa fa-list mr-1"></i> Show 5 / Page
                            </button>
                            <button type="button" id="btnShowAll"
                                    style="background:linear-gradient(135deg,#28a745,#20c997)!important;color:#fff;border:none;border-radius:25px;font-weight:700;padding:6px 16px;">
                                <i class="fa fa-th-list mr-1"></i> Show All
                            </button>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <button class="btn btn-sm" onclick="goToPage('prev')"
                                    style="background:#fff;color:#4e73df;border:none;border-radius:10px;font-weight:600;padding:6px 14px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
                                ⬅ Prev
                            </button>
                            <span id="pageInfo" class="mx-1"></span>
                            <button class="btn btn-sm" onclick="goToPage('next')"
                                    style="background:#fff;color:#4e73df;border:none;border-radius:10px;font-weight:600;padding:6px 14px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
                                Next ➡
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== ADD ROLE MODAL ===== -->
<div class="modal fade" id="addRole" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-plus-circle mr-2"></i>Add New Role</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="addRoleForm">
                    <div class="form-group">
                        <label>Role Name <span class="mandatoryfield">*</span></label>
                        <input type="text" class="form-control" id="txtRoleName"
                               placeholder="Enter role name (letters only)" />
                        <span class="validationMessage" id="msgAddRoleValidation"></span>
                    </div>
                    <div class="form-group form-group-inline mb-0">
                        <label>Status:</label>
                        <div class="custom-control custom-switch">
                            <input type="checkbox" class="custom-control-input" id="chkActiveStatus" checked>
                            <label class="custom-control-label" for="chkActiveStatus">Active</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning-modern btnRoleReset">
                  Reset
                </button>
                <button type="button" class="btn btn-primary-modern" id="btnRoleSave">
                    Save Role
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ===== EDIT ROLE MODAL ===== -->
<div class="modal fade" id="editRole" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-edit mr-2"></i>Edit Role</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="editRoleForm">
                    <input type="hidden" id="hdnRoleId" />
                    <div class="form-group">
                        <label>Role Name <span class="mandatoryfield">*</span></label>
                        <input type="text" class="form-control" id="txtEditRoleNameInput"
                               placeholder="Enter role name" />
                        <span class="validationMessage" id="msgEditRoleValidation"></span>
                    </div>
                    <div class="form-group form-group-inline mb-0">
                        <label>Status:</label>
                        <div class="custom-control custom-switch">
                            <input type="checkbox" class="custom-control-input" id="chkActiveStatusEdit">
                            <label class="custom-control-label" for="chkActiveStatusEdit">Active</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning-modern btnRoleReset">Reset</button>
                <button type="button" class="btn btn-primary-modern" id="btnEditRoleSave">
       Update Role
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ===== VIEW ROLE MODAL ===== -->
<div class="modal fade" id="viewRole" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-eye mr-2"></i>Role Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">

                <div class="view-row">
                    <div class="view-label">Role Name:</div>
                    <div class="view-value" id="lblvwRoleName">Loading...</div>
                </div>

                <div class="view-row">
                    <div class="view-label">Role ID:</div>
                    <div class="view-value" id="lblvwRoleId">-</div>
                </div>

                <div class="view-row mb-0">
                    <div class="view-label">Status:</div>
                    <div class="view-value" id="lblvwRoleStatus">-</div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- ===== DELETE ROLE MODAL ===== -->
<div class="modal fade" id="deleteRole" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa fa-trash mr-2"></i> Delete Role
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="hdnDeRoleId" />
                <div style="width:70px;height:70px;background:rgba(231,76,59,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px auto;">
                    <i class="fa fa-trash" style="font-size:32px;color:#e74a3b;"></i>
                </div>
                <p style="font-size:18px;font-weight:700;color:#2c3e50;margin-bottom:6px;">Are you sure?</p>
                <p style="font-size:14px;color:#7f8c8d;margin-bottom:0;">
                    You are about to delete role <strong id="lblDelRoleName">this role</strong>.<br />
                    This action <strong>cannot be undone</strong>.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-lg px-4" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger-modern btn-lg px-4" id="btnConfirmRoleDelete">
        Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script>
                function noAccess(type) {
            Swal.fire({
                icon: 'error',
                title: 'Access Denied',
                text: 'You do not have ' + type + ' permission for Role module.',
                confirmButtonColor: '#dc2626'
            });
        }
        $(document).ready(function () {

            // ===== BIND EVENT HANDLERS =====
            function bindEventHandlers() {
                $(document).off('click', '.editByRoleId').on('click', '.editByRoleId', function () {
                    loadRoleData($(this).data('edroleid'), 'edit');
                });
                $(document).off('click', '.viewByRoleId').on('click', '.viewByRoleId', function () {
                    loadRoleData($(this).data('vwroleid'), 'view');
                });
                $(document).off('click', '.deleteRoles').on('click', '.deleteRoles', function () {
                    loadRoleData($(this).data('dlroleid'), 'delete');
                });
            }

            // ===== LOAD ROLE DATA =====
            function loadRoleData(roleId, action) {
                $.get('@Url.Action("GetRole", "Role")', { role_ID: JSON.stringify(roleId) })
                    .done(function (role) {
                        var roleIdResp = role.role_ID || role.Role_ID;
                        var roleName   = role.role_Name || role.Role_Name;
                        var isActive   = (role.isActive || role.IsActive) == 1;

                        if (action === 'edit') {
                            $('#hdnRoleId').val(roleIdResp);
                            $('#txtEditRoleNameInput').val(roleName);
                            $('#chkActiveStatusEdit').prop('checked', isActive);
                            $('#editRole').modal('show');
                        } else if (action === 'view') {
                            $('#lblvwRoleName').text(roleName || 'N/A');
                            $('#lblvwRoleId').text(roleIdResp || 'N/A');
                            $('#lblvwRoleStatus').html(
                                '<span class="status-badge ' + (isActive ? 'badge-success-custom' : 'badge-danger-custom') + '">' +
                                (isActive ? '<i class="fas fa-check-circle mr-1"></i>Active' : '<i class="fas fa-times-circle mr-1"></i>Inactive') +
                                '</span>'
                            );
                            $('#viewRole').modal('show');
                        } else if (action === 'delete') {
                            $('#lblDelRoleName').text(roleName);
                            $('#hdnDeRoleId').val(roleIdResp);
                            $('#deleteRole').modal('show');
                        }
                    })
                    .fail(function () {
                        Swal.fire('Error!', 'Error loading role data', 'error');
                    });
            }

            // ===== VALIDATE ROLE NAME =====
            function validateRoleName(name, inputId, msgId) {
                var regex = /^[a-zA-Z\s]+$/;
                if (name === '') {
                    $(inputId).addClass('is-invalid');
                    $(msgId).html('Please enter Role Name');
                    return false;
                }
                if (!regex.test(name)) {
                    $(inputId).addClass('is-invalid');
                    $(msgId).html('Letters only');
                    return false;
                }
                $(inputId).removeClass('is-invalid');
                $(msgId).html('');
                return true;
            }

            // ===== ADD ROLE SAVE =====
            $('#btnRoleSave').on('click', function (e) {
                e.preventDefault();
                var roleName = $('#txtRoleName').val().trim();
                if (!validateRoleName(roleName, '#txtRoleName', '#msgAddRoleValidation')) return;

                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("Save", "Role")',
                    contentType: 'application/json',
                    data: JSON.stringify({ Role_Name: roleName, IsDeleted: 0, IsActive: $('#chkActiveStatus').is(':checked') ? 1 : 0 }),
                    dataType: 'text',
                    success: function (r) {
                        r = r.toString().trim().replace(/^"/, '').replace(/"$/, '').toLowerCase();
                        if (r.includes('success')) {
                            Swal.fire({ icon: 'success', title: 'Success!', text: 'Role added successfully!', confirmButtonColor: '#4e73df' })
                                .then(function () { location.reload(); });
                        } else if (r.includes('duplicate')) {
                            Swal.fire('Error!', 'Role already exists.', 'error');
                        } else {
                            Swal.fire('Error!', r, 'error');
                        }
                    },
                    error: function () { Swal.fire('Error!', 'Error saving role', 'error'); }
                });
            });

            // ===== EDIT ROLE SAVE =====
            $('#btnEditRoleSave').on('click', function (e) {
                e.preventDefault();
                var roleName = $('#txtEditRoleNameInput').val().trim();
                if (!validateRoleName(roleName, '#txtEditRoleNameInput', '#msgEditRoleValidation')) return;

                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("Edit", "Role")',
                    contentType: 'application/json',
                    data: JSON.stringify({ Role_ID: parseInt($('#hdnRoleId').val()), Role_Name: roleName, IsDeleted: 0, IsActive: $('#chkActiveStatusEdit').is(':checked') ? 1 : 0 }),
                    dataType: 'text',
                    success: function (r) {
                        r = r.toString().trim().replace(/^"/, '').replace(/"$/, '').toLowerCase();
                        if (r.includes('success')) {
                            Swal.fire({ icon: 'success', title: 'Updated!', text: 'Role updated successfully!', confirmButtonColor: '#4e73df' })
                                .then(function () { location.reload(); });
                        } else {
                            Swal.fire('Error!', r, 'error');
                        }
                    },
                    error: function () { Swal.fire('Error!', 'Error updating role', 'error'); }
                });
            });

            // ===== DELETE ROLE =====
            $('#btnConfirmRoleDelete').on('click', function () {
                var roleId = $('#hdnDeRoleId').val();
                if (!roleId) { Swal.fire('Error!', 'Role ID not found!', 'error'); return; }

                $.get('@Url.Action("DeleteRole", "Role")', { role_ID: JSON.stringify(roleId) })
                    .done(function (r) {
                        r = r.toString().trim().replace(/"/g, '');
                        if (r === '1' || r.toLowerCase() === 'success') {
                            Swal.fire({ icon: 'success', title: 'Deleted!', text: 'Role deleted successfully!', confirmButtonColor: '#4e73df' })
                                .then(function () { location.reload(); });
                        } else {
                            Swal.fire('Error!', 'Delete failed: ' + r, 'error');
                        }
                    })
                    .fail(function () { Swal.fire('Error!', 'Error deleting role', 'error'); });
            });

            // ===== INPUT VALIDATION ON TYPE =====
            $('#txtRoleName, #txtEditRoleNameInput').on('input', function () {
                var val = $(this).val().trim();
                var msgId = $(this).attr('id') === 'txtRoleName' ? '#msgAddRoleValidation' : '#msgEditRoleValidation';
                if (val === '' || /^[a-zA-Z\s]+$/.test(val)) {
                    $(this).removeClass('is-invalid');
                    $(msgId).html('');
                } else {
                    $(this).addClass('is-invalid');
                    $(msgId).html('Only letters and spaces allowed');
                }
            });

            $('#txtRoleName, #txtEditRoleNameInput').keypress(function (e) {
                if (!/^[a-zA-Z\s]+$/.test(String.fromCharCode(e.which)) && e.which !== 8 && e.which !== 0) {
                    e.preventDefault();
                }
            });

            // ===== RESET =====
            $('.btnRoleReset').on('click', function () {
                var modal = $(this).closest('.modal');
                modal.find('input[type="text"]').val('').removeClass('is-invalid');
                modal.find('.validationMessage').html('');
                modal.find('#chkActiveStatus').prop('checked', true);
                modal.find('#chkActiveStatusEdit').prop('checked', false);
            });

            // ===== CLEAR ON MODAL CLOSE =====
            $('#addRole, #editRole, #viewRole, #deleteRole').on('hidden.bs.modal', function () {
                $(this).find('input[type="text"], input[type="password"]').val('');
                $(this).find('.validationMessage').html('');
                $(this).find('.form-control').removeClass('is-invalid');
                $('#lblvwRoleName').text('Loading...');
                $('#chkActiveStatus').prop('checked', true);
                $('#chkActiveStatusEdit').prop('checked', false);
                $('#hdnDeRoleId, #hdnRoleId').val('');
                $('#lblDelRoleName').text('this role');
            });

            // ===== PAGINATION =====
            var rowsPerPage = 5;
            var currentPage = 1;

            function getRows() {
                return $('#roleTable tbody tr').filter(function () {
                    return $(this).find('td').length > 1;
                });
            }

            function showPage(pageNum) {
                var rows = getRows();
                var totalPages = Math.ceil(rows.length / rowsPerPage);
                if (pageNum < 1) pageNum = 1;
                if (pageNum > totalPages) pageNum = totalPages;
                rows.hide();
                rows.slice((pageNum - 1) * rowsPerPage, pageNum * rowsPerPage).show();
                currentPage = pageNum;
                $('#pageInfo').text('Page ' + currentPage + ' of ' + totalPages);
            }

            window.goToPage = function (direction) {
                var totalPages = Math.ceil(getRows().length / rowsPerPage);
                if (direction === 'prev' && currentPage > 1) currentPage--;
                else if (direction === 'next' && currentPage < totalPages) currentPage++;
                showPage(currentPage);
            };

            $('#btnShowPage').click(function () {
                rowsPerPage = 5;
                showPage(1);
            });

            $('#btnShowAll').click(function () {
                getRows().show();
                $('#pageInfo').text('Showing All (' + getRows().length + ')');
            });

            // Init
            bindEventHandlers();
            showPage(1);
        });
    </script>
}