
@model IEnumerable<A2R_Project.Models.Role>
@{
    ViewBag.Title = "Roles List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ================= GLOBAL ================= */
    body {
        background: #f4f7fb;
        font-family: 'Segoe UI', sans-serif;
    }

    /* ================= CARD ================= */
    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    /* ================= TITLE ================= */
    .card-title {
        font-size: 22px;
        font-weight: 700;
        color: #111;
    }

    /* ================= TABLE ================= */
    .table {
        border-radius: 12px;
        overflow: hidden;
    }

        .table thead {
            background: linear-gradient(45deg, #2563eb, #1e40af);
            color: #fff;
        }

            .table thead th {
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border: none !important;
            }

        .table tbody tr {
            transition: all 0.3s ease;
            background: #fff;
        }

            .table tbody tr:hover {
                background: #eef4ff !important;
                transform: scale(1.01);
                box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            }

        .table td {
            vertical-align: middle !important;
            font-weight: 600;
            color: #111;
        }

            /* FIX ACTION COLUMN */
            .table td:last-child {
                white-space: nowrap;
                text-align: center;
            }

    /* ================= BUTTONS ================= */
    .btn-custom {
        transition: all 0.3s ease;
        border-radius: 30px !important;
    }

        .btn-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(0,0,0,0.15);
        }

    /* Add button */
    .btn-gradient-primary {
        background: linear-gradient(45deg, #2563eb, #60a5fa);
        border: none;
    }

    /* View */
    .btn-gradient-dark {
        background: linear-gradient(45deg, #111827, #374151);
        border: none;
    }

    /* Edit */
    .btn-gradient-primary.btn-role-list:hover {
        filter: brightness(1.1);
    }

    /* Delete */
    .btn-gradient-warning {
        background: linear-gradient(45deg, #f59e0b, #f97316);
    }

    /* ================= BADGES ================= */
    .badge-success {
        background: #16a34a;
        padding: 6px 10px;
        border-radius: 20px;
    }

    .badge-danger {
        background: #dc2626;
        padding: 6px 10px;
        border-radius: 20px;
    }

    /* ================= MODAL ================= */
    .modal-content {
        border-radius: 18px;
        border: none;
        box-shadow: 0 15px 40px rgba(0,0,0,0.2);
        animation: fadeInUp 0.3s ease;
    }

    .modal-header {
        background: linear-gradient(45deg, #2563eb, #1e40af);
        color: #fff;
        border-radius: 18px 18px 0 0;
    }

    .modal-title {
        font-weight: 700;
    }

    /* Center modal */
    .modal-dialog {
        margin-top: 80px;
    }

    /* Inputs */
    .form-control {
        border-radius: 10px;
        border: 1px solid #ddd;
        transition: 0.3s;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 10px rgba(37,99,235,0.2);
        }

    /* ================= CLOSE BUTTON ================= */
    .close {
        color: #fff;
        opacity: 1;
    }

    /* ================= ANIMATION ================= */
    @@keyframes fadeInUp {
        from

    {
        transform: translateY(20px);
        opacity: 0;
    }

    to {
        transform: translateY(0);
        opacity: 1;
    }

    }
    /* ================= GLOBAL TABLE CENTER FIX ================= */
    .table th,
    .table td {
        text-align: center !important;
        vertical-align: middle !important;
    }

    /* If you ONLY want Role Name centered, uncomment below */
    /*
    .table tbody td:first-child,
    .table thead th:first-child {
        text-align: center !important;
    }
    */

   


    /* header style */
    .modal-header {
        background: linear-gradient(45deg, #2563eb, #1e40af);
        color: #fff;
        border-radius: 18px 18px 0 0;
    }

    /* ================= TABLE HOVER ENHANCEMENT ================= */
    .table tbody tr:hover {
        background: #eaf2ff !important;
        transform: scale(1.01);
        transition: all 0.2s ease-in-out;
    }

    /* ================= TEXT IMPROVEMENT ================= */
    .table td {
        font-weight: 600;
        color: #111;
        font-size: 15px;
    }

        /* ================= BUTTON ALIGN FIX ================= */
        .table td:last-child {
            display: flex;
            justify-content: center;
            gap: 6px;
        }


        
/* ================= EDIT MODAL SAME AS VIEW POSITION ================= */
#editRole.modal {
    padding-top: 0 !important;
}

/* keep EXACT center like view modal */
.edit-role-modal {
    margin: 1.75rem auto !important;   /* SAME AS BOOTSTRAP DEFAULT VIEW */
    max-width: 800px;                  /* BIG SIZE */
}

/* ================= MODAL CONTENT STYLE ================= */
#editRole .modal-content {
    border-radius: 16px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.25);
}

/* ================= HEADER STYLE ================= */
#editRole .modal-header {
    padding: 12px 20px;
}

/* ================= BODY SPACING ================= */
#editRole .modal-body {
    padding: 25px;
}

/* ================= FORM ALIGNMENT ================= */
#editRole .form-group.row {
    align-items: center;
}

#editRole label {
    font-weight: 600;
    color: #111;
    font-size: 15px;
}

#editRole .form-control {
    height: 42px;
    border-radius: 10px;
    font-weight: 600;
}

    #clientPagination a.active {
        background: #2563eb;
        color: #fff !important;
        border-color: #2563eb;
    }

    #clientPagination {
        display: flex;
        align-items: center;
    }

    .modal-content {
        border-radius: 18px;
        border: none;
        box-shadow: 0 15px 40px rgba(0,0,0,0.25);
    }

    .modal-header {
        background: #0d6efd;
        color: #fff;
        font-weight: 700;
    }

    .modal-body {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            font-weight: 600;
            color: #111;
            display: block;
            margin-bottom: 6px;
        }

    .form-control {
        border-radius: 10px;
        height: 42px;
    }

    .status-box {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .status-box input {
            width: 18px;
            height: 18px;
        }

    .modal-footer {
        border-top: none;
        padding: 15px 20px;
    }
    /* ================= MODAL TOP CENTER FIX ================= */
    .modal {
        padding-top: 40px !important;
    }

    .modal-dialog.modal-top-center {
        margin: 0 auto;
        top: 40px;
        transform: none !important;
        transition: all 0.3s ease-in-out;
    }

    /* smooth animation */
    .modal.fade .modal-dialog {
        transform: translateY(-20px);
        transition: all 0.25s ease;
    }

    .modal.show .modal-dialog {
        transform: translateY(0);
    }

    #viewRole .modal-header {
        background:white ;
        color:blue;
        font-weight: 700;
    }

    #viewRole .modal-content {
        border-radius: 18px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.2);
    }

    #deleteRole .modal-header {
        background: blue;
        color: black;
        font-weight: 700;
    }

    #deleteRole .modal-content {
        border-radius: 18px;
        box-shadow: 0 20px 50px rgba(239, 68, 68, 0.25);
        border: none;
    }

    /* make delete text stronger */
    #deleteRole .modal-body label {
        font-weight: 700;
        font-size: 16px;
        color: #111;
    }

</style>



<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Roles List</strong>
                <button type="button" class="btn btn-gradient-primary btn-rounded btn-fw" data-toggle="modal" data-target="#addRole">
                    <i class="fa fa-plus"></i> Add
                </button>
            </div>
            <table class="table table-bordered" id="roleTable">
                <thead>
                    <tr>
                        <th> Role name </th>
                        <th> Status </th>
                        <th> Action </th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="table-info">
                                <td class="table-primary">@item.Role_Name</td>
                                <td class="table-warning">
                                    @if (item.IsActive == 1)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <!-- Edit button -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-primary btn-rounded btn-role-list editByRoleId" 
                                            data-edRoleId='@item.Role_ID' title="Edit" data-toggle="modal" data-target="#editRole">
                                        <i class="mdi mdi-pencil"></i>
                                    </button>

                                    <!-- View button -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-dark btn-rounded btn-role-list viewByRoleId" 
                                            data-vwRoleId='@item.Role_ID' title="View" data-toggle="modal" data-target="#viewRole">
                                        <i class="mdi mdi-eye"></i>
                                    </button>

                                    <!-- Delete button -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-warning btn-rounded btn-role-list deleteRoles" 
                                            data-dlRoleId='@item.Role_ID' title="Delete" data-toggle="modal" data-target="#deleteRole">
                                        <i class="mdi mdi-delete"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center">No roles found</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="d-flex justify-content-between align-items-center mt-3">

                <!-- Show All Button -->
                <button id="btnShowAll" class="btn btn-dark btn-sm">
                    Show All
                </button>

                <!-- Static Pagination -->
                <div id="clientPagination">
                    <button class="btn btn-sm btn-primary page-btn active" data-page="1">1</button>
                    <button class="btn btn-sm btn-outline-primary page-btn" data-page="2">2</button>
                    <button class="btn btn-sm btn-outline-primary page-btn" data-page="3">3</button>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addRole" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md" role="document">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title">➕ ADD ROLE</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <div class="form-group">
                    <label>Role Name <span class="mandatoryfield">*</span></label>
                    <input type="text" class="form-control" id="txtRoleName" placeholder="Enter role name">
                    <span class="validationMessage" id="msgAddRoleValidation"></span>
                </div>

                <div class="form-group status-box">
                    <input type="checkbox" id="chkActiveStatus" checked>
                    <label for="chkActiveStatus">Active Status</label>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-rounded" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning btn-rounded btnRoleReset">Reset</button>
                <button type="button" class="btn btn-primary btn-rounded" id="btnRoleSave">Submit</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="editRole" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md" role="document">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title">✏️ EDIT ROLE</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <div class="form-group">
                    <label>Role Name <span class="mandatoryfield">*</span></label>
                    <input type="text" class="form-control" id="txtEditRoleNameInput" placeholder="Enter role name">
                    <span class="validationMessage" id="msgEditRoleValidation"></span>
                    <input type="hidden" id="hdnRoleId">
                </div>

                <div class="form-group status-box">
                    <input type="checkbox" id="chkActiveStatusEdit">
                    <label for="chkActiveStatusEdit">Active Status</label>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-rounded" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning btn-rounded btnRoleReset">Reset</button>
                <button type="button" class="btn btn-primary btn-rounded" id="btnEditRoleSave">Update</button>
            </div>

        </div>
    </div>
</div>

<!-- View Role Modal -->
<div class="modal fade" id="viewRole" tabindex="-1" role="dialog" aria-labelledby="viewRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewRoleModalLabel">View Role</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row" style="margin-top: 20px;">
                    <div class="col-md-10">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="row form-group">
                                    <div class="col col-md-4"><label class="form-control-label">Role Name :</label></div>
                                    <div class="col-12 col-md-8">
                                        <label class="form-control-label" id="lblvwRoleName"></label>
                                        <input type="hidden" id="hdnVwRoleId" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-gradient-warning btn-rounded btn-fw" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Role Modal -->
<div class="modal fade" id="deleteRole" tabindex="-1" role="dialog" aria-labelledby="deleteRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteRoleModalLabel" style="color:red">Confirm Delete Role</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-10">
                        <div class="row" style="margin-top: 20px;">
                            <div class="col-md-8">
                                <div class="row form-group">
                                    <div class="col col-md-4"><label class="form-control-label">Role Name :</label></div>
                                    <div class="col-12 col-md-8">
                                        <label class="form-control-label" id="lblDelRoleName"></label>
                                        <input type="hidden" id="hdnDeRoleId" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-gradient-warning btn-rounded btn-fw" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-gradient-danger btn-rounded btn-fw" id="btnConfirmRoleDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

<style>
    .mandatoryfield { color: red; }
    .validationMessage { color: red; font-size: 12px; }
    .rounded-checkbox { width: 20px; height: 20px; }
    .btn-custom { margin-right: 5px; }
    .table-info { background-color: #f8f9fa; }
</style>

@section Scripts {
    <!-- CRITICAL: jQuery & Bootstrap FIRST -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>

    <script>
        $(document).ready(function() {
            console.log("🚀 Role Management - FULLY LOADED ✅");

            // ================= GLOBAL STATE =================
            let tableRows = [];

            // ================= FIXED REALTIME TABLE RELOAD =================
            function refreshTable() {
                location.reload();
            }

            // ================= FIXED PAGINATION - ALWAYS SHOWS =================
            function setupPagination() {
                tableRows = $('#roleTable tbody tr:not(.no-data-row)');
                const rowsPerPage = 5;
                const totalPages = Math.ceil(tableRows.length / rowsPerPage);

                console.log(`📊 Total rows: ${tableRows.length}, Pages: ${totalPages}`);

                // Clear existing pagination
                $('#clientPagination').empty();

                // ALWAYS show pagination, even for few records
                if (tableRows.length === 0) {
                    $('#clientPagination').html('<span class="text-muted small">No records</span>');
                    return;
                }

                // Create pagination buttons (minimum 1 page)
                const maxVisiblePages = 5;
                let startPage = 1;
                let endPage = Math.min(totalPages, maxVisiblePages);

                if (totalPages > maxVisiblePages) {
                    startPage = Math.max(1, totalPages - maxVisiblePages + 1);
                    endPage = totalPages;
                }

                // Previous button
                if (totalPages > 1) {
                    $('#clientPagination').append(`
                        <button class="btn btn-sm btn-outline-secondary prev-btn" data-page="prev">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                    `);
                }

                // Page numbers
                for (let i = startPage; i <= endPage; i++) {
                    const isActive = i === 1 ? 'btn-primary active' : 'btn-outline-primary';
                    $('#clientPagination').append(`
                        <button class="btn btn-sm ${isActive} mx-1 page-btn" data-page="${i}">${i}</button>
                    `);
                }

                // Next button
                if (totalPages > 1) {
                    $('#clientPagination').append(`
                        <button class="btn btn-sm btn-outline-secondary next-btn" data-page="next">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    `);
                }

                // Show first page
                showPage(1);
            }

            function showPage(pageNum) {
                const rowsPerPage = 5;

                // Hide all rows first
                tableRows.hide();

                // Handle prev/next
                let currentPage = parseInt($('.page-btn.active').data('page')) || 1;

                if (pageNum === 'prev') {
                    currentPage = Math.max(1, currentPage - 1);
                } else if (pageNum === 'next') {
                    const totalPages = Math.ceil(tableRows.length / rowsPerPage);
                    currentPage = Math.min(totalPages, currentPage + 1);
                } else {
                    currentPage = pageNum;
                }

                // Calculate row range
                const startIdx = (currentPage - 1) * rowsPerPage;
                const endIdx = startIdx + rowsPerPage;

                // Show rows for current page
                tableRows.slice(startIdx, endIdx).show();

                // Update active button
                $('.page-btn').removeClass('btn-primary active').addClass('btn-outline-primary');
                $(`.page-btn[data-page="${currentPage}"]`).removeClass('btn-outline-primary').addClass('btn-primary active');

                console.log(`📄 Page ${currentPage}: rows ${startIdx + 1}-${Math.min(endIdx, tableRows.length)} of ${tableRows.length}`);
            }

            // ================= PAGINATION EVENTS =================
            $(document).on('click', '.page-btn', function(e) {
                e.preventDefault();
                const page = $(this).data('page');
                showPage(page);
            });

            $(document).on('click', '.prev-btn, .next-btn', function(e) {
                e.preventDefault();
                const direction = $(this).data('page');
                showPage(direction);
            });

            // ================= PERFECT "SHOW ALL" BUTTON =================
            $('#btnShowAll').click(function() {
                console.log('👀 Show All clicked');

                // Show ALL rows
                tableRows.show();

                // Show "Showing All" status
                $('#clientPagination').html(`
                    <span class="badge badge-success px-3 py-2">
                        <i class="fa fa-check"></i> Showing All ${tableRows.length} Records
                    </span>
                `);

                console.log(`✅ Showing all ${tableRows.length} rows`);
            });

            // ================= FORM RESET =================
            function resetForms() {
                $('#txtRoleName').val('').removeClass('is-invalid');
                $('#txtEditRoleNameInput').val('').removeClass('is-invalid');
                $('#chkActiveStatus, #chkActiveStatusEdit').prop('checked', true);
                $('.validationMessage').text('').hide();
                $('#hdnRoleId').val('');
            }

            // ================= VALIDATION =================
            function isValidRoleName(name, msgElement) {
                const trimmed = name.trim();
                const isEmpty = !trimmed;
                const hasInvalidChars = !/^[a-zA-Z\s]+$/.test(trimmed);

                if (isEmpty) {
                    msgElement.text('Role name is required').show();
                    return false;
                }
                if (hasInvalidChars) {
                    msgElement.text('Only letters and spaces allowed').show();
                    return false;
                }

                msgElement.hide();
                return true;
            }

            // ================= SUCCESS TOAST =================
            function showSuccess(message) {
                const toast = $(`
                    <div class="alert alert-success alert-dismissible fade show position-fixed"
                         style="top: 20px; right: 20px; z-index: 9999; min-width: 300px; border-radius: 10px;"
                         role="alert">
                        <i class="fa fa-check-circle mr-2"></i> ${message}
                        <button type="button" class="close" data-dismiss="alert">
                            <span>&times;</span>
                        </button>
                    </div>
                `);

                $('body').append(toast);
                setTimeout(() => toast.alert('close'), 4000);
            }

            // ================= ADD ROLE =================
            $('#btnRoleSave').click(function(e) {
                e.preventDefault();

                const roleName = $('#txtRoleName').val();
                const msgDiv = $('#msgAddRoleValidation');

                if (!isValidRoleName(roleName, msgDiv)) {
                    $('#txtRoleName').addClass('is-invalid');
                    return;
                }

                $('#txtRoleName').removeClass('is-invalid');

                const roleData = {
                    Role_Name: roleName.trim(),
                    IsActive: $('#chkActiveStatus').is(':checked') ? 1 : 0,
                    IsDeleted: 0
                };

                $.ajax({
                    method: 'POST',
                    url: '@Url.Action("Save", "Role")',
                    contentType: 'application/json',
                    data: JSON.stringify(roleData),
                    dataType: 'text',
                    success: function(rawResponse) {
                        let response = rawResponse.toString().trim().replace(/^"/, '').replace(/"$/, '').replace(/\\"/g, '"').toLowerCase();

                        if (response.includes('success')) {
                            $('#addRole').modal('hide');
                            resetForms();
                            showSuccess('Role added successfully!');
                            setTimeout(refreshTable, 1500);
                        } else {
                            alert('❌ Add failed: ' + response);
                        }
                    },
                    error: function(xhr) {
                        alert('❌ Add failed - Network error');
                    }
                });
            });

            // ================= EDIT ROLE =================
            $('#btnEditRoleSave').click(function(e) {
                e.preventDefault();

                const roleName = $('#txtEditRoleNameInput').val();
                const msgDiv = $('#msgEditRoleValidation');

                if (!isValidRoleName(roleName, msgDiv)) {
                    $('#txtEditRoleNameInput').addClass('is-invalid');
                    return;
                }

                $('#txtEditRoleNameInput').removeClass('is-invalid');

                const roleData = {
                    Role_ID: parseInt($('#hdnRoleId').val()),
                    Role_Name: roleName.trim(),
                    IsActive: $('#chkActiveStatusEdit').is(':checked') ? 1 : 0,
                    IsDeleted: 0
                };

                $.ajax({
                    method: 'POST',
                    url: '@Url.Action("Edit", "Role")',
                    contentType: 'application/json',
                    data: JSON.stringify(roleData),
                    dataType: 'text',
                    success: function(rawResponse) {
                        let response = rawResponse.toString().trim().replace(/^"/, '').replace(/"$/, '').replace(/\\"/g, '"');

                        if (response.toLowerCase().includes('success')) {
                            $('#editRole').modal('hide');
                            resetForms();
                            showSuccess('Role updated successfully!');
                            setTimeout(refreshTable, 1500);
                        } else {
                            alert('❌ Update failed: ' + response);
                        }
                    },
                    error: function(xhr) {
                        alert('❌ Update failed - Network error');
                    }
                });
            });

            // ================= BUTTON BINDING =================
            function rebindButtons() {
                $(document).off('click', '.editByRoleId, .viewByRoleId, .deleteRoles');

                $(document).on('click', '.editByRoleId', function() {
                    const roleId = $(this).data('edroleid');
                    $.get('@Url.Action("GetRole", "Role")', { role_ID: JSON.stringify(roleId) })
                    .done(function(role) {
                        $('#hdnRoleId').val(role.role_ID);
                        $('#txtEditRoleNameInput').val(role.role_Name);
                        $('#chkActiveStatusEdit').prop('checked', role.isActive == 1);
                        $('#editRole').modal('show');
                    });
                });

                $(document).on('click', '.viewByRoleId', function() {
                    const roleId = $(this).data('vwroleid');
                    $.get('@Url.Action("GetRole", "Role")', { role_ID: JSON.stringify(roleId) })
                    .done(function(role) {
                        $('#lblvwRoleName').text(role.role_Name);
                        $('#viewRole').modal('show');
                    });
                });

                $(document).on('click', '.deleteRoles', function() {
                    const roleId = $(this).data('dlroleid');
                    $.get('@Url.Action("GetRole", "Role")', { role_ID: JSON.stringify(roleId) })
                    .done(function(role) {
                        $('#lblDelRoleName').text(role.role_Name);
                        $('#hdnDeRoleId').val(role.role_ID);
                        $('#deleteRole').modal('show');
                    });
                });
            }

            // ================= DELETE =================
            $('#btnConfirmRoleDelete').click(function() {
                const roleId = $('#hdnDeRoleId').val();
                $.get('@Url.Action("DeleteRole", "Role")', { role_ID: JSON.stringify(roleId) })
                .done(function(response) {
                    response = response.toString().trim().replace(/"/g, '');
                    if (response === '1') {
                        $('#deleteRole').modal('hide');
                        showSuccess('Role deleted successfully!');
                        setTimeout(refreshTable, 1500);
                    } else {
                        alert('❌ Delete failed');
                    }
                });
            });

            // ================= MODAL & INPUT EVENTS =================
            $('#addRole, #editRole, #viewRole, #deleteRole').on('hidden.bs.modal', resetForms);

            $('#txtRoleName, #txtEditRoleNameInput').on('input', function() {
                $(this).val($(this).val().replace(/[^a-zA-Z\s]/g, ''));
            });

            $('.btnRoleReset').click(function() {
                resetForms();
                $(this).closest('.modal').find('.form-control').removeClass('is-invalid');
            });

            // ================= INITIALIZE =================
            setTimeout(function() {
                setupPagination();
                rebindButtons();
            }, 100);

            $(document).ajaxComplete(function() {
                setTimeout(setupPagination, 500);
            });

            console.log("✅ Perfect pagination ready!");
        });
    </script>

    <style>
        /* Pagination always visible */
        #clientPagination {
            gap: 3px;
        }

        .page-btn, .prev-btn, .next-btn {
            min-width: 38px;
            font-weight: 600;
            border-radius: 6px;
            transition: all 0.3s ease;
        }

            .page-btn.active {
                background: linear-gradient(45deg, #2563eb, #1e40af) !important;
                color: white !important;
                box-shadow: 0 3px 10px rgba(37,99,235,0.4);
            }

            .page-btn:hover:not(.active) {
                transform: translateY(-1px);
            }

        #btnShowAll:hover {
            transform: translateY(-2px);
        }
    </style>
}