@model A2R_Project.Models.Logins
@{
    ViewBag.Title = "Users List";
    // Remove layout if it's causing issues
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <style>
        .btn-gradient-primary {
            background: linear-gradient(45deg, #007bff, #0056b3);
            border: none;
            color: white;
        }

            .btn-gradient-primary:hover {
                background: linear-gradient(45deg, #0056b3, #004085);
                color: white;
            }

        .btn-gradient-warning {
            background: linear-gradient(45deg, #ffc107, #e0a800);
            border: none;
            color: #212529;
        }

        .btn-gradient-dark {
            background: linear-gradient(45deg, #6c757d, #545b62);
            border: none;
            color: white;
        }

        .view-box {
            padding: 8px;
            background: #f8f9fa;
            border-radius: 4px;
            min-height: 40px;
            display: flex;
            align-items: center;
        }
        /* ================= ACTION BUTTONS MODERN ================= */
        .btn-group-sm .btn {
            border-radius: 10px !important;
            padding: 6px 10px;
            margin: 0 3px;
            transition: all 0.25s ease;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        }

        /* EDIT BUTTON */
        .btn-gradient-primary {
            background: linear-gradient(135deg, #4facfe, #00c6ff);
            border: none;
            color: #fff;
        }

            .btn-gradient-primary:hover {
                transform: translateY(-2px) scale(1.05);
                box-shadow: 0 8px 18px rgba(0, 123, 255, 0.3);
            }

        /* VIEW BUTTON */
        .btn-gradient-dark {
            background: linear-gradient(135deg, #434343, #000000);
            border: none;
            color: #fff;
        }

            .btn-gradient-dark:hover {
                transform: translateY(-2px) scale(1.05);
                box-shadow: 0 8px 18px rgba(0, 0, 0, 0.3);
            }

        /* DELETE BUTTON */
        .btn-gradient-warning {
            background: linear-gradient(135deg, #ff758c, #ff7eb3);
            border: none;
            color: #fff;
        }

            .btn-gradient-warning:hover {
                transform: translateY(-2px) scale(1.05);
                box-shadow: 0 8px 18px rgba(255, 99, 132, 0.3);
            }

        /* ICON STYLE */
        .btn i {
            font-size: 14px;
        }

        /* CENTER ALIGN ACTION COLUMN */
        #userTable td:last-child {
            text-align: center;
            vertical-align: middle;
        }

        /* OPTIONAL: TABLE ROW HOVER EFFECT */
        #userTable tbody tr:hover {
            background: #f4f8ff;
            transition: 0.3s;
        }

        #pageInfo {
            color: #333;
            font-size: 14px;
        }

        .btn-light {
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-light:hover {
                background: #007bff;
                color: white;
            }
        /* ================= GLOBAL RESPONSIVE ================= */
        body {
            overflow-x: hidden;
        }

        /* Container spacing */
        .container-fluid {
            padding-left: 10px;
            padding-right: 10px;
        }

        /* ================= TABLE RESPONSIVE ================= */
        .table-responsive {
            overflow-x: auto;
        }

        #userTable {
            min-width: 600px;
        }

        /* Make table text smaller on mobile */
        @@media (max-width: 768px) {
            #userTable th, #userTable td {
                font-size: 13px;
                padding: 8px;
            }
        }

        /* ================= BUTTON GROUP ================= */
        .btn-group-sm .btn {
            margin: 2px;
            padding: 5px 8px;
        }

        /* Stack buttons on small screen */
        @@media (max-width: 576px) {
            .btn-group {
                display: flex;
                flex-direction: column;
                width: 100%;
            }

                .btn-group .btn {
                    width: 100%;
                }
        }

        /* ================= HEADER SECTION ================= */
        @@media (max-width: 576px) {
            .d-flex.justify-content-between {
                flex-direction: column;
                align-items: stretch !important;
            }

                .d-flex.justify-content-between .btn {
                    margin-top: 10px;
                    width: 100%;
                }
        }

        /* ================= MODAL RESPONSIVE ================= */
        .modal-dialog {
            max-width: 500px;
        }

        @@media (max-width: 576px) {
            .modal-dialog {
                max-width: 95%;
                margin: 10px auto;
            }

            .modal-content {
                border-radius: 12px;
            }
        }

        /* ================= FORM INPUT ================= */
        .form-control {
            font-size: 14px;
        }

        @@media (max-width: 576px) {
            .form-control {
                font-size: 13px;
                padding: 8px;
            }
        }

        /* ================= VIEW BOX ================= */
        .view-box {
            font-size: 14px;
        }

        @@media (max-width: 576px) {
            .view-box {
                font-size: 13px;
            }
        }
    </style>


</head>
<body>
    <div class="container-fluid mt-4">
        <div class="col-lg-12 stretch-card">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <strong class="card-title h4">👥 Users List (@Model.adminLogin.Count users)</strong>
                        <button class="btn btn-gradient-primary" data-toggle="modal" data-target="#addAdminLogin">
                            <i class="fa fa-plus"></i> Add User
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover" id="userTable">
                            <thead class="thead-dark">
                                <tr>
                                    <th>User Name</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model?.adminLogin != null && Model.adminLogin.Any())
                                {
                                    @foreach (var item in Model.adminLogin)
                                    {
                                        <tr>
                                            <td><strong>@item.UserName</strong></td>
                                            <td>@item.Role_Name</td>
                                            <td>
                                                @if (item.IsActive == 1)
                                                {
                                                    <span class="badge badge-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-gradient-primary editByLoginId"
                                                            data-edloginid="@item.LoginID"
                                                            data-toggle="modal" data-target="#editAdminLogin"
                                                            title="Edit">
                                                        <i class="fa fa-edit"></i>
                                                    </button>
                                                    <button class="btn btn-gradient-dark viewByLoginId"
                                                            data-vwloginid="@item.LoginID"
                                                            data-toggle="modal" data-target="#viewAdminLogin"
                                                            title="View">
                                                        <i class="fa fa-eye"></i>
                                                    </button>
                                                    <button class="btn btn-gradient-warning deleteLogins"
                                                            data-dlloginid="@item.LoginID"
                                                            data-toggle="modal" data-target="#deleteAdminLogin"
                                                            title="Delete">
                                                        <i class="fa fa-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-4">No users found</td></tr>
                                }
                            </tbody>
                        </table>
                        <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap">

                            <!-- LEFT SIDE BUTTONS -->
                            <div>
                                <button class="btn btn-sm btn-info mr-2" id="btnShowPage">
                                    Show 10 / Page
                                </button>
                                <button class="btn btn-sm btn-secondary" id="btnShowAll">
                                    Show All
                                </button>
                            </div>

                            <!-- RIGHT SIDE PAGINATION -->
                            <div>
                                <button class="btn btn-sm btn-light mr-1" onclick="goToPage('prev')">
                                    ⬅ Prev
                                </button>

                                <span id="pageInfo" class="mx-2 font-weight-bold"></span>

                                <button class="btn btn-sm btn-light ml-1" onclick="goToPage('next')">
                                    Next ➡
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ADD MODAL -->
        <div class="modal fade" id="addAdminLogin" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title"><i class="fa fa-plus"></i> Add New User</h5>
                        <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                    </div>
                    <div class="modal-body">
                        <form id="addForm">
                            <div class="form-group">
                                <label>User Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtAdminLoginName" required />
                                <small class="text-danger" id="msgAddName"></small>
                            </div>
                            <div class="form-group">
                                <label>Role <span class="text-danger">*</span></label>
                                <select id="ddlRoleId" class="form-control" required>
                                    <option value="">Select Role</option>
                                    @if (ViewBag.Roles != null)
                                    {
                                        foreach (var role in ViewBag.Roles as List<A2R_Project.Models.Role>)
                                        {
                                            <option value="@role.Role_ID">@role.Role_Name</option>
                                        }
                                    }
                                </select>
                                <small class="text-danger" id="msgAddRole"></small>
                            </div>
                            <div class="form-group">
                                <label>Password <span class="text-danger">*</span></label>
                                <input type="password" class="form-control" id="txtAdminLoginPassword" required minlength="6" />
                                <small class="text-danger" id="msgAddPass"></small>
                            </div>
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="chkActiveStatus" checked>
                                <label class="form-check-label">Active Status</label>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="btnAdminLoginSave">
                            <i class="fa fa-save"></i> Save User
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- EDIT MODAL -->
        <div class="modal fade" id="editAdminLogin" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title"><i class="fa fa-edit"></i> Edit User</h5>
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="hdnAdminLoginId" />
                        <div class="form-group">
                            <label>User Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtEditAdminLoginName" required />
                        </div>
                        <div class="form-group">
                            <label>Role <span class="text-danger">*</span></label>
                            <select id="ddlEditRoleId" class="form-control" required>
                                <option value="">Select Role</option>
                                @if (ViewBag.Roles != null)
                                {
                                    foreach (var role in ViewBag.Roles as List<A2R_Project.Models.Role>)
                                    {
                                        <option value="@role.Role_ID">@role.Role_Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>New Password (leave blank to keep current)</label>
                            <input type="password" class="form-control" id="txtEditPassword" placeholder="Leave blank to keep current" />
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="chkActiveStatusEdit" checked>
                            <label class="form-check-label">Active Status</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-warning" id="btnEditAdminLoginSave">
                            <i class="fa fa-save"></i> Update User
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <!-- VIEW MODAL - FIXED -->
        <div class="modal fade" id="viewAdminLogin" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-info text-white">
                        <h5 class="modal-title"><i class="fa fa-eye"></i> User Details</h5>
                        <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="hdnVwAdminLoginId" />
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label><strong>User Name:</strong></label>
                                <div class="view-box p-2 mt-1" id="lblvwUserName">Loading...</div>
                            </div>

                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label><strong>User ID:</strong></label>
                                <div class="view-box p-2 mt-1" id="lblvwLoginID">-</div>
                            </div>
                            <div class="col-md-6">
                                <label><strong>Status:</strong></label>
                                <div class="view-box p-2 mt-1" id="lblvwStatus">-</div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- DELETE MODAL -->
        <div class="modal fade" id="deleteAdminLogin" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title"><i class="fa fa-trash"></i> Confirm Delete</h5>
                        <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="hdnDeAdminLoginId" />
                        <div class="alert alert-warning">
                            <p>Are you sure you want to delete <strong id="lblDelUserName">this user</strong>?</p>
                            <p class="mb-0"><small class="text-danger">⚠️ This action cannot be undone!</small></p>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger" id="btnConfirmAdminLoginDelete">
                            <i class="fa fa-trash"></i> Delete User
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function() {
            console.log('🚀 === ADMIN LOGIN PAGE LOADED ===');
            console.log('📊 Table rows found:', $('#userTable tbody tr').length);
            console.log('🔗 Save URL:', '@Url.Action("Save", "AdminLogin")');
            console.log('🔗 Get URL:', '@Url.Action("GetAdminLogin", "AdminLogin")');

            // 🔥 GLOBAL AJAX ERROR HANDLER
            $(document).ajaxError(function(event, xhr, settings, error) {
                console.error('🌐 AJAX ERROR:', {
                    url: settings.url,
                    status: xhr.status,
                    statusText: xhr.statusText,
                    response: xhr.responseText,
                    error: error
                });
            });

            // 🔥 1. ADD USER - FULL DEBUG
            $('#btnAdminLoginSave').click(function(e) {
                console.log('➕ === ADD USER CLICKED ===');

                let userName = $('#txtAdminLoginName').val().trim();
                let roleId = $('#ddlRoleId').val();
                let password = $('#txtAdminLoginPassword').val();
                let isActive = $('#chkActiveStatus').is(':checked') ? 1 : 0;

                console.log('📋 ADD FORM DATA:', { userName, roleId, password: password ? '***HIDDEN***' : '', isActive });

                // Validation
                if (!userName) {
                    console.log('❌ Validation: Username empty');
                    showError('#msgAddName', 'User name is required!');
                    return;
                }
                if (!roleId) {
                    console.log('❌ Validation: Role empty');
                    showError('#msgAddRole', 'Please select a role!');
                    return;
                }
                if (!password || password.length < 6) {
                    console.log('❌ Validation: Password invalid');
                    showError('#msgAddPass', 'Password must be at least 6 characters!');
                    return;
                }

                let loginData = {
                    LoginID: 0,
                    UserName: userName,
                    Role_ID: parseInt(roleId),
                    Password: password,
                    IsActive: isActive
                };

                console.log('📤 SENDING ADD DATA:', loginData);
                console.log('🌐 POST URL:', '@Url.Action("Save", "AdminLogin")');

                $.ajax({
                    url: '@Url.Action("Save", "AdminLogin")',
                    type: 'POST',
                    data: loginData,
                    dataType: 'json',
                    beforeSend: function() {
                        console.log('⏳ Sending ADD request...');
                        $('#btnAdminLoginSave').prop('disabled', true).text('Saving...');
                    },
                    success: function(response) {
                        console.log('✅ ADD SUCCESS:', response);
                        if (response.success) {
                            showSuccess('✅ User added successfully!');
                            $('#addAdminLogin').modal('hide');
                            setTimeout(() => location.reload(), 1500);
                        } else {
                            console.log('❌ ADD Failed:', response.message);
                            showError(null, response.message || 'Failed to add user!');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('❌ ADD AJAX ERROR:', {
                            status: xhr.status,
                            statusText: xhr.statusText,
                            response: xhr.responseText
                        });
                        showError(null, `Network error! ${xhr.status}: ${xhr.statusText}`);
                    },
                    complete: function() {
                        $('#btnAdminLoginSave').prop('disabled', false).text('Save');
                    }
                });
            });
        // 🔥 2. EDIT LOAD DATA - FIXED FOR YOUR DB (lowercase properties)
        $(document).on('click', '.editByLoginId', function() {
            let loginId = $(this).data('edloginid');
            console.log('📝 === EDIT LOAD CLICKED === RAW ID:', loginId, 'TYPE:', typeof loginId);

            $.get('@Url.Action("GetAdminLogin", "AdminLogin")', { loginID: loginId })
            .done(function(response) {
                console.log('📥 EDIT LOAD RESPONSE:', response);
                if (response && response.success && response.data) {
                    let data = response.data;
                    console.log('✅ EDIT RAW DATA:', data);

                    // ✅ FIX: Handle BOTH cases (your DB returns lowercase)
                    let loginID = data.loginID || data.LoginID;
                    let userName = data.userName || data.UserName;
                    let roleID = data.role_ID || data.Role_ID;
                    let isActive = data.isActive || data.IsActive;

                    console.log('🔧 MAPPED DATA:', { loginID, userName, roleID, isActive });

                    // ✅ Set values SAFELY
                    $('#hdnAdminLoginId').val(loginID);
                    $('#txtEditAdminLoginName').val(userName || '');
                    $('#ddlEditRoleId').val(roleID);
                    $('#chkActiveStatusEdit').prop('checked', isActive == 1);

                    // ✅ DEBUG: Verify fields are set
                    console.log('✅ FORM AFTER SET:', {
                        hiddenID: $('#hdnAdminLoginId').val(),
                        nameField: $('#txtEditAdminLoginName').val(),
                        roleField: $('#ddlEditRoleId').val(),
                        checkbox: $('#chkActiveStatusEdit').is(':checked')
                    });

                } else {
                    console.log('❌ EDIT LOAD FAILED:', response);
                    showError(null, response?.error || 'User data not found!');
                }
            })
            .fail(function(xhr, status, error) {
                console.error('❌ EDIT LOAD AJAX ERROR:', {
                    status: xhr.status,
                    response: xhr.responseText,
                    error: error
                });
                showError(null, `Failed to load user! (${xhr.status})`);
            });
        });

        // 🔥 3. EDIT SAVE - FIXED ID VALIDATION
        $('#btnEditAdminLoginSave').click(function() {
            let hiddenId = $('#hdnAdminLoginId').val();
            let loginId = parseInt(hiddenId);

            console.log('✏️ === EDIT SAVE CLICKED ===');
            console.log('🔍 RAW HIDDEN ID:', hiddenId);
            console.log('🔍 PARSED ID:', loginId, 'IS NAN?', isNaN(loginId));

            // ✅ BETTER ID CHECK
            if (!hiddenId || hiddenId === '' || isNaN(loginId) || loginId <= 0) {
                console.error('❌ EDIT SAVE: INVALID ID', { hiddenId, loginId });
                showError(null, `Invalid user ID! (${hiddenId} -> ${loginId})`);
                return;
            }

            let roleIdRaw = $('#ddlEditRoleId').val();
            let roleId = parseInt(roleIdRaw);

            if (!roleId || roleId <= 0) {
                showError(null, 'Please select a valid role!');
                return;
            }

            let data = {
                LoginID: loginId,
                UserName: $('#txtEditAdminLoginName').val().trim(),
                Role_ID: roleId,
                Password: $('#txtEditPassword').val() || '',
                IsActive: $('#chkActiveStatusEdit').is(':checked') ? 1 : 0
            };

            console.log('📤 SENDING EDIT DATA:', data);
            console.log('🌐 POST URL:', '@Url.Action("Edit", "AdminLogin")');

            $.ajax({
                url: '@Url.Action("Edit", "AdminLogin")',
                type: 'POST',
                data: data,
                dataType: 'json',
                beforeSend: function() {
                    console.log('⏳ Sending EDIT request...');
                    $('#btnEditAdminLoginSave').prop('disabled', true).text('Updating...');
                },
                success: function(response) {
                    console.log('✅ EDIT SAVE RESPONSE:', response);
                    if (response && response.success) {
                        showSuccess('✅ User updated successfully!');
                        $('#editAdminLogin').modal('hide');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        console.log('❌ EDIT SAVE FAILED:', response);
                        showError(null, response?.message || 'Update failed!');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('❌ EDIT SAVE AJAX ERROR:', {
                        status: xhr.status,
                        response: xhr.responseText,
                        error: error
                    });
                    showError(null, `Update failed! (${xhr.status})`);
                },
                complete: function() {
                    $('#btnEditAdminLoginSave').prop('disabled', false).text('Update');
                }
            });
        });
                  // 🔥 4. VIEW USER - FIXED DISPLAY
        $(document).on('click', '.viewByLoginId', function() {
            let loginId = $(this).data('vwloginid');
            console.log('👁️ === VIEW CLICKED === ID:', loginId);

            $.get('@Url.Action("GetAdminLogin", "AdminLogin")', { loginID: loginId })
            .done(function(response) {
                console.log('👁️ VIEW RESPONSE:', response);
                if (response && response.success && response.data) {
                    let data = response.data;
                    console.log('✅ VIEW RAW DATA:', data);

                    // ✅ USE lowercase properties from your DB
                    $('#lblvwUserName').text(data.userName || data.UserName || 'N/A');
                    $('#lblvwRoleName').text(data.role_Name || data.Role_Name || 'No Role');
                    $('#lblvwLoginID').text(data.loginID || data.LoginID || 'N/A');

                    let status = (data.isActive || data.IsActive) == 1 ? 'Active' : 'Inactive';
                    $('#lblvwStatus').html(
                        `<span class="badge ${status === 'Active' ? 'badge-success' : 'badge-danger'}">${status}</span>`
                    );

                    console.log('✅ VIEW FIELDS SET:', {
                        name: $('#lblvwUserName').text(),
                        role: $('#lblvwRoleName').text(),
                        id: $('#lblvwLoginID').text(),
                        status: status
                    });
                } else {
                    console.log('❌ VIEW FAILED:', response);
                    $('#lblvwUserName').text('Error loading...');
                }
            })
            .fail(function(xhr) {
                console.error('❌ VIEW ERROR:', xhr.status, xhr.responseText);
                $('#lblvwUserName').text('Load failed');
            });
        });
            // 🔥 5. DELETE LOAD
            $(document).on('click', '.deleteLogins', function() {
                let loginId = $(this).data('dlloginid');
                console.log('🗑️ === DELETE LOAD === ID:', loginId);

                $.get('@Url.Action("GetAdminLogin", "AdminLogin")', { loginID: loginId })
                .done(function(response) {
                    console.log('🗑️ DELETE LOAD RESPONSE:', response);
                    if (response && response.success && response.data) {
                        $('#lblDelUserName').text(response.data.UserName);
                        $('#hdnDeAdminLoginId').val(loginId);
                    }
                });
            });

            // 🔥 6. DELETE CONFIRM
            $('#btnConfirmAdminLoginDelete').click(function() {
                let loginId = $('#hdnDeAdminLoginId').val();
                console.log('🗑️ === DELETE CONFIRM === ID:', loginId);

                if (!loginId) {
                    console.log('❌ DELETE: No ID');
                    showError(null, 'Invalid user ID!');
                    return;
                }

                $.get('@Url.Action("DeleteAdminLogin", "AdminLogin")', { loginID: loginId })
                .done(function(response) {
                    console.log('🗑️ DELETE RESPONSE:', response);
                    if (response.success) {
                        showSuccess('✅ User deleted successfully!');
                        $('#deleteAdminLogin').modal('hide');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showError(null, response.message || 'Delete failed!');
                    }
                })
                .fail(function(xhr) {
                    console.error('❌ DELETE AJAX ERROR:', xhr.status, xhr.responseText);
                    showError(null, 'Delete failed!');
                });
            });

            // 🔥 UTILITY FUNCTIONS
            $('.form-control').on('input', function() {
                $(this).siblings('.text-danger').text('');
            });

            $('#addAdminLogin, #editAdminLogin, #viewAdminLogin, #deleteAdminLogin').on('hidden.bs.modal', function() {
                $(this).find('input[type="text"], input[type="password"], select').val('');
                $('.text-danger').text('');
                $('#lblvwUserName').text('Loading...');
            });

            console.log('✅ All event handlers attached!');
        });

        // 🔥 HELPER FUNCTIONS (GLOBAL)
        function showError(selector, message) {
            console.log('⚠️ SHOW ERROR:', message);
            if (selector) {
                $(selector).text(message).show();
            } else {
                alert('❌ ' + message);
            }
        }

        function showSuccess(message) {
            console.log('✅ SHOW SUCCESS:', message);
            alert('✅ ' + message);
        }
        let rowsPerPage = 10;
        let currentPage = 1;

        function getRows() {
            return $('#userTable tbody tr:not(:has(.text-center))');
        }

        function updatePageInfo(totalPages) {
            $('#pageInfo').text(`Page ${currentPage} of ${totalPages}`);
        }

        function showPage(pageNum) {
            let rows = getRows();
            let totalRows = rows.length;
            let totalPages = Math.ceil(totalRows / rowsPerPage);

            if (pageNum < 1) pageNum = 1;
            if (pageNum > totalPages) pageNum = totalPages;

            rows.hide();

            let start = (pageNum - 1) * rowsPerPage;
            let end = start + rowsPerPage;

            rows.slice(start, end).show();

            currentPage = pageNum;
            updatePageInfo(totalPages);
        }

        function goToPage(direction) {
            let rows = getRows();
            let totalPages = Math.ceil(rows.length / rowsPerPage);

            if (direction === 'prev' && currentPage > 1) currentPage--;
            else if (direction === 'next' && currentPage < totalPages) currentPage++;

            showPage(currentPage);
        }

        $(document).ready(function () {

            // Default load
            showPage(1);

            // Show 10 per page
            $('#btnShowPage').click(function () {
                rowsPerPage = 10;
                showPage(1);
            });

            // Show all
            $('#btnShowAll').click(function () {
                let rows = getRows();
                rows.show();
                $('#pageInfo').text(`Showing All (${rows.length})`);
            });

        });

    </script>
</body>
</html>