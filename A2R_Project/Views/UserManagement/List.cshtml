@model A2R_Project.Models.Logins
@{
    ViewBag.Title = "Users List";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@@mdi/font@6.5.95/css/materialdesignicons.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #eef2ff, #f8fbff);
            font-family: 'Segoe UI', sans-serif;
        }

        .card {
            border-radius: 18px;
            border: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
        }

        .card-title {
            font-size: 20px;
            font-weight: 700;
            color: #2c3e50;
            letter-spacing: 0.5px;
        }

        .table {
            border-radius: 14px;
            overflow: hidden;
            background: #fff;
        }

            .table thead th {
                border: none;
                color: #fff;
                font-size: 14px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.6px;
                padding: 14px;
            }

            .table tbody td {
                font-size: 15px;
                font-weight: 600;
                color: #34495e;
                padding: 14px;
                vertical-align: middle;
                background-color: white !important;
            }

            .table tbody tr {
                transition: all 0.25s ease;
            }


        .badge-success {
            background: linear-gradient(135deg, #1cc88a, #17a673) !important;
            padding: 7px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            color: #fff;
        }

        .badge-danger {
            background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
            padding: 7px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            color: #fff;
        }

        .btn-gradient-primary {
            background: linear-gradient(135deg, #28a745, #20c997) !important;
            border: none !important;
            color: #fff !important;
            font-weight: 700;
            border-radius: 25px !important;
            padding: 8px 18px !important;
            transition: all 0.25s ease;
        }

            .btn-gradient-primary:hover {
                background: linear-gradient(135deg, #218838, #17a2b8) !important;
                color: #fff !important;
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }

        .table .btn-sm,
        .btn-group-sm .btn {
            width: 36px !important;
            height: 36px !important;
            border-radius: 10px !important;
            padding: 0 !important;
            margin-right: 4px;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            border: none !important;
            transition: all 0.25s ease;
        }

            .table .btn-sm i,
            .btn-group-sm .btn i {
                font-size: 16px !important;
                line-height: 1;
            }

            .table .btn-sm:hover,
            .btn-group-sm .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }

            .btn-group-sm .btn.editByLoginId,
            .table .btn-sm.btn-primary {
                background: linear-gradient(135deg, #4e73df, #224abe) !important;
                color: #fff !important;
            }

            .btn-group-sm .btn.viewByLoginId,
            .table .btn-sm.btn-info {
                background: linear-gradient(135deg, #36b9cc, #1f8ea3) !important;
                color: #fff !important;
            }

            .btn-group-sm .btn.deleteLogins,
            .table .btn-sm.btn-danger {
                background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
                color: #fff !important;
            }

        #btnShowPage, #btnShowAll {
            border-radius: 25px !important;
            font-weight: 600 !important;
            padding: 6px 16px !important;
            transition: all 0.25s ease;
        }

            #btnShowPage:hover, #btnShowAll:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }

        #pageInfo {
            color: #2c3e50;
            font-size: 14px;
            font-weight: 600;
        }

        .pagination .page-link {
            border-radius: 10px;
            margin: 0 4px;
            font-weight: 600;
            color: #4e73df;
            border: none;
        }

        .pagination .page-item.active .page-link {
            background: linear-gradient(135deg, #4e73df, #224abe);
            color: #fff;
        }

        .pagination .page-link:hover {
            background: #e8edff;
        }

        .form-control {
            border-radius: 10px;
            border: 1px solid #dce3f0;
            padding: 8px 12px;
            font-weight: 600;
            color: #111 !important;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                border-color: #4e73df;
                box-shadow: 0 0 0 3px rgba(78,115,223,0.15);
                outline: none;
            }

        label {
            font-weight: 600;
            color: #2c3e50;
        }

        .view-box {
            background: #f1f4ff;
            border-radius: 8px;
            padding: 8px 12px;
            font-weight: 600;
            color: #2c3e50;
            min-height: 38px;
            display: flex;
            align-items: center;
        }

        .error-text {
            font-size: 12px;
            margin-top: 3px;
            display: block;
            color: red;
        }

        .is-invalid {
            border-color: #ef4444 !important;
        }

        .modal-backdrop {
            opacity: 0.25 !important;
            background-color: #000;
        }

        /* ===== ALL 4 MODALS - SAME SIZE ===== */
        .modal-dialog {
            max-width: 700px !important;
            margin-top: 80px;
        }

        /* ===== MODAL CONTENT - STANDARD STYLE ===== */
        .modal-content {
            border-radius: 14px !important;
            border: none !important;
            box-shadow: 0 12px 35px rgba(0,0,0,0.18) !important;
            overflow: hidden;
            animation: fadeInScale 0.3s ease;
        }

        @@keyframes fadeInScale {
            from {
                opacity: 0;
                transform: scale(0.93);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* ===== MODAL HEADER - STANDARD ===== */
        .modal-header {
            padding: 16px 22px !important;
            border-bottom: 1px solid rgba(255,255,255,0.15) !important;
            border-radius: 14px 14px 0 0 !important;
        }

        .modal-title {
            font-size: 16px !important;
            font-weight: 700 !important;
            letter-spacing: 0.4px !important;
        }

        /* ===== STANDARD CLOSE BUTTON (×) ===== */
        .modal-header .close {
            font-size: 22px !important;
            font-weight: 700 !important;
            line-height: 1 !important;
            opacity: 0.85 !important;
            text-shadow: none !important;
            padding: 0 4px !important;
            margin: 0 !important;
            background: transparent !important;
            border: none !important;
            cursor: pointer;
            transition: opacity 0.2s ease;
        }

            .modal-header .close:hover {
                opacity: 1 !important;
            }

        .modal-body {
            padding: 24px 26px !important;
            background: #f9fbff !important;
            font-size: 15px;
        }

        .modal-footer {
            padding: 14px 22px !important;
            background: #fff !important;
            border-top: 1px solid #eee !important;
            border-radius: 0 0 14px 14px !important;
        }

            .modal-footer .btn {
                border-radius: 25px !important;
                padding: 7px 20px !important;
                font-weight: 600 !important;
                font-size: 14px !important;
                transition: all 0.25s ease;
            }

                .modal-footer .btn:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 15px rgba(0,0,0,0.15);
                }

       

        #deleteAdminLogin .modal-header {
            background: #fff !important;
            border-bottom: 1px solid #f5c6cb !important;
            padding: 18px 24px !important;
        }

        #deleteAdminLogin .modal-title {
            color: #c0392b !important;
            font-size: 18px !important;
        }

        #deleteAdminLogin .modal-header .close {
            color: #c0392b !important;
        }

        #deleteAdminLogin .modal-body {
            background: #fff !important;
            padding: 28px 30px !important;
            text-align: center;
        }

        #deleteAdminLogin .delete-icon-wrap {
            width: 70px;
            height: 70px;
            background: #fdecea;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px auto;
        }

            #deleteAdminLogin .delete-icon-wrap i {
                font-size: 32px;
                color: #e74a3b;
            }

        #deleteAdminLogin .delete-title {
            font-size: 18px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 6px;
        }

        #deleteAdminLogin .delete-subtitle {
            font-size: 14px;
            color: #7f8c8d;
            margin-bottom: 0;
        }

        #deleteAdminLogin .modal-footer {
           
            gap: 12px;
            padding: 18px 22px !important;
        }

        /* ===== TABLE CENTER ===== */
        #userTable th,
        #userTable td {
            text-align: center;
            vertical-align: middle;
        }

            #userTable td:first-child,
            #userTable th:first-child {
                text-align: left;
            }

        /* ===== VIEW STATUS INLINE ===== */
        .view-inline-row {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .view-inline-row label {
                margin: 0;
                white-space: nowrap;
                min-width: 65px;
            }

        @@media (max-width: 768px) {
            .table th, .table td {
                font-size: 12px;
                padding: 8px;
            }

            .modal-dialog {
                max-width: 95% !important;
                margin: 10px auto;
            }

            .btn {
                font-size: 12px;
            }
        }
        /* ===== COMMON MODAL THEME (MATCH SECOND PAGE) ===== */

        /* Header gradient */
        .modal-header {
            background: linear-gradient(135deg, #4e73df, #224abe) !important;
            color: #fff !important;
            border-bottom: none !important;
            border-radius: 18px 18px 0 0 !important;
        }

            .modal-header .modal-title {
                color: #fff !important;
                font-size: 18px;
                font-weight: 700;
            }

            .modal-header .close {
                color: #fff !important;
                opacity: 1;
                font-size: 22px;
            }

        /* Body */
        .modal-body {
            background: #f9fbff !important;
            padding: 24px !important;
        }

        /* Footer */
        .modal-footer {
            background: #fff !important;
            border-top: 1px solid #eee !important;
            padding: 14px 20px !important;
        }

            /* ===== BUTTON COLORS (MATCH SECOND PAGE) ===== */

            /* PRIMARY (Save / Update) */
            .modal-footer .btn-primary,
            .modal-footer .btn-warning,
            .modal-footer .btn-success {
                background: linear-gradient(135deg, #4e73df, #224abe) !important;
                border: none !important;
                color: #fff !important;
                font-weight: 600;
            }

            /* RESET BUTTON */
            .modal-footer .btn-warning {
                background: linear-gradient(135deg, #f6c23e, #e0a800) !important;
                color: #000 !important;
            }

            /* CANCEL BUTTON */
            .modal-footer .btn-secondary {
                background: #6c757d !important;
                color: #fff !important;
                border: none !important;
            }

            /* DELETE BUTTON */
            .modal-footer .btn-danger {
                background: linear-gradient(135deg, #e74a3b, #c0392b) !important;
                border: none !important;
                color: #fff !important;
            }

            /* Hover effect */
            .modal-footer .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }

        /* Modal box */
        .modal-content {
            border-radius: 18px !important;
            border: none !important;
            box-shadow: 0 12px 40px rgba(0,0,0,0.18) !important;
            overflow: hidden;
        }
    

#deleteAdminLogin .modal-body {
    text-align: center;
    padding: 30px !important;
}

#deleteAdminLogin .delete-icon-wrap {
    width: 80px;
    height: 80px;
    background: rgba(231,76,59,0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 15px;
}

#deleteAdminLogin .delete-icon-wrap i {
    font-size: 32px;
    color: #e74a3b;
}

#deleteAdminLogin .delete-title {
    font-size: 18px;
    font-weight: 700;
    color: #2c3e50;
}

#deleteAdminLogin .delete-subtitle {
    font-size: 14px;
    color: #7f8c8d;
}
        /* ===== SAME HEADER FOR ALL MODALS ===== */
        #addAdminLogin .modal-header,
        #editAdminLogin .modal-header,
        #viewAdminLogin .modal-header,
        #deleteAdminLogin .modal-header {
            background: linear-gradient(135deg, #4e73df, #224abe) !important;
            color: #fff !important;
            border-bottom: none !important;
        }

        /* TITLE COLOR */
        #addAdminLogin .modal-title,
        #editAdminLogin .modal-title,
        #viewAdminLogin .modal-title,
        #deleteAdminLogin .modal-title {
            color: #fff !important;
            font-weight: 700;
        }

        /* CLOSE BUTTON COLOR */
        #addAdminLogin .modal-header .close,
        #editAdminLogin .modal-header .close,
        #viewAdminLogin .modal-header .close,
        #deleteAdminLogin .modal-header .close {
            color: #fff !important;
            opacity: 1 !important;
        }
        /* ===== ALL MODALS - UNIFORM SIZE ===== */
        .modal-dialog {
            max-width: 700px !important;
            width: 700px !important;
            margin-top: 80px !important;
        }

        .modal-content {
            min-height: 420px !important;
        }

        .modal-body {
            min-height: 300px !important;
            max-height: 300px !important;
            overflow-y: auto !important;
        }

        /* Delete modal body override - center content vertically */
        #deleteAdminLogin .modal-body {
            min-height: 300px !important;
            max-height: 300px !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            justify-content: center !important;
        }

        /* View modal body override */
        #viewAdminLogin .modal-body {
            min-height: 300px !important;
            max-height: 300px !important;
        }

        @@media (max-width: 768px) {
            .modal-dialog

        {
            max-width: 95% !important;
            width: 95% !important;
            margin: 10px auto !important;
        }

        }

        #btnToggleEditPassword {
            background: transparent !important;
            border: none !important;
            color: #4e73df !important;
            padding: 0 10px !important;
        }

            #btnToggleEditPassword:hover {
                color: #224abe !important;
            }

            #btnToggleEditPassword i {
                font-size: 16px;
            }

            #btnToggleEditPassword i {
                color: #000 !important;
            }

        .view-box {
            background: none !important;
            border: none !important;
            padding: 0 !important;
            font-weight: 500;
            color: #111;
        }
    </style>
</head>
<body>
    <div class="container-fluid mt-4">
        <div class="col-lg-12 stretch-card">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <strong class="card-title h4"> Users List (@Model.adminLogin.Count users)</strong>
                        @if (ViewBag.CanInsert == true)
                        {
                            <button class="btn btn-gradient-primary" data-toggle="modal" data-target="#addAdminLogin">
                                <i class="fa fa-plus"></i> Add User
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-rounded" onclick="noAccess('Insert')">
                                <i class="fa fa-plus"></i> Add User
                            </button>
                        }
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="userTable">
                            <thead class="thead-dark">
                                <tr>
                                    <th>User Name</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model?.adminLogin != null && Model.adminLogin.Any())
                                {
                                    @foreach (var item in Model.adminLogin)
                                    {
                                        <tr>
                                            <td><strong>@item.UserName</strong></td>
                                            <td>@item.Role_Name</td>
                                            <td>
                                                @if (item.IsActive == 1)
                                                {
                                                    <span class="badge badge-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">

                                                    @* EDIT *@
                                                    @if (ViewBag.CanUpdate == true)
                                                    {
                                                        <button type="button" class="btn btn-sm editByLoginId"
                                                                data-edloginid="@item.LoginID"
                                                                data-toggle="modal" data-target="#editAdminLogin"
                                                                title="Edit">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary"
                                                                title="No Edit Permission"
                                                                onclick="noAccess('Update')">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </button>
                                                    }

                                                    @* VIEW — always visible *@
                                                    <button type="button" class="btn btn-sm viewByLoginId"
                                                            data-vwloginid="@item.LoginID"
                                                            data-toggle="modal" data-target="#viewAdminLogin"
                                                            title="View">
                                                        <i class="mdi mdi-eye"></i>
                                                    </button>

                                                    @* DELETE *@
                                                    @if (ViewBag.CanDelete == true)
                                                    {
                                                        <button type="button" class="btn btn-sm deleteLogins"
                                                                data-dlloginid="@item.LoginID"
                                                                data-toggle="modal" data-target="#deleteAdminLogin"
                                                                title="Delete">
                                                            <i class="mdi mdi-delete"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary"
                                                                title="No Delete Permission"
                                                                onclick="noAccess('Delete')">
                                                            <i class="mdi mdi-delete"></i>
                                                        </button>
                                                    }

                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-4">No users found</td></tr>
                                }
                            </tbody>
                        </table>

                        <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap">
                            <div style="display: flex; gap: 8px;">
                                <button class="btn btn-sm" id="btnShowPage"
                                        style="background: linear-gradient(135deg, #36b9cc, #1f8ea3) !important; color:#fff; border:none; border-radius:25px; font-weight:700; padding:6px 16px;">
                                    <i class="fa fa-list"></i> Show 10 / Page
                                </button>
                                <button class="btn btn-sm" id="btnShowAll"
                                        style="background: linear-gradient(135deg, #28a745, #20c997) !important; color:#fff; border:none; border-radius:25px; font-weight:700; padding:6px 16px;">
                                    <i class="fa fa-th-list"></i> Show All
                                </button>
                            </div>
                            <div style="display: flex; align-items: center; gap: 6px;">
                                <button class="btn btn-sm" onclick="goToPage('prev')"
                                        style="background:#fff; color:#4e73df; border:none; border-radius:10px; font-weight:600; padding:6px 14px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
                                    ⬅ Prev
                                </button>
                                <span id="pageInfo" class="mx-1"
                                      style="background:#eef2ff; color:#2c3e50; font-weight:700; font-size:14px; padding:5px 14px; border-radius:20px;">
                                </span>
                                <button class="btn btn-sm" onclick="goToPage('next')"
                                        style="background:#fff; color:#4e73df; border:none; border-radius:10px; font-weight:600; padding:6px 14px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
                                    Next ➡
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== ADD MODAL ===== -->
        <div class="modal fade" id="addAdminLogin" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header" style="background: linear-gradient(135deg, #2563eb, #1e40af);">
                        <h5 class="modal-title text-white"><i class="fa fa-user-plus mr-2"></i> Add New User</h5>
                        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <form id="addForm">
                            <div class="form-group">
                                <label>User Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtAdminLoginName" required />
                                <small class="text-danger" id="msgAddName"></small>
                            </div>
                            <div class="form-group">
                                <label>Role <span class="text-danger">*</span></label>
                                <select id="ddlRoleId" class="form-control" required>
                                    <option value="">Select Role</option>
                                    @if (ViewBag.Roles != null)
                                    {
                                        foreach (var role in ViewBag.Roles as List<A2R_Project.Models.Role>)
                                        {
                                            <option value="@role.Role_ID">@role.Role_Name</option>
                                        }
                                    }
                                </select>
                                <small class="text-danger" id="msgAddRole"></small>
                            </div>
                            <div class="form-group">
                                <label>Password <span class="text-danger">*</span></label>
                                <input type="password" class="form-control" id="txtAdminLoginPassword" required minlength="6" />
                                <small class="text-danger" id="msgAddPass"></small>
                            </div>
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="chkActiveStatus" checked>
                                <label class="form-check-label">Active Status</label>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">
                           Cancel
                        </button>
                        <button type="button" class="btn btn-primary" id="btnAdminLoginSave">
                           Save User
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== EDIT MODAL ===== -->
        <div class="modal fade" id="editAdminLogin" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                        <h5 class="modal-title text-white"><i class="fa fa-edit mr-2"></i> Edit User</h5>
                        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="hdnAdminLoginId" />
                        <div class="form-group">
                            <label>User Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtEditAdminLoginName" required />
                        </div>
                        <div class="form-group">
                            <label>Role <span class="text-danger">*</span></label>
                            <select id="ddlEditRoleId" class="form-control" required>
                                <option value="">Select Role</option>
                                @if (ViewBag.Roles != null)
                                {
                                    foreach (var role in ViewBag.Roles as List<A2R_Project.Models.Role>)
                                    {
                                        <option value="@role.Role_ID">@role.Role_Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label> Password <small class="text-muted"></small></label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="txtEditPassword" placeholder="Leave blank to keep current" />
                                <div class="input-group-append">
                                    <button type="button" class="btn btn-outline-secondary" id="btnToggleEditPassword" tabindex="-1">
                                        <i class="fa fa-eye" id="iconToggleEditPassword"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="chkActiveStatusEdit" checked>
                            <label class="form-check-label">Active Status</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">
                        Cancel
                        </button>
                        <button type="button" class="btn btn-warning text-white" id="btnEditAdminLoginSave">
                            Update User
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== VIEW MODAL ===== -->
        <div class="modal fade" id="viewAdminLogin" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header" style="background: linear-gradient(135deg, #0ea5e9, #0284c7);">
                        <h5 class="modal-title text-white"><i class="fa fa-eye mr-2"></i> User Details</h5>
                        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="hdnVwAdminLoginId" />

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label>User Name</label>
                            </div>
                            <div class="col-md-8">
                                <div class="view-box" id="lblvwUserName">Loading...</div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label>User ID</label>
                            </div>
                            <div class="col-md-8">
                                <div class="view-box" id="lblvwLoginID">-</div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label>Status</label>
                            </div>
                            <div class="col-md-8">
                                <div class="view-box">
                                    <span id="lblvwStatus">-</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">
                             Close
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== DELETE MODAL - DIFFERENT STYLE ===== -->
        <div class="modal fade" id="deleteAdminLogin" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="fa fa-trash mr-2"></i> Delete User
                        </h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="hdnDeAdminLoginId" />
                        <div class="delete-icon-wrap">
                            <i class="fa fa-trash"></i>
                        </div>
                        <p class="delete-title">Are you sure?</p>
                        <p class="delete-subtitle">
                            You are about to delete <strong id="lblDelUserName">this user</strong>.<br>
                            This action <strong>cannot be undone</strong>.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-lg px-4" data-dismiss="modal">
                             Cancel
                        </button>
                        <button type="button" class="btn btn-danger btn-lg px-4" id="btnConfirmAdminLoginDelete">
                           Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
              function noAccess(type) {
            Swal.fire({
                icon: 'error',
                title: 'Access Denied',
                text: 'You do not have ' + type + ' permission for Users module.',
                confirmButtonColor: '#dc2626'
            });
        }
        $(document).ready(function () {
            console.log('🚀 === ADMIN LOGIN PAGE LOADED ===');

            $(document).ajaxError(function (event, xhr, settings, error) {
                console.error('🌐 AJAX ERROR:', { url: settings.url, status: xhr.status, response: xhr.responseText });
            });

            // 1. ADD USER
            $('#btnAdminLoginSave').click(function (e) {
                let userName = $('#txtAdminLoginName').val().trim();
                let roleId = $('#ddlRoleId').val();
                let password = $('#txtAdminLoginPassword').val();
                let isActive = $('#chkActiveStatus').is(':checked') ? 1 : 0;

                if (!userName) { showError('#msgAddName', 'User name is required!'); return; }
                if (!roleId)   { showError('#msgAddRole', 'Please select a role!'); return; }
                if (!password || password.length < 6) { showError('#msgAddPass', 'Password must be at least 6 characters!'); return; }

                $.ajax({
                    url: '@Url.Action("Save", "AdminLogin")',
                    type: 'POST',
                    data: { LoginID: 0, UserName: userName, Role_ID: parseInt(roleId), Password: password, IsActive: isActive },
                    dataType: 'json',
                    beforeSend: function () { $('#btnAdminLoginSave').prop('disabled', true).text('Saving...'); },
                    success: function (response) {
                        if (response.success) {
                            showSuccess('✅ User added successfully!');
                            $('#addAdminLogin').modal('hide');
                            setTimeout(() => location.reload(), 1500);
                        } else {
                            showError(null, response.message || 'Failed to add user!');
                        }
                    },
                    error: function (xhr) { showError(null, `Network error! ${xhr.status}: ${xhr.statusText}`); },
                    complete: function () { $('#btnAdminLoginSave').prop('disabled', false).text('Save'); }
                });
            });

                   // 2. EDIT LOAD
        $(document).on('click', '.editByLoginId', function () {
            let loginId = $(this).data('edloginid');
            $.get('@Url.Action("GetAdminLogin", "AdminLogin")', { loginID: loginId })
            .done(function (response) {
                if (response && response.success && response.data) {
                    let data = response.data;
                    $('#hdnAdminLoginId').val(data.loginID || data.LoginID);
                    $('#txtEditAdminLoginName').val(data.userName || data.UserName || '');
                    $('#ddlEditRoleId').val(data.role_ID || data.Role_ID);
                    $('#chkActiveStatusEdit').prop('checked', (data.isActive || data.IsActive) == 1);
                    $('#txtEditPassword').val(data.password || data.Password || ''); // ← ADD THIS LINE
                } else {
                    showError(null, response?.error || 'User data not found!');
                }
            })
            .fail(function (xhr) { showError(null, `Failed to load user! (${xhr.status})`); });
        });

            // 3. EDIT SAVE
            $('#btnEditAdminLoginSave').click(function () {
                let hiddenId = $('#hdnAdminLoginId').val();
                let loginId  = parseInt(hiddenId);
                if (!hiddenId || isNaN(loginId) || loginId <= 0) { showError(null, `Invalid user ID!`); return; }

                let roleId = parseInt($('#ddlEditRoleId').val());
                if (!roleId || roleId <= 0) { showError(null, 'Please select a valid role!'); return; }

                $.ajax({
                    url: '@Url.Action("Edit", "AdminLogin")',
                    type: 'POST',
                    data: { LoginID: loginId, UserName: $('#txtEditAdminLoginName').val().trim(), Role_ID: roleId, Password: $('#txtEditPassword').val() || '', IsActive: $('#chkActiveStatusEdit').is(':checked') ? 1 : 0 },
                    dataType: 'json',
                    beforeSend: function () { $('#btnEditAdminLoginSave').prop('disabled', true).text('Updating...'); },
                    success: function (response) {
                        if (response && response.success) {
                            showSuccess('✅ User updated successfully!');
                            $('#editAdminLogin').modal('hide');
                            setTimeout(() => location.reload(), 1500);
                        } else {
                            showError(null, response?.message || 'Update failed!');
                        }
                    },
                    error: function (xhr) { showError(null, `Update failed! (${xhr.status})`); },
                    complete: function () { $('#btnEditAdminLoginSave').prop('disabled', false).text('Update'); }
                });
            });

            // 4. VIEW
            $(document).on('click', '.viewByLoginId', function () {
                let loginId = $(this).data('vwloginid');
                $.get('@Url.Action("GetAdminLogin", "AdminLogin")', { loginID: loginId })
                .done(function (response) {
                    if (response && response.success && response.data) {
                        let data = response.data;
                        $('#lblvwUserName').text(data.userName || data.UserName || 'N/A');
                        $('#lblvwLoginID').text(data.loginID || data.LoginID || 'N/A');
                        let isActive = (data.isActive || data.IsActive) == 1;
                        $('#lblvwStatus').html(
                            `<span class="badge ${isActive ? 'badge-success' : 'badge-danger'}">${isActive ? 'Active' : 'Inactive'}</span>`
                        );
                    } else {
                        $('#lblvwUserName').text('Error loading...');
                    }
                })
                .fail(function () { $('#lblvwUserName').text('Load failed'); });
            });

            // 5. DELETE LOAD
            $(document).on('click', '.deleteLogins', function () {
                let loginId = $(this).data('dlloginid');
                $.get('@Url.Action("GetAdminLogin", "AdminLogin")', { loginID: loginId })
                .done(function (response) {
                    if (response && response.success && response.data) {
                        $('#lblDelUserName').text(response.data.UserName || response.data.userName);
                        $('#hdnDeAdminLoginId').val(loginId);
                    }
                });
            });

            // 6. DELETE CONFIRM
            $('#btnConfirmAdminLoginDelete').click(function () {
                let loginId = $('#hdnDeAdminLoginId').val();
                if (!loginId) { showError(null, 'Invalid user ID!'); return; }
                $.get('@Url.Action("DeleteAdminLogin", "AdminLogin")', { loginID: loginId })
                .done(function (response) {
                    if (response.success) {
                        showSuccess('✅ User deleted successfully!');
                        $('#deleteAdminLogin').modal('hide');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showError(null, response.message || 'Delete failed!');
                    }
                })
                .fail(function () { showError(null, 'Delete failed!'); });
            });
                    // TOGGLE PASSWORD VISIBILITY
        $('#btnToggleEditPassword').click(function () {
            let input = $('#txtEditPassword');
            let icon = $('#iconToggleEditPassword');
            if (input.attr('type') === 'password') {
                input.attr('type', 'text');
                icon.removeClass('fa-eye').addClass('fa-eye-slash');
            } else {
                input.attr('type', 'password');
                icon.removeClass('fa-eye-slash').addClass('fa-eye');
            }
        });
            // CLEAR ON MODAL CLOSE
            $('#addAdminLogin, #editAdminLogin, #viewAdminLogin, #deleteAdminLogin').on('hidden.bs.modal', function () {
                $(this).find('input[type="text"], input[type="password"], select').val('');
                $('.text-danger').text('');
                $('#lblvwUserName').text('Loading...');
            });

            // CLEAR ERRORS ON INPUT
            $('.form-control').on('input', function () {
                $(this).siblings('.text-danger').text('');
            });

            // PAGINATION DEFAULT
            showPage(1);

            $('#btnShowPage').click(function () { rowsPerPage = 10; showPage(1); });
            $('#btnShowAll').click(function () {
                getRows().show();
                $('#pageInfo').text(`Showing All (${getRows().length})`);
            });
        });

        function showError(selector, message) {
            if (selector) $(selector).text(message).show();
            else alert('❌ ' + message);
        }

        function showSuccess(message) { alert('✅ ' + message); }

        let rowsPerPage = 10;
        let currentPage = 1;

        function getRows() {
            return $('#userTable tbody tr:not(:has(.text-center))');
        }

        function updatePageInfo(totalPages) {
            $('#pageInfo').text(`Page ${currentPage} of ${totalPages}`);
        }

        function showPage(pageNum) {
            let rows = getRows();
            let totalPages = Math.ceil(rows.length / rowsPerPage);
            if (pageNum < 1) pageNum = 1;
            if (pageNum > totalPages) pageNum = totalPages;
            rows.hide();
            rows.slice((pageNum - 1) * rowsPerPage, pageNum * rowsPerPage).show();
            currentPage = pageNum;
            updatePageInfo(totalPages);
        }

        function goToPage(direction) {
            let totalPages = Math.ceil(getRows().length / rowsPerPage);
            if (direction === 'prev' && currentPage > 1) currentPage--;
            else if (direction === 'next' && currentPage < totalPages) currentPage++;
            showPage(currentPage);
        }
    </script>
</body>
</html>