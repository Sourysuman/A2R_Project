        display: flex;
        align-items: center;
        gap: 5px;
    }

        .btn-group .btn {
            margin: 0;
        }

    .status-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .badge-success-custom {
        background: var(--success);
