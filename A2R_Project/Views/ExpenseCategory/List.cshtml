<div class="container-fluid px-4">
    <div class="row">
        <div class="col-12">
            <div class="card card-modern">
                <div class="card-header-custom">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                        <div>
                            <h5 class="card-title mb-1">
                                <i class="fas fa-list mr-2"></i>Expense Category List
                            </h5>
                            <small>Total: <strong id="totalCount">@(ViewBag.TotalCount ?? 0)</strong></small>
                        </div>

                        @if (ViewBag.CanInsert == true)
                        {
                            <button type="button" class="btn add-category-btn"
                                    data-toggle="modal" data-target="#addModal">
                                <i class="fas fa-plus mr-2"></i>Add Category
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn add-category-btn"
                                    style="background:linear-gradient(135deg,#6b7280,#4b5563)!important;"
                                    onclick="noAccess('Insert')">
                                <i class="fas fa-plus mr-2"></i>Add Category
                            </button>
                        }
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-modern mb-0" id="categoryTable">
                            <thead>
                                <tr>
                                    <th>Category Name</th>
                                   
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="categoryTableBody">
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td style="text-align: left !important;">
                                                <div class="d-flex align-items-center" style="padding-left: 16px;">
                                                   
                                                    <div>
                                                        <strong style="color:var(--dark);">@item.Category_Name</strong>
                                                        <br><small style="color:var(--gray);">ID: @item.Category_ID</small>
                                                    </div>
                                                </div>
                                            </td>

                                            <td>
                                                <div class="btn-group" role="group">

                                                    @* EDIT *@
                                                    @if (ViewBag.CanUpdate == true)
                                                    {
                                                        <button class="btn btn-primary-modern btn-modern btn-sm edit-btn"
                                                                data-id="@item.Category_ID" title="Edit">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-modern btn-sm"
                                                                style="background:linear-gradient(135deg,#6b7280,#4b5563)!important;color:#fff!important;"
                                                                title="No Edit Permission"
                                                                onclick="noAccess('Update')">
                                                            <i class="mdi mdi-pencil"></i>
                                                        </button>
                                                    }

                                                    @* VIEW — always visible *@
                                                    <button class="btn btn-info-modern btn-modern btn-sm view-btn"
                                                            data-id="@item.Category_ID" title="View">
                                                        <i class="mdi mdi-eye"></i>
                                                    </button>

                                                    @* DELETE *@
                                                    @if (ViewBag.CanDelete == true)
                                                    {
                                                        <button class="btn btn-danger-modern btn-modern btn-sm delete-btn"
                                                                data-id="@item.Category_ID" title="Delete">
                                                            <i class="mdi mdi-delete"></i>
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-modern btn-sm"
                                                                style="background:linear-gradient(135deg,#6b7280,#4b5563)!important;color:#fff!important;"
                                                                title="No Delete Permission"
                                                                onclick="noAccess('Delete')">
                                                            <i class="mdi mdi-delete"></i>
                                                        </button>
                                                    }

                                                </div>
                                            </td>
                                         
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="empty-state">
                                            <i class="fas fa-tags"></i>
                                            <h5>No Expense Categories Found</h5>
                                            <p class="mb-0">Click "Add Category" to get started</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Show All + Pagination -->
                    <div class="row mt-3 px-4 pb-4 align-items-center">
                        <div class="col-auto">
                            <button type="button" id="btnShowAll" class="show-all-btn btn-modern">
                                <i class="fas fa-expand-arrows-alt mr-2"></i>Show All Records
                            </button>
                        </div>
                        <div class="col">
                            <nav aria-label="Page navigation">
                                <ul class="pagination pagination-modern justify-content-end mb-0" id="clientPagination"></ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ADD MODAL -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-plus-circle mr-2"></i>Add New Category</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <span class="text-danger" id="msgAddValidation" style="font-size:12px;"></span>
            <!-- ADD MODAL BODY -->
            <div class="modal-body">
                <form id="addForm">
                    <div class="form-group">
                        <label class="form-label">Category Name: <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-modern" id="addCategoryName"
                               placeholder="Enter category name" />
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-modern" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning-modern btn-modern" id="btnAddReset">
                   Reset
                </button>
                <button type="button" class="btn btn-primary-modern btn-modern" id="btnAddSave">
                    Save Category
                </button>
            </div>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-edit mr-2"></i>Edit Category</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editForm">
                    <input type="hidden" id="editCategoryId">
                    <!-- EDIT MODAL -->
                    <div class="form-group">
                        <label class="form-label">Category Name: <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-modern" id="editCategoryName"
                               placeholder="Enter category name" />
                    </div>
                    <span class="text-danger" id="msgEditValidation" style="font-size:12px;"></span>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-modern" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning-modern btn-modern" id="btnEditReset">Reset</button>
                <button type="button" class="btn btn-primary-modern btn-modern" id="btnEditSave">
                   Update Category
                </button>
            </div>
        </div>
    </div>
</div>

<!-- VIEW MODAL -->
<div class="modal fade" id="viewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-eye mr-2"></i>Category Details</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body" style="padding:25px 30px;">
                <div class="view-row">
                    <span class="view-label">Category Name:</span>
                    <span class="view-value" id="viewCategoryName"></span>
                </div>
                
            </div>
            <div class="modal-footer" style="padding:12px 30px;">
                <button type="button" class="btn btn-secondary btn-modern" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle mr-2"></i>Confirm Delete</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="deleteCategoryId" />
                <div class="text-center py-4">
                    <div style="width:80px;height:80px;border-radius:50%;background:rgba(239,68,68,0.1);margin:0 auto 1.5rem;display:flex;align-items:center;justify-content:center;">
                        <i class="fas fa-trash-alt" style="font-size:2.5rem;color:var(--danger);"></i>
                    </div>
                    <h5 class="mb-3" style="color:var(--dark);">Delete this category?</h5>
                    <p class="mb-4" style="color:var(--gray);">This action cannot be undone. Category "<strong id="deleteCategoryName"></strong>" will be permanently deleted.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-modern" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger-modern btn-modern" id="confirmDeleteBtn">
                   Delete Category
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script>
        function noAccess(type) {
            Swal.fire({
                icon: 'error',
                title: 'Access Denied',
                text: 'You do not have ' + type + ' permission for Expense Category module.',
                confirmButtonColor: '#dc2626'
            });
        }
        $(document).ready(function () {
            console.log('✅ Expense Category Management Loaded!');

            let tableRows = [];

            // ===== HELPERS =====
            function getVal(data, prop) {
                var keys = [prop, prop.toLowerCase(), prop.charAt(0).toLowerCase() + prop.slice(1), prop.replace('_', '')];
                for (var k of keys) { if (data[k] !== undefined && data[k] !== null) return data[k]; }
                return null;
            }

            function formatDate(val) {
                if (!val) return 'N/A';
                try { return new Date(val).toLocaleString('en-IN'); } catch (e) { return val; }
            }

            // ===== PAGINATION =====
            function setupPagination() {
                tableRows = $('#categoryTableBody tr').filter(function () { return $(this).find('td').length > 1; });
                var rowsPerPage = 5, totalPages = Math.ceil(tableRows.length / rowsPerPage);
                $('#clientPagination').empty();
                if (tableRows.length === 0) return;

                $('#clientPagination').append('<li class="page-item" id="prevPage"><a class="page-link" href="#"><i class="fas fa-chevron-left"></i></a></li>');
                for (var i = 1; i <= totalPages; i++) {
                    $('#clientPagination').append('<li class="page-item' + (i === 1 ? ' active' : '') + '" data-page="' + i + '"><a class="page-link" href="#">' + i + '</a></li>');
                }
                $('#clientPagination').append('<li class="page-item" id="nextPage"><a class="page-link" href="#"><i class="fas fa-chevron-right"></i></a></li>');
                showPage(1, rowsPerPage);
            }

            function showPage(page, rowsPerPage) {
                rowsPerPage = rowsPerPage || 5;
                tableRows.hide();
                tableRows.slice((page - 1) * rowsPerPage, page * rowsPerPage).show();
                $('#clientPagination .page-item[data-page]').removeClass('active');
                $('#clientPagination .page-item[data-page="' + page + '"]').addClass('active');
            }

            function getCurrentPage() { return parseInt($('#clientPagination .page-item.active').data('page')) || 1; }
            function getTotalPages()  { return $('#clientPagination .page-item[data-page]').length; }

            $(document).on('click', '#clientPagination .page-item[data-page] a', function (e) {
                e.preventDefault(); showPage($(this).closest('.page-item').data('page'));
            });
            $(document).on('click', '#prevPage a', function (e) {
                e.preventDefault(); var c = getCurrentPage(); if (c > 1) showPage(c - 1);
            });
            $(document).on('click', '#nextPage a', function (e) {
                e.preventDefault(); var c = getCurrentPage(); if (c < getTotalPages()) showPage(c + 1);
            });

            $('#btnShowAll').click(function () {
                tableRows.show();
                $('#clientPagination').empty().append('<li class="page-item disabled"><a class="page-link" href="#"><i class="fas fa-check mr-1"></i>Showing All ' + tableRows.length + ' Records</a></li>');
            });

            // ===== ADD =====
            $('#btnAddSave').on('click', function () {
                var name = $('#addCategoryName').val().trim();
                if (!name) { $('#msgAddValidation').text('Please enter Category Name'); return; }
                $('#msgAddValidation').text('');

                $.post('@Url.Action("Save", "ExpenseCategory")', { Category_Name: name })
                    .done(function (r) {
                        if (r.toLowerCase() === 'success') {
                            Swal.fire({ icon: 'success', title: 'Success!', text: 'Category added successfully!', confirmButtonColor: 'var(--primary)' })
                                .then(function () { location.reload(); });
                        } else { Swal.fire('Error!', r, 'error'); }
                    })
                    .fail(function () { Swal.fire('Error!', 'Failed to add category', 'error'); });
            });

            $('#btnAddReset').click(function () { $('#addCategoryName').val(''); $('#msgAddValidation').text(''); });

            // ===== EDIT LOAD =====
            $(document).on('click', '.edit-btn', function () {
                var id = $(this).data('id');
                $.get('@Url.Action("GetExpenseCategory", "ExpenseCategory")', { category_ID: id })
                    .done(function (data) {
                        $('#editCategoryId').val(getVal(data, 'Category_ID'));
                        $('#editCategoryName').val(getVal(data, 'Category_Name'));
                        $('#editModal').modal('show');
                    })
                    .fail(function () { Swal.fire('Error!', 'Error loading category data', 'error'); });
            });

            // ===== EDIT SAVE =====
            $('#btnEditSave').on('click', function () {
                var name = $('#editCategoryName').val().trim();
                if (!name) { $('#msgEditValidation').text('Please enter Category Name'); return; }
                $('#msgEditValidation').text('');
                var id = $('#editCategoryId').val();

                $.ajax({
                    type: 'POST', url: '@Url.Action("Edit", "ExpenseCategory")',
                    data: { Category_ID: id, Category_Name: name },
                    success: function (r) {
                        Swal.fire({ icon: 'success', title: 'Updated!', text: 'Category updated successfully!', confirmButtonColor: 'var(--primary)' })
                            .then(function () { location.reload(); });
                    },
                    error: function () { Swal.fire('Error!', 'Update failed', 'error'); }
                });
            });

            $('#btnEditReset').click(function () { $('#editCategoryName').val(''); $('#msgEditValidation').text(''); });

            // ===== VIEW =====
            $(document).on('click', '.view-btn', function () {
                var id = $(this).data('id');
                $.get('@Url.Action("GetExpenseCategory", "ExpenseCategory")', { category_ID: id })
                    .done(function (data) {
                        $('#viewCategoryName').text(getVal(data, 'Category_Name') || 'N/A');
                        $('#viewCategoryId').text(getVal(data, 'Category_ID') || 'N/A');
                        $('#viewCreatedBy').text(getVal(data, 'Created_By') || 'N/A');
                        $('#viewCreatedDate').text(formatDate(getVal(data, 'Created_Date')));
                        $('#viewUpdatedBy').text(getVal(data, 'Updated_By') || 'N/A');
                        $('#viewUpdatedDate').text(formatDate(getVal(data, 'Updated_Date')));
                        $('#viewModal').modal('show');
                    })
                    .fail(function () { Swal.fire('Error!', 'Error loading details', 'error'); });
            });

            // ===== DELETE =====
            $(document).on('click', '.delete-btn', function () {
                var id   = $(this).data('id');
                var name = $(this).closest('tr').find('td:first strong').text().trim();
                $('#deleteCategoryId').val(id);
                $('#deleteCategoryName').text(name);
                $('#deleteModal').modal('show');
            });

            $('#confirmDeleteBtn').on('click', function () {
                var id = $('#deleteCategoryId').val();
                $.get('@Url.Action("DeleteExpenseCategory", "ExpenseCategory")', { category_ID: id })
                    .done(function (r) {
                        r = r.toString().trim().replace(/"/g, '');
                        if (r === '1' || r.toLowerCase() === 'success') {
                            Swal.fire({ icon: 'success', title: 'Deleted!', text: 'Category deleted successfully!', confirmButtonColor: 'var(--primary)' })
                                .then(function () { location.reload(); });
                        } else { Swal.fire('Error!', 'Delete failed: ' + r, 'error'); }
                    })
                    .fail(function () { Swal.fire('Error!', 'Error deleting category', 'error'); });
            });

            // ===== MODAL RESET ON CLOSE =====
            $('#addModal, #editModal, #deleteModal, #viewModal').on('hidden.bs.modal', function () {
                $(this).find('.form-control-modern').val('');
                $('#msgAddValidation, #msgEditValidation').text('');
                $('#deleteCategoryId, #editCategoryId').val('');
                $('#deleteCategoryName').text('');
            });

            // ===== REAL-TIME VALIDATION =====
            $('#addCategoryName, #editCategoryName').on('input', function () {
                var msgId = $(this).attr('id') === 'addCategoryName' ? '#msgAddValidation' : '#msgEditValidation';
                if ($(this).val().trim() !== '') { $(msgId).text(''); }
            });

            setupPagination();
            console.log('✅ All features initialized!');
        });
    </script>
}