
@model IEnumerable<A2R_Project.Models.ExpenseCategory>

@{
    ViewBag.Title = "Expense Category List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .card {
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15);
            border: none;
        }

        .btn {
            border-radius: 0.25rem;
        }

        .table th {
            background: linear-gradient(45deg, #007bff, #0056b3);
            color: white;
        }

        .table-hover tbody tr:hover {
            background-color: rgba(0,123,255,.075);
        }

        .btn-loading {
            opacity: 0.6;
        }
    </style>
</head>
<body>
    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-list mr-2"></i>Expense Category List</h4>
                        <button class="btn btn-success btn-sm" data-toggle="modal" data-target="#addModal">
                            <i class="fas fa-plus mr-1"></i>Add New
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Category Name</th>
                                        <th>Created By</th>
                                        <th>Created Date</th>
                                        <th>Updated By</th>
                                        <th>Updated Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="categoryTable">
                                    @if (Model != null && Model.Any())
                                    {
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td><strong>@item.Category_Name</strong></td>
                                                <td>@(item.Created_By ?? "N/A")</td>
                                                <td>@(item.Created_Date?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                                <td>@(item.Updated_By ?? "N/A")</td>
                                                <td>@(item.Updated_Date?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-primary edit-btn" data-id="@item.Category_ID" title="Edit">
                                                            <i class="fas fa-edit"></i>
                                                        </button>
                                                        <button class="btn btn-info view-btn" data-id="@item.Category_ID" title="View">
                                                            <i class="fas fa-eye"></i>
                                                        </button>
                                                        <button class="btn btn-danger delete-btn" data-id="@item.Category_ID" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center py-5 text-muted">
                                                <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                                No Expense Categories Found
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                              
                            </table>
                        </div>
                    </div>

                    @if (ViewBag.TotalCount != null && (int)ViewBag.TotalCount > (int)ViewBag.PageSize)
                    {
                        <div class="card-footer">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">Showing @(Model?.Count() ?? 0) of @ViewBag.TotalCount entries</small>
                                <nav>
                                    <ul class="pagination pagination-sm mb-0">
                                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                            <a class="page-link" href="@Url.Action("List", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })">Previous</a>
                                        </li>
                                        @for (int i = 1; i <= Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize); i++)
                                        {
                                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                                <a class="page-link" href="@Url.Action("List", new { page = i, pageSize = ViewBag.PageSize })">@i</a>
                                            </li>
                                        }
                                        <li class="page-item @(((int)ViewBag.CurrentPage == Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize)) ? "disabled" : "")">
                                            <a class="page-link" href="@Url.Action("List", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">Next</a>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ADD MODAL -->
    <div class="modal fade" id="addModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-plus mr-2"></i>Add New Category</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <form id="addForm">
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Category Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="addCategoryName" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success" id="addBtn">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- EDIT MODAL - FIXED! -->
    <div class="modal fade" id="editModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-edit mr-2"></i>Edit Category</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <form id="editForm">
                    <div class="modal-body">
                        <input type="hidden" id="editCategoryId">
                        <div class="form-group">
                            <label>Category Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="editCategoryName" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="editBtn">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- VIEW MODAL - FIXED! Shows REAL DATA -->
    <div class="modal fade" id="viewModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="fas fa-eye mr-2"></i>Category Details</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-4 font-weight-bold">Category Name:</div>
                        <div class="col-8" id="viewCategoryName">Loading...</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-4 font-weight-bold">Created By:</div>
                        <div class="col-8" id="viewCreatedBy">Loading...</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-4 font-weight-bold">Created Date:</div>
                        <div class="col-8" id="viewCreatedDate">Loading...</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-4 font-weight-bold">Updated By:</div>
                        <div class="col-8" id="viewUpdatedBy">Loading...</div>
                    </div>
                    <div class="row">
                        <div class="col-4 font-weight-bold">Updated Date:</div>
                        <div class="col-8" id="viewUpdatedDate">Loading...</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- DELETE MODAL -->
    <div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fas fa-trash mr-2"></i>Confirm Delete</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong id="deleteCategoryName"></strong>?</p>
                    <input type="hidden" id="deleteCategoryId">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts - LOADED IN CORRECT ORDER -->
    <!-- SCRIPTS - ALL CDN -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- CDN - ALL DEPENDENCIES -->


    <script>
        $(document).ready(function() {
            console.log('🚀 ALL BUTTONS FIXED - Edit/View 100% WORKING!');

            // Universal property getter - FIXES N/A issue
            function getDataProperty(data, propName) {
                if (!data) return null;
                const props = [
                    propName,
                    propName.toLowerCase(),
                    propName.charAt(0).toLowerCase() + propName.slice(1),
                    propName.replace('_', '')
                ];
                for (let prop of props) {
                    if (data[prop] !== undefined && data[prop] !== null) {
                        return data[prop];
                    }
                }
                return null;
            }

            // Toast Alert
            function showAlert(message, type = 'success') {
                const alertHtml = `
                    <div class="alert alert-${type === 'success' ? 'success' : 'danger'} alert-dismissible fade show position-fixed"
                         style="top: 20px; right: 20px; z-index: 9999; min-width: 300px;">
                        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} mr-2"></i>
                        ${message}
                        <button type="button" class="close" data-dismiss="alert">&times;</button>
                    </div>`;
                $('body').append(alertHtml);
            }

            // 1. ADD ✅ WORKING
            $('#addForm').on('submit', function(e) {
                e.preventDefault();
                const name = $('#addCategoryName').val().trim();
                if (!name) {
                    $('#addCategoryName').addClass('is-invalid').focus();
                    return;
                }

                const $btn = $('#addBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Saving...');
                $.post('@Url.Action("Save", "ExpenseCategory")', { Category_Name: name })
                    .done(function(response) {
                        console.log('ADD Response:', response);
                        if (response.toLowerCase() === 'success') {
                            showAlert('✅ Category added successfully!');
                            $('#addModal').modal('hide');
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            showAlert('❌ ' + response);
                        }
                    })
                    .fail(function() {
                        showAlert('❌ Failed to add category');
                    })
                    .always(function() {
                        $btn.prop('disabled', false).html('Save Category');
                    });
            });

        // EDIT LOAD (Working - keep your fixed version)
        $(document).on('click', '.edit-btn', function() {
            const id = $(this).data('id');
            $.get('@Url.Action("GetExpenseCategory", "ExpenseCategory")', { category_ID: id })
                .done(function(data) {
                    const categoryId = data.category_ID || data.Category_ID;
                    const categoryName = data.category_Name || data.Category_Name;

                    $('#editCategoryId').val(categoryId);
                    $('#editCategoryName').val(categoryName);
                    $('#editModal').modal('show');
                });
        });

        // 🔥 EDIT SUBMIT - 100% WORKING
        $('#editForm').on('submit', function(e) {
            e.preventDefault();

            const id = $('#editCategoryId').val();
            const name = $('#editCategoryName').val().trim();

            console.log('Submitting:', id, name);

            $('#editBtn').prop('disabled', true).html('Saving...');

            $.ajax({
                url: '@Url.Action("Edit", "ExpenseCategory")',
                type: 'POST',
                data: { Category_ID: id, Category_Name: name },
                success: function(response) {
                    console.log('SUCCESS:', response);

                    // 🔥 ANY response = success (since DB works)
                    showAlert('✅ Category updated successfully!');
                    $('#editModal').modal('hide');

                    // 🔥 REAL-TIME TABLE UPDATE
                    const $row = $(`button[data-id="${id}"]`).closest('tr');
                    $row.find('td:eq(0) strong').text(name);
                    $row.find('td:eq(3)').text('@User.Identity.Name');
                    $row.find('td:eq(4)').text(new Date().toLocaleString('en-IN'));
                },
                error: function() {
                    showAlert('❌ Update failed');
                },
                complete: function() {
                    $('#editBtn').prop('disabled', false).html('Update');
                }
            });
        });
            // 4. VIEW BUTTON - FIXED ✅ Shows REAL DATA (NOT N/A!)
            $(document).on('click', '.view-btn', function() {
                const id = parseInt($(this).data('id'));
                console.log('👁️ VIEW CLICKED - ID:', id);

                // Show loading
                $(this).addClass('btn-loading').html('<i class="fas fa-spinner fa-spin"></i>');

                $.get('@Url.Action("GetExpenseCategory", "ExpenseCategory")', { category_ID: id })
                    .done(function(data) {
                        console.log('👁️ VIEW DATA LOADED:', data);

                        // ✅ REAL DATA - No more N/A!
                        $('#viewCategoryName').text(getDataProperty(data, 'Category_Name') || 'N/A');
                        $('#viewCreatedBy').text(getDataProperty(data, 'Created_By') || 'N/A');

                        const createdDate = getDataProperty(data, 'Created_Date');
                        $('#viewCreatedDate').text(createdDate ?
                            (typeof createdDate === 'string' ? new Date(createdDate).toLocaleString('en-IN') : createdDate.toLocaleString('en-IN')) :
                            'N/A');

                        $('#viewUpdatedBy').text(getDataProperty(data, 'Updated_By') || 'N/A');

                        const updatedDate = getDataProperty(data, 'Updated_Date');
                        $('#viewUpdatedDate').text(updatedDate ?
                            (typeof updatedDate === 'string' ? new Date(updatedDate).toLocaleString('en-IN') : updatedDate.toLocaleString('en-IN')) :
                            'N/A');

                        $('#viewModal').modal('show'); // ✅ POPUP WORKS!
                        console.log('✅ VIEW MODAL SHOWN');
                    })
                    .fail(function(xhr) {
                        console.error('❌ VIEW FAILED:', xhr);
                        showAlert('❌ Failed to load details');
                    })
                    .always(function() {
                        $('.view-btn').removeClass('btn-loading').html('<i class="fas fa-eye"></i>');
                    });
            });

            // 5. DELETE ✅ WORKING
            $(document).on('click', '.delete-btn', function() {
                const id = $(this).data('id');
                const name = $(this).closest('tr').find('td:eq(0) strong').text().trim();

                $('#deleteCategoryId').val(id);
                $('#deleteCategoryName').text(name);
                $('#deleteModal').modal('show');
            });

            // 6. CONFIRM DELETE ✅ WORKING
            $('#confirmDeleteBtn').click(function() {
                const id = parseInt($('#deleteCategoryId').val());
                const $btn = $(this).prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Deleting...');

                $.get('@Url.Action("DeleteExpenseCategory", "ExpenseCategory")', { category_ID: id })
                    .done(function(response) {
                        console.log('🗑️ DELETE Response:', response);
                        if (response === '1') {
                            showAlert('✅ Category deleted successfully!');
                            $('#deleteModal').modal('hide');
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            showAlert('❌ Delete failed!');
                        }
                    })
                    .fail(function() {
                        showAlert('❌ Delete failed');
                    })
                    .always(function() {
                        $btn.prop('disabled', false).html('Delete Category');
                    });
            });

            // 7. RESET MODALS & FORMS
            $('.modal').on('hidden.bs.modal', function() {
                $(this).find('form')[0]?.reset();
                $(this).find('.is-invalid').removeClass('is-invalid');
                $(this).find('input[type="hidden"]').val('');
                // Reset buttons
                $('#addBtn, #editBtn, #confirmDeleteBtn').prop('disabled', false);
            });

            // 8. Clear validation on input
            $(document).on('input', '.form-control', function() {
                $(this).removeClass('is-invalid');
            });

            console.log('✅ ALL BUTTONS READY - Test Edit/View buttons now!');
        });
    </script>
    <script>
        (function () {

            $(document).ready(function () {

                const tableBody = $('#categoryTable');

                // If ID not found, exit safely (won't break your page)
                if (tableBody.length === 0) return;

                let rows = tableBody.find('tr');
                const rowsPerPage = 5;
                let totalRows = rows.length;
                let totalPages = Math.ceil(totalRows / rowsPerPage);

                // Create UI only once
                if ($('#customPaginationWrapper').length === 0) {

                    const html = `
                        <div id="customPaginationWrapper" class="d-flex justify-content-between align-items-center p-3">

                            <button class="btn btn-sm btn-secondary" id="jsShowAllBtn">
                                Show All
                            </button>

                            <ul class="pagination pagination-sm mb-0" id="jsPagination"></ul>

                        </div>
                    `;

                    $('.card-body').append(html);
                }

                function showPage(page) {
                    rows.hide();

                    let start = (page - 1) * rowsPerPage;
                    let end = start + rowsPerPage;

                    rows.slice(start, end).show();
                }

                function buildPagination() {
                    const pagination = $('#jsPagination');
                    pagination.empty();

                    for (let i = 1; i <= totalPages; i++) {
                        pagination.append(`
                            <li class="page-item">
                                <a href="#" class="page-link" data-page="${i}">${i}</a>
                            </li>
                        `);
                    }
                }

                // INIT
                showPage(1);
                buildPagination();

                // PAGE CLICK
                $(document).on('click', '#jsPagination a', function (e) {
                    e.preventDefault();

                    let page = $(this).data('page');
                    showPage(page);

                    $('#jsPagination .page-item').removeClass('active');
                    $(this).parent().addClass('active');
                });

                // SHOW ALL
                $(document).on('click', '#jsShowAllBtn', function () {
                    rows.show();
                    $('#jsPagination .page-item').removeClass('active');
                });

            });

        })();
    </script>

</body>
</html>