    }

    #addModal .modal-footer, #editModal .modal-footer {
        padding: 15px 25px;
    }

    #viewModal .modal-dialog {
        max-width: 500px !important;
    }

    .view-row {
        display: flex;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
        gap: 16px;
    }

        .view-row.last {
            border-bottom: none;
        }

    .view-label {
        width: 140px;
        font-size: 13px;
        font-weight: 700;
        color: #374151;
