@model A2R_Project.Models.ExpenseViewModel
@{
    ViewBag.Title = "Expense List";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/@@mdi/font@6.5.95/css/materialdesignicons.min.css" rel="stylesheet">

<style>

    /* ================= GLOBAL ================= */
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fbff);
        font-family: 'Segoe UI', sans-serif;
    }

    /* ================= CARD ================= */
    .card {
        border-radius: 16px;
        border: none;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-3px);
        }

    /* ================= TABLE ================= */
    .table {
        border-radius: 12px;
        overflow: hidden;
        background: #ffffff;
    }

        .table thead {
            background: linear-gradient(45deg, #4f46e5, #6366f1);
            color: #fff;
            font-weight: 600;
        }

        .table th {
            border: none !important;
            padding: 14px;
        }

        .table td {
            border: none !important;
            padding: 12px;
            font-weight: 500;
            color: #333;
        }

        /* Row hover animation */
        .table tbody tr {
            transition: all 0.25s ease-in-out;
        }

            .table tbody tr:hover {
                background: #eef2ff;
                transform: scale(1.01);
                box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            }

            /* Alternate row color */
            .table tbody tr:nth-child(even) {
                background: #f9fbff;
            }

    /* ================= BADGES ================= */
    .badge-success {
        background: linear-gradient(45deg, #22c55e, #16a34a);
        padding: 6px 10px;
        border-radius: 20px;
    }

    .badge-danger {
        background: linear-gradient(45deg, #ef4444, #dc2626);
        padding: 6px 10px;
        border-radius: 20px;
    }

    /* ================= BUTTONS ================= */
    .btn {
        border-radius: 25px !important;
        transition: all 0.3s ease;
        font-weight: 500;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(0,0,0,0.15);
        }

    /* Action buttons */
    .btn-sm {
        padding: 6px 10px;
    }

    /* ================= INPUT FIELDS ================= */
    .form-control,
    textarea,
    select {
        border-radius: 10px;
        border: 1px solid #d1d5db;
        padding: 10px;
        font-weight: 600;
        color: #111 !important;
        transition: all 0.3s ease;
    }

        /* Focus effect */
        .form-control:focus,
        textarea:focus,
        select:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
            outline: none;
        }

    /* Labels */
    label {
        font-weight: 600;
        color: #222;
    }

    /* ================= MODAL ================= */
    .modal-content {
        border-radius: 16px;
        border: none;
        animation: fadeInScale 0.3s ease;
    }

    .modal-header {
        background: linear-gradient(45deg, #6366f1, #4f46e5);
        color: white;
        border-top-left-radius: 16px;
        border-top-right-radius: 16px;
    }

    .modal-title {
        font-weight: 600;
    }

    .modal-footer {
        border-top: none;
    }

    /* Modal animation */
    @@keyframes fadeInScale {
        from {
            opacity: 0;
            transform: scale(0.9);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* ================= IMAGE PREVIEW ================= */
    img {
        border-radius: 10px;
        border: 1px solid #ddd;
        transition: 0.3s;
    }

        img:hover {
            transform: scale(1.05);
        }

    /* ================= PAGINATION ================= */
    .pagination .page-link {
        border-radius: 8px;
        margin: 0 3px;
        color: #4f46e5;
        font-weight: 500;
    }

    .pagination .active .page-link {
        background: #4f46e5;
        color: #fff;
    }

    /* ================= RESPONSIVE ================= */
    @@media (max-width: 768px) {
        .table th, .table td {
            font-size: 12px;
            padding: 8px;
        }

        .modal-dialog {
            max-width: 95%;
        }

        .btn {
            font-size: 12px;
            padding: 6px 10px;
        }
    }
    /* ROUND ICON BUTTONS */
    .btn-course-list {
        width: 38px;
        height: 38px;
        border-radius: 50% !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    /* COLORS */
    .btn-gradient-primary {
        background: linear-gradient(45deg, #6366f1, #4f46e5);
        color: white;
    }

    .btn-gradient-dark {
        background: linear-gradient(45deg, #111827, #374151);
        color: white;
    }

    .btn-gradient-warning {
        background: linear-gradient(45deg, #f59e0b, #d97706);
        color: white;
    }

    /* HOVER */
    .btn:hover {
        transform: translateY(-3px) scale(1.08);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }
    /* BIG MODAL SIZE */
    #addExpense .modal-dialog,
    #editExpense .modal-dialog {
        max-width: 950px;
        width: 95%;
    }

    /* AUTO HEIGHT */
    #addExpense .modal-content,
    #editExpense .modal-content {
        height: auto !important;
        min-height: 520px;
    }
    /* HEADER - YELLOW GRADIENT */
    #addExpense .modal-header,
    #editExpense .modal-header {
        background: linear-gradient(45deg, #facc15, #eab308);
        color: #222;
        border-top-left-radius: 16px;
        border-top-right-radius: 16px;
    }

    /* BODY BACKGROUND */
    #addExpense .modal-body,
    #editExpense .modal-body {
        background: #fffdf5;
    }

    /* LABEL COLOR */
    #addExpense label,
    #editExpense label {
        color: #92400e;
        font-weight: 600;
    }
    /* INPUT STYLE */
    #addExpense .form-control,
    #editExpense .form-control,
    #addExpense select,
    #editExpense select {
        border-radius: 10px;
        border: 1px solid #fcd34d;
        font-weight: 600;
        color: #111;
    }

        /* FOCUS EFFECT */
        #addExpense .form-control:focus,
        #editExpense .form-control:focus,
        #addExpense select:focus,
        #editExpense select:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(251,191,36,0.3);
        }
    /* SUBMIT BUTTON */
    #btnExpenseSave,
    #btnExpenseUpdate {
        background: linear-gradient(45deg, #facc15, #f59e0b);
        color: #222;
        border-radius: 25px;
        font-weight: 600;
    }

    /* RESET BUTTON */
    .btnExpenseReset {
        background: linear-gradient(45deg, #fde68a, #fcd34d);
        color: #222;
    }

    /* CLOSE BUTTON */
    .btnClose {
        background: #f3f4f6;
        color: #333;
    }

    /* HOVER EFFECT */
    #btnExpenseSave:hover,
    #btnExpenseUpdate:hover,
    .btnExpenseReset:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 18px rgba(0,0,0,0.15);
    }
    /* POPUP BUTTON COMMON */
    .modal-footer .btn {
        border-radius: 30px !important;
        font-weight: 600;
        padding: 8px 18px;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
    }

    /* SUBMIT (YELLOW PRIMARY) */
    #btnExpenseSave,
    #btnExpenseUpdate {
        background: linear-gradient(45deg, #facc15, #f59e0b);
        color: #222;
        border: none;
    }

    /* RESET */
    .btnExpenseReset {
        background: linear-gradient(45deg, #fde68a, #fcd34d);
        color: #333;
        border: none;
    }

    /* CLOSE */
    .btnClose {
        background: #e5e7eb;
        color: #333;
        border: none;
    }

    /* DELETE BUTTON */
    #btnExpenseDelete {
        background: linear-gradient(45deg, #ef4444, #dc2626);
        color: #fff;
    }

    /* HOVER EFFECT */
    .modal-footer .btn:hover {
        transform: translateY(-2px) scale(1.05);
        box-shadow: 0 8px 18px rgba(0,0,0,0.2);
    }

    /* CLICK EFFECT */
    .modal-footer .btn:active {
        transform: scale(0.95);
    }
    /* IMAGE CONTAINER FIXED SIZE */
    #Add_Expense_Proof_Preview,
    #Edit_Expense_Proof_Preview,
    #View_Expense_Proof {
        width: 100%;
        height: 150px;
        object-fit: cover; /* crop nicely */
        border-radius: 12px;
        border: 2px solid #fcd34d;
        background: #fff;
    }

    /* IMAGE BOX WRAPPER (OPTIONAL BUT BEST) */
    .image-box {
        width: 100%;
        height: 150px;
        overflow: hidden;
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 5px 12px rgba(0,0,0,0.1);
    }

        /* HOVER EFFECT */
        .image-box img:hover {
            transform: scale(1.08);
            transition: 0.3s;
        }

    #editExpense .modal-header {
        background: linear-gradient(45deg, #22c55e, #16a34a);
        color: #fff;
    }

    #editExpense .modal-body {
        background: #f0fdf4;
    }

    /* Inputs */
    #editExpense .form-control,
    #editExpense select {
        border: 1px solid #86efac;
        background: #ffffff;
    }

        #editExpense .form-control:focus,
        #editExpense select:focus {
            border-color: #22c55e;
            box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
        }

    /* Labels */
    #editExpense label {
        color: #166534;
    }

    #viewExpense .modal-header {
        background: linear-gradient(45deg, #8b5cf6, #6d28d9);
        color: #fff;
    }

    #viewExpense .modal-body {
        background: #faf5ff;
    }

    /* Text */
    #viewExpense label {
        color: #4c1d95;
        font-weight: 600;
    }

    /* Image border */
    #View_Expense_Proof {
        border: 2px solid #c4b5fd;
    }

    #deleteExpense .modal-header {
        background: linear-gradient(45deg, #ef4444, #dc2626);
        color: #fff;
    }

    #deleteExpense .modal-body {
        background: #fef2f2;
    }

    /* Text */
    #deleteExpense label {
        color: #7f1d1d;
        font-weight: 600;
    }

    #deleteExpense .modal-dialog {
        max-width: 400px;
        width: 90%;
    }

    #deleteExpense .modal-content {
        border-radius: 18px;
        text-align: center;
        padding: 10px;
    }

    #deleteExpense .modal-dialog {
        max-width: 566px;
        width: 95%;
    }
    /* Remove extra gap */
    #deleteExpense p {
        margin-bottom: 6px;
        font-size: 14px;
        color: #444;
    }

    /* Expense title (field name) tight + highlight */
    #Delete_Expense_Title {
        display: inline; /* keeps it inline with sentence */
        margin-left: 4px; /* small gap only */
        color: #dc2626;
        font-weight: 700;
    }

    #deleteExpense .form-group {
        margin-bottom: 5px;
    }

    #deleteExpense label {
        margin-bottom: 0;
    }

    .error-text {
        font-size: 12px;
        margin-top: 3px;
        display: block;
        color: red;
    }

    .is-invalid {
        border-color: #ef4444 !important;
    }

</style>
<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Expense List</strong>
                <button type="button" class="btn btn-gradient-primary btn-rounded btn-fw" data-toggle="modal" data-target="#addExpense">
                    <i class="fa fa-plus"></i> Add
                </button>
            </div>

            <!-- Table with ID for ShowAll functionality -->
            <table id="expenseTable" class="table table-bordered">
                <thead>
                    <tr>
                        <th>Expense Title</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.expenses != null && Model.expenses.Any())
                    {
                        foreach (var expense in Model.expenses)
                        {
                            <tr>
                                <td>@expense.Expense_Title</td>
                                <td>@expense.Category_Name</td>
                                <td>@expense.Expense_Amount</td>
                                <td>@expense.Expense_Date?.ToString("dd-MM-yyyy")</td>
                                <td>
                                    @if (expense.IsActive == 1)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <!-- ✅ FIXED - NO SINGLE QUOTES -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-primary btn-rounded btn-course-list editExpenseByID"
                                            data-edexpenseId="@expense.Expense_ID" title="Edit" data-toggle="modal" data-target="#editExpense">
                                        <i class="mdi mdi-pencil"></i>
                                    </button>
                                    <!-- ✅ FIXED - NO SINGLE QUOTES -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-dark btn-rounded btn-course-list viewExpenseId"
                                            data-vwexpenseId="@expense.Expense_ID" title="View" data-toggle="modal" data-target="#viewExpense">
                                        <i class="mdi mdi-eye"></i>
                                    </button>
                                    <!-- ✅ FIXED - NO SINGLE QUOTES -->
                                    <button type="button" class="btn btn-sm btn-custom btn-gradient-warning btn-rounded btn-course-list deleteExpenses"
                                            data-dltexpenseId="@expense.Expense_ID" title="Delete" data-toggle="modal" data-target="#deleteExpense">
                                        <i class="mdi mdi-delete"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">No expenses found</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (ViewBag.ShowAllButton == true)
            {
                <div class="row">
                    <div class="col text-right">
                        <button type="button" id="showAllButton" class="btn btn-primary">Show All</button>
                    </div>
                </div>
            }

            @if (ViewBag.TotalCount != null && ViewBag.TotalCount > ViewBag.PageSize)
            {
                <div class="row">
                    <div class="col">
                        <nav aria-label="Page navigation">
                            <ul id="pagination" class="pagination">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("List", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })" tabindex="-1">Previous</a>
                                </li>
                                @for (int i = 1; i <= Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize); i++)
                                {
                                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("List", new { page = i, pageSize = ViewBag.PageSize })">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.CurrentPage == Math.Ceiling((double)ViewBag.TotalCount / ViewBag.PageSize) ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("List", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">Next</a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Add Expense Modal -->
<div class="modal fade" id="addExpense" tabindex="-1" role="dialog" aria-labelledby="addExpenseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" style="height: 348px;width: 824px;">
            <div class="modal-header">
                <h5 class="modal-title" id="addExpenseModalLabel">Add Expense</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="addExpenseForm" class="form-sample" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Expense_Title">Expense Title</label>
                                <input type="text" class="form-control" id="Expense_Title" name="Expense_Title" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Category_ID">Category</label>
                                <div style="position: relative; flex: 1;">
                                    <select class="form-control" id="Category_ID" name="Category_ID">
                                        <option value="">Select Category</option>
                                        @if (Model.expenseCategory != null)
                                        {
                                            @foreach (var category in Model.expenseCategory)
                                            {
                                                <option value="@category.Category_ID">@category.Category_Name</option>
                                            }
                                        }
                                    </select>
                                    <span class="input-group-text" style="position: absolute; right: 0; top: 0; bottom: 0; display: flex; align-items: center; padding: 0 10px;">
                                        <i class="mdi mdi-menu-down"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Expense_Amount">Amount</label>
                                <input type="text" class="form-control" id="Expense_Amount" name="Expense_Amount" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Expense_Date">Date</label>
                                <input type="date" class="form-control" id="Expense_Date" name="Expense_Date" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Invoice_Id">Invoice ID</label>
                                <input type="text" class="form-control" id="Invoice_Id" name="Invoice_Id" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="Expense_Proof">Proof</label>
                                <input type="file" class="form-control-file" id="Add_Expense_Proof" name="Expense_Proof" accept="image/*" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <img id="Add_Expense_Proof_Preview" src="~/images/bird.jpg" alt="Preview" style="max-width: 100px; max-height: 100px;" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Expense_Remark">Remark</label>
                                <textarea class="form-control" id="Expense_Remark" name="Expense_Remark" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input rounded-checkbox" id="chkActiveStatusAdd" checked>
                                <label class="form-check-label" for="chkActiveStatusAdd">Status</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-gradient-warning btn-rounded btn-fw btnClose" data-dismiss="modal">Close</button>
               
                <button type="button" class="btn btn-gradient-info btn-rounded btn-fw" id="btnExpenseSave">Submit</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Expense Modal -->
<div class="modal fade" id="editExpense" tabindex="-1" role="dialog" aria-labelledby="editExpenseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" style="height: 348px;width: 824px;">
            <div class="modal-header">
                <h5 class="modal-title" id="editExpenseModalLabel">Edit Expense</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="editExpenseForm" class="form-sample">
                    <input type="hidden" id="hdnExpenseId" name="expense_ID">
                    <input type="hidden" id="hdnExpenseProofId" name="expenseImagId">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Edit_Expense_Title">Expense Title</label>
                                <input type="text" class="form-control" id="Edit_Expense_Title" name="Edit_Expense_Title" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Edit_Category_ID">Category</label>
                                <div style="position: relative; flex: 1;">
                                    <select class="form-control" id="Edit_Category_ID" name="Edit_Category_ID">
                                        <option value="">Select Category</option>
                                        @if (Model.expenseCategory != null)
                                        {
                                            @foreach (var category in Model.expenseCategory)
                                            {
                                                <option value="@category.Category_ID">@category.Category_Name</option>
                                            }
                                        }
                                    </select>
                                    <span class="input-group-text" style="position: absolute; right: 0; top: 0; bottom: 0; display: flex; align-items: center; padding: 0 10px;">
                                        <i class="mdi mdi-menu-down"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Edit_Expense_Amount">Amount</label>
                                <input type="text" class="form-control" id="Edit_Expense_Amount" name="Edit_Expense_Amount" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Edit_Expense_Date">Date</label>
                                <input type="date" class="form-control" id="Edit_Expense_Date" name="Edit_Expense_Date" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Invoice_IdEdit">Invoice ID</label>
                                <input type="text" class="form-control" id="Invoice_IdEdit" name="Invoice_IdEdit" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="Edit_Expense_Proof">Proof</label>
                                <input type="file" class="form-control-file" id="Edit_Expense_Proof" name="Edit_Expense_Proof" accept="image/*" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <img id="Edit_Expense_Proof_Preview" src="~/images/bird.jpg" alt="Preview" style="max-width: 100px; max-height: 100px;" />
                        </div>
