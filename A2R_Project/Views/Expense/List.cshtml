<!-- SCRIPTS - ALL CDN -->
<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<!-- CDN - ALL DEPENDENCIES -->



<script>
    $(document).ready(function() {
        console.log("🚀 ✅ PERFECT SCRIPT - Handles ALL cases!");

        function reloadPage() { setTimeout(() => location.reload(), 1000); }
        function showLoader($btn, text = "Loading...") { $btn.prop('disabled', true).html(`<i class="fa fa-spinner fa-spin mr-1"></i>${text}`); }
        function hideLoader($btn, originalHtml) { $btn.prop('disabled', false).html(originalHtml); }

        function resetForm(formId) {
            $(formId)[0].reset();
            $(formId).find('input[type="checkbox"]').prop('checked', true);
            $(formId).find('img').attr('src', '~/images/bird.jpg');
            $(formId).find('select').val('');
        }

        function getImageUrl(path) { return path && path.trim() ? path : '~/images/bird.jpg'; }

        // File Preview
        $(document).on('change', 'input[type="file"]', function() {
            const id = $(this).attr('id');
            const previewId = id === 'Add_Expense_Proof' ? '#Add_Expense_Proof_Preview' : '#Edit_Expense_Proof_Preview';
            if (this.files[0] && previewId) {
                const reader = new FileReader();
                reader.onload = e => $(previewId).attr('src', e.target.result);
                reader.readAsDataURL(this.files[0]);
            }
        });

        // ADD
        $('#btnExpenseSave').click(function(e) {
            e.preventDefault();
            saveExpense('@Url.Action("Save", "Expense")', '#addExpenseForm', '#addExpense', this);
        });

        // VIEW - ✅ FIXED for ID=0 issue
        $(document).on('click', '.viewExpenseId', function(e) {
            e.preventDefault();
            const expenseID = $(this).data('vwexpenseid');
            const $btn = $(this);
            const originalHtml = $btn.html();

            console.log(`👁️ VIEW BUTTON ID: ${expenseID}`); // DEBUG

            showLoader($btn);
            $.ajax({
                url: '@Url.Action("GetExpense", "Expense")',
                type: 'GET',
                data: { expense_ID: expenseID },
                success: function(data) {
                    console.log("✅ VIEW DATA:", data);

                    // ✅ CHECK DATA EXISTS (even if ID=0)
                    if (data && (data.expense_Title || data.Expense_Title)) {
                        $('#lblvwExpenseTitle').text(data.expense_Title || data.Expense_Title || 'N/A');
                        $('#lblvwCategoryName').text(data.category_Name || data.Category_Name || 'N/A');
                        $('#lblvwExpenseAmount').text('₹' + Number(data.expense_Amount || data.Expense_Amount || 0).toLocaleString('en-IN'));
                        $('#lblvwInvoiceId').text(data.invoice_Id || data.Invoice_Id || 'N/A');
                        $('#lblvwRemark').text(data.expense_Remark || data.Expense_Remark || 'N/A');

                        const dateVal = data.expense_Date || data.Expense_Date;
                        if (dateVal) {
                            const date = new Date(dateVal);
                            $('#lblvwExpenseDate').text(date.toLocaleDateString('en-IN'));
                        } else {
                            $('#lblvwExpenseDate').text('N/A');
                        }

                        $('#View_Expense_Proof').attr('src', getImageUrl(data.expense_Proof || data.Expense_Proof));
                        $('#viewExpense').modal('show');
                        console.log("✅ VIEW SUCCESS!");
                    } else {
                        console.log("❌ NO DATA FOUND");
                        alert("❌ No expense data!");
                    }
                },
                error: function(xhr) {
                    console.error("❌ VIEW ERROR:", xhr.responseText);
                    alert("View failed!");
                },
                complete: function() {
                    hideLoader($btn, originalHtml);
                }
            });
        });

        // EDIT - ✅ FIXED for ID=0 issue
        $(document).on('click', '.editExpenseByID', function(e) {
            e.preventDefault();
            const expenseID = $(this).data('edexpenseid');
            const $btn = $(this);
            const originalHtml = $btn.html();

            console.log(`✏️ EDIT BUTTON ID: ${expenseID}`); // DEBUG

            showLoader($btn);
            $.ajax({
                url: '@Url.Action("GetExpense", "Expense")',
                type: 'GET',
                data: { expense_ID: expenseID },
                success: function(data) {
                    console.log("✅ EDIT DATA:", data);

                    // ✅ CHECK DATA EXISTS (ignore ID=0)
                    if (data && (data.expense_Title || data.Expense_Title)) {
                        resetForm('#editExpenseForm');

                        $('#hdnExpenseId').val(data.expense_ID || data.Expense_ID || expenseID);
                        $('#Edit_Expense_Title').val(data.expense_Title || data.Expense_Title || '');
                        $('#Edit_Category_ID').val(data.category_ID || data.Category_ID || '');
                        $('#Edit_Expense_Amount').val(data.expense_Amount || data.Expense_Amount || '');
                        $('#Invoice_IdEdit').val(data.invoice_Id || data.Invoice_Id || '');
                        $('#Expense_RemarkEdit').val(data.expense_Remark || data.Expense_Remark || '');
                        $('#hdnExpenseProofId').val(data.expense_Proof || data.Expense_Proof || '');

                        const dateVal = data.expense_Date || data.Expense_Date;
                        if (dateVal) {
                            const date = new Date(dateVal);
                            const year = date.getFullYear();
                            const month = String(date.getMonth() + 1).padStart(2, '0');
                            const day = String(date.getDate()).padStart(2, '0');
                            $('#Edit_Expense_Date').val(`${year}-${month}-${day}`);
                        }

                        $('#Edit_Expense_Proof_Preview').attr('src', getImageUrl(data.expense_Proof || data.Expense_Proof));
                        $('#chkEditActiveStatus').prop('checked', (data.isActive || data.IsActive) == 1);

                        $('#editExpense').modal('show');
                        console.log("✅ EDIT FORM FILLED!");
                    } else {
                        console.log("❌ NO EDIT DATA");
                        alert("❌ No expense data!");
                    }
                },
                error: function(xhr) {
                    console.error("❌ EDIT ERROR:", xhr.responseText);
                    alert("Edit failed!");
                },
                complete: function() {
                    hideLoader($btn, originalHtml);
                }
            });
        });

        // DELETE
        $(document).on('click', '.deleteExpenses', function(e) {
            e.preventDefault();
            const expenseID = $(this).data('dltexpenseid');
            const title = $(this).closest('tr').find('td:eq(0)').text().trim();
            $('#hdndltExpenseId').val(expenseID);
            $('#Delete_Expense_Title').text(title);
            $('#deleteExpense').modal('show');
        });

        $('#btnExpenseDelete').click(function() {
            const expenseID = $('#hdndltExpenseId').val();
            const $btn = $(this);
            const originalHtml = $btn.html();
            showLoader($btn, "Deleting...");

            $.ajax({
                url: '@Url.Action("DeleteExpense", "Expense")',
                type: 'GET',
                data: { expense_ID: expenseID },
                success: function(result) {
                    if (result === "success") {
                        alert("✅ Deleted!");
                        $('#deleteExpense').modal('hide');
                        reloadPage();
                    } else {
                        alert("❌ " + result);
                    }
                },
                complete: function() {
                    hideLoader($btn, originalHtml);
                }
            });
        });

        // SAVE FUNCTION
        function saveExpense(url, formSelector, modalSelector, btnElement) {
            const $btn = $(btnElement);
            const formData = new FormData();
            const isAdd = formSelector === '#addExpenseForm';

            const expenseData = {
                Expense_ID: parseInt($(`${formSelector} #hdnExpenseId`).val()) || 0,
                Category_ID: parseInt($(`${formSelector} select[id*="Category_ID"]`).val()) || null,
                Expense_Title: $(`${formSelector} input[id*="Expense_Title"]`).val().trim() || '',
                Invoice_Id: $(`${formSelector} ${isAdd ? '#Invoice_Id' : '#Invoice_IdEdit'}`).val().trim() || '',
                Expense_Amount: parseFloat($(`${formSelector} input[id*="Expense_Amount"]`).val()) || 0,
                Expense_Date: $(`${formSelector} input[id*="Expense_Date"]`).val() || null,
                Expense_Remark: $(`${formSelector} textarea[id*="Expense_Remark"]`).val().trim() || '',
                IsActive: $(`${formSelector} input[type="checkbox"]`).is(':checked') ? 1 : 0
            };

            if (!isAdd) expenseData.ExistingExpense_Proof = $('#hdnExpenseProofId').val() || '';

            if (!expenseData.Expense_Title || !expenseData.Category_ID) {
                alert("❌ Title & Category required!");
                return;
            }

            formData.append('Expense', JSON.stringify(expenseData));
            const fileId = isAdd ? '#Add_Expense_Proof' : '#Edit_Expense_Proof';
            const fileInput = $(fileId)[0];
            if (fileInput?.files[0]) formData.append('file', fileInput.files[0]);

            showLoader($btn, 'Saving...');
            $.ajax({
                url: url, type: 'POST', data: formData,
                contentType: false, processData: false,
                success: function(result) {
                    if (result.toLowerCase().includes('success')) {
                        alert("✅ Saved!");
                        $(modalSelector).modal('hide');
                        reloadPage();
                    } else {
                        alert("❌ " + result);
                    }
                },
                complete: function() {
                    $btn.prop('disabled', false).html('Submit');
                }
            });
        }

        $('#btnExpenseUpdate').click(function(e) {
            e.preventDefault();
            saveExpense('@Url.Action("Edit", "Expense")', '#editExpenseForm', '#editExpense', this);
        });

        $(document).on('click', '.btnExpenseReset, .btnClose', function() {
            const $modal = $(this).closest('.modal');
            resetForm($modal.find('form'));
            $modal.modal('hide');
        });

        // Show All
        $('#showAllButton').click(function() {
            $.ajax({
                url: '@Url.Action("ShowAll", "Expense")',
                success: function(expenses) {
                    let html = expenses?.length ?
                        expenses.map(e => {
                            const id = e.expense_ID || e.Expense_ID;
                            return `<tr >
                                <td>${e.expense_Title || e.Expense_Title}</td>
                                <td>${e.category_Name || e.Category_Name}</td>
                                <td>${e.expense_Amount || e.Expense_Amount}</td>
                                <td>${new Date(e.expense_Date || e.Expense_Date).toLocaleDateString('en-IN')}</td>
                                <td>${(e.isActive || e.IsActive) == 1 ? '<span class="badge badge-success">Active</span>' : '<span class="badge badge-danger">Inactive</span>'}</td>
                                <td>
                                    <button class="btn btn-sm btn-gradient-primary editExpenseByID" data-edexpenseId="${id}"><i class="mdi mdi-pencil"></i></button>
                                    <button class="btn btn-sm btn-gradient-dark viewExpenseId" data-vwexpenseId="${id}"><i class="mdi mdi-eye"></i></button>
                                    <button class="btn btn-sm btn-gradient-warning deleteExpenses" data-dltexpenseId="${id}"><i class="mdi mdi-delete"></i></button>
                                </td>
                            </tr>`;
                        }).join('') :
                        '<tr><td colspan="6" class="text-center">No expenses</td></tr>';
                    $('#expenseTable tbody').html(html);
                }
            });
        });
            // ADD
 

    // EDIT
    $('#btnExpenseUpdate').click(function (e) {
        e.preventDefault();
        if (!validateExpenseForm('#editExpenseForm')) return;
        saveExpense('@Url.Action("Edit", "Expense")', '#editExpenseForm', '#editExpense', this);
    });
        function validateExpenseForm(formId) {
        let isValid = true;

        // remove old errors
        $(formId + ' .error-text').remove();
        $(formId + ' .form-control').removeClass('is-invalid');

        function showError(input, message) {
            input.addClass('is-invalid');
            input.after('<span class="error-text">' + message + '</span>');
            isValid = false;
        }

        let title = $(formId + ' input[id*="Expense_Title"]');
        let category = $(formId + ' select[id*="Category_ID"]');
        let amount = $(formId + ' input[id*="Expense_Amount"]');
        let date = $(formId + ' input[id*="Expense_Date"]');

        if (!title.val().trim()) {
            showError(title, "Title is required");
        }

        if (!category.val()) {
            showError(category, "Category is required");
        }

        if (!amount.val() || isNaN(amount.val())) {
            showError(amount, "Valid amount required");
        }

        if (!date.val()) {
            showError(date, "Date is required");
        }

        return isValid;
    }
    });
</script>