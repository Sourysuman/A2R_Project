@using A2R_Project.Models
@model IEnumerable<A2R_Project.Models.ExpenseReport>

@{
    ViewData["Title"] = "Expense Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ================= GLOBAL ================= */
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fbff);
        font-family: 'Segoe UI', sans-serif;
        color: #000;
    }

    /* ================= CARD ================= */
    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-3px);
        }

    /* ================= HEADINGS ================= */
    .card-title {
        font-size: 20px;
        font-weight: 700;
        color: #000;
    }

    /* ================= LABEL ================= */
    label {
        font-weight: 600;
        font-size: 14px;
        color: #000;
    }

    /* ================= INPUT ================= */
    .form-control {
        border-radius: 10px;
        border: 1px solid #dcdcdc;
        font-size: 14px;
        padding: 10px;
        transition: all 0.3s;
        height: 45px;
    }

        .form-control:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 6px rgba(79,70,229,0.3);
        }

    /* ================= BUTTON ================= */
    .btn {
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        padding: 10px 18px;
        transition: all 0.3s ease;
        height: 45px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #4f46e5, #6366f1);
        border: none;
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #4338ca, #4f46e5);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(79,70,229,0.3);
        }

    /* ================= TABLE ================= */
    .table {
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
    }

        .table thead {
            background: linear-gradient(135deg, #4f46e5, #6366f1);
        }

            .table thead th {
                color: #fff;
                font-weight: 700;
                font-size: 15px;
                padding: 12px;
                text-align: center;
            }

        .table tbody td {
            font-size: 15px;
            font-weight: 600;
            color: #000;
            padding: 12px;
            text-align: center;
        }

        .table tbody tr {
            transition: 0.2s;
        }

            .table tbody tr:hover {
                background: #eef2ff;
                transform: scale(1.01);
            }

    /* ================= BADGES ================= */
    .badge-success {
        background-color: #16a34a;
        font-size: 13px;
        padding: 6px 10px;
        border-radius: 8px;
    }

    .badge-danger {
        background-color: #dc2626;
        font-size: 13px;
        padding: 6px 10px;
        border-radius: 8px;
    }

    /* ================= TOTAL TEXT ================= */
    #totalExpenseAmount {
        font-size: 20px;
        font-weight: 800;
        color: #111;
    }

    /* ================= PAGINATION ================= */
    .pagination .page-item .page-link {
        border-radius: 8px;
        margin: 0 4px;
        color: #4f46e5;
        font-weight: 600;
        border: none;
        transition: 0.3s;
    }

    .pagination .page-item.active .page-link {
        background: #4f46e5;
        color: #fff;
    }

    .pagination .page-item .page-link:hover {
        background: #6366f1;
        color: #fff;
    }

    /* ================= FILTER SECTION ================= */
    .row.mb-4 {
        background: #ffffff;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 5px 12px rgba(0,0,0,0.05);
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: end;
    }

        .row.mb-4 .col-md-2 {
            flex: 1 1 180px;
            max-width: 200px;
        }

    /* ================= SHOW ALL BUTTON ================= */
    #showAllButton {
        background: linear-gradient(135deg, #059669, #10b981);
        border: none;
    }

        #showAllButton:hover {
            background: linear-gradient(135deg, #047857, #059669);
            transform: translateY(-2px);
        }

    #toDateWarning {
        font-weight: 600;
        font-size: 12px;
    }
    /* ================= FILTER WRAPPER ================= */
    .row.mb-3 {
        background: #ffffff;
        padding: 18px 20px;
        border-radius: 14px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.06);
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: flex-end;
    }

        /* each filter field */
        .row.mb-3 .col-md-2 {
            flex: 1 1 180px;
            max-width: 220px;
        }

        /* labels spacing */
        .row.mb-3 label {
            font-size: 13px;
            margin-bottom: 6px;
            color: #374151;
        }

        /* inputs cleaner look */
        .row.mb-3 .form-control {
            border-radius: 10px;
            border: 1px solid #e5e7eb;
            transition: 0.3s;
        }

            .row.mb-3 .form-control:focus {
                border-color: #4f46e5;
                box-shadow: 0 0 0 3px rgba(79,70,229,0.15);
            }
    /* ================= ACTION AREA (LEFT ALIGN) ================= */
    .filter-actions {
        display: flex;
        justify-content: flex-start;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

    /* Show All Button */
    #showAllButton {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        color: #fff;
        transition: 0.3s;
    }

        #showAllButton:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(16,185,129,0.25);
        }
    /* keep filters in one line on large screens */
    @@media (min-width: 992px) {
        .row.mb-3

    {
        flex-wrap: nowrap;
    }

    }

    /* ================= FILTER CARD HEADER ================= */
    .row.mb-3 {
        background: linear-gradient(135deg, #ffffff, #f9fafb);
        padding: 20px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
        display: flex;
        flex-wrap: wrap;
