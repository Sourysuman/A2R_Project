    }

        /* ================= FILTER FIELDS ================= */
        .row.mb-3 .col-md-2 {
            flex: 1 1 180px;
            max-width: 220px;
        }

        /* label style */
        .row.mb-3 label {
            font-size: 13px;
            font-weight: 700;
            color: #374151;
