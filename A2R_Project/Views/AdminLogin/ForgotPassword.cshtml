@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A2R - Forgot Password</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #0a0a0a;
            overflow: hidden;
        }

        .bg-image {
            position: fixed;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(10,10,10,0.85), rgba(20,20,40,0.75));
            z-index: 1;
        }

        .login-container {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            z-index: 10;
            position: relative;
        }

        .login-card {
            background: rgba(15, 15, 25, 0.97);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 40px 30px;
            width: 360px;
            box-shadow: 0 24px 48px rgba(0, 0, 0, 0.6);
        }

        .logo-section {
            text-align: center;
            margin-bottom: 25px;
        }

        .logo-image {
            width: 100%;
            height: 100px;
            object-fit: contain;
            border-radius: 10px;
            box-shadow: 0 10px 20px rgba(102,126,234,0.4);
        }

        .welcome h2 {
            text-align: center;
            color: #fff;
            margin-bottom: 5px;
        }

        .welcome p {
            text-align: center;
            color: #aaa;
            font-size: 0.9rem;
            margin-bottom: 20px;
        }

        .input-group {
            margin-bottom: 15px;
            position: relative;
        }

        .input-field {
            width: 100%;
            padding: 14px;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.05);
            color: white;
        }

        .input-icon {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #888;
            cursor: pointer;
        }

        .btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
        }

            .btn:hover {
                transform: translateY(-1px);
            }

        .msg {
            margin-top: 15px;
            text-align: center;
            font-size: 0.9rem;
        }

        .link {
            text-align: center;
            margin-top: 15px;
        }

            .link a {
                color: #667eea;
                text-decoration: none;
            }
        /* ================= GLOBAL ================= */
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top, #141427, #050509);
            overflow: hidden;
        }

        /* ================= BACKGROUND ================= */
        .bg-image {
            position: fixed;
            width: 100%;
            height: 100%;
            background: linear-gradient(120deg, rgba(102,126,234,0.15), rgba(118,75,162,0.15));
            z-index: 1;
        }

        /* ================= CONTAINER ================= */
        .login-container {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            position: relative;
            z-index: 10;
        }

        /* ================= CARD ================= */
        .login-card {
            background: rgba(20, 20, 35, 0.85);
            backdrop-filter: blur(25px);
            border-radius: 22px;
            padding: 40px 30px;
            width: 370px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7);
            border: 1px solid rgba(255,255,255,0.08);
            animation: fadeIn 0.6s ease-in-out;
        }

        /* ================= LOGO ================= */
        .logo-section {
            text-align: center;
            margin-bottom: 20px;
        }

        .logo-image {
            width: 100%;
            height: 90px;
            object-fit: contain;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(102,126,234,0.5);
        }

        /* ================= TITLE ================= */
        .welcome h2 {
            text-align: center;
            color: #fff;
            margin-bottom: 5px;
            font-weight: 600;
        }

        .welcome p {
            text-align: center;
            color: #aaa;
            font-size: 0.9rem;
            margin-bottom: 25px;
        }

        /* ================= INPUT GROUP ================= */
        .input-group {
            margin-bottom: 18px;
            position: relative;
        }

        /* ================= INPUT FIELD ================= */
        .input-field {
            width: 100%;
            padding: 14px 45px 14px 15px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.04);
            color: #fff;
            font-size: 14px;
            transition: all 0.3s ease;
        }

            /* Placeholder */
            .input-field::placeholder {
                color: #777;
            }

            /* Focus Effect */
            .input-field:focus {
                outline: none;
                border: 1px solid #667eea;
                background: rgba(102,126,234,0.08);
                box-shadow: 0 0 12px rgba(102,126,234,0.6);
            }

        /* ================= ICON ================= */
        .input-icon {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #888;
            cursor: pointer;
            transition: 0.3s;
        }

            .input-icon:hover {
                color: #667eea;
            }

        /* ================= BUTTON ================= */
        .btn {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            border-radius: 12px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            transition: all 0.3s ease;
        }

            /* Hover */
            .btn:hover {
                transform: translateY(-2px) scale(1.02);
                box-shadow: 0 10px 25px rgba(102,126,234,0.5);
            }

        /* ================= MESSAGE ================= */
        .msg {
            margin-top: 15px;
            text-align: center;
            font-size: 0.9rem;
            color: #ffb3b3;
        }

        /* ================= LINK ================= */
        .link {
            text-align: center;
            margin-top: 18px;
        }

            .link a {
                color: #667eea;
                text-decoration: none;
                font-size: 14px;
            }

                .link a:hover {
                    text-decoration: underline;
                }

        /* ================= ANIMATION ================= */
        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .input-group {
            margin-bottom: 18px;
            position: relative;
            width: 100%;
        }

        /* IMPORTANT FIX */
        .input-field {
            width: 100%;
            padding: 14px 45px 14px 15px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.04);
            color: #fff;
            font-size: 14px;
            /* 🔥 THIS FIXES OVERFLOW */
            box-sizing: border-box;
        }

        * {
            box-sizing: border-box;
        }

    </style>
</head>

<body>

    <div class="bg-image"></div>

    <div class="login-container">
        <div class="login-card">

            <!-- LOGO -->
            <div class="logo-section">
                <img src="~/image/a2r software.png" class="logo-image" />
            </div>

            <!-- TITLE -->
            <div class="welcome">
                <h2>Forgot Password</h2>
                <p>Reset your account password</p>
            </div>

            <!-- USERNAME -->
            <div class="input-group">
                <input type="text" id="username" class="input-field" placeholder="Enter Username" />
                <i class="fas fa-user input-icon"></i>
            </div>

            <button class="btn" onclick="generateToken()">Generate Token</button>

            <!-- RESET SECTION -->
            <div id="resetSection" style="display:none;">

                <div class="input-group">
                    <input type="password" id="newPassword" class="input-field" placeholder="New Password" />
                    <i class="fas fa-eye input-icon" onclick="togglePassword('newPassword', this)"></i>
                </div>

                <div class="input-group">
                    <input type="password" id="confirmPassword" class="input-field" placeholder="Confirm Password" />
                    <i class="fas fa-eye input-icon" onclick="togglePassword('confirmPassword', this)"></i>
                </div>

                <button class="btn" onclick="resetPassword()">Reset Password</button>
            </div>

            <div class="msg" id="message"></div>

            <div class="link">
                <a href="/AdminLogin/Login">← Back to Login</a>
            </div>

        </div>
    </div>

    <script>
        function generateToken() {
            var username = $('#username').val();

            $.post('/AdminLogin/ForgotPassword', { username: username }, function (res) {
                if (res.success) {
                    $('#message').text("✅ Token generated!");
                    $('#resetSection').show();
                } else {
                    $('#message').text(res.message);
                }
            });
        }

        function resetPassword() {
            var newPass = $('#newPassword').val();
            var confirmPass = $('#confirmPassword').val();

            $.ajax({
                url: '/AdminLogin/ResetPassword',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    NewPassword: newPass,
                    ConfirmPassword: confirmPass
                }),
                success: function (res) {
                    if (res.success) {
                        alert("🎉 Password Reset Successful!");
                        window.location.href = "/AdminLogin/Login";
                    } else {
                        $('#message').text(res.message);
                    }
                }
            });
        }

        function togglePassword(id, icon) {
            var input = document.getElementById(id);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }
    </script>

</body>
</html>