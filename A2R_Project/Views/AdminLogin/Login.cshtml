@model A2R_Project.Models.AdminLogin
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A2R - Admin Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>z
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            width: 100%;
            overflow: hidden;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #0a0a0a;
            position: relative;
        }

        .bg-image {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: linear-gradient(135deg, rgba(10,10,10,0.85), rgba(20,20,40,0.75)), url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080"><defs><radialGradient id="a" cx="30%" cy="20%"><stop offset="0%" stop-color="%23667eea" stop-opacity="0.4"/><stop offset="70%" stop-color="%23764ba2" stop-opacity="0.1"/></radialGradient><radialGradient id="b" cx="70%" cy="80%"><stop offset="0%" stop-color="%23ff6b6b" stop-opacity="0.3"/><stop offset="100%" stop-color="%23feca57" stop-opacity="0"/></radialGradient></defs><rect width="1920" height="1080" fill="%230a0a0a"/><circle cx="400" cy="300" r="400" fill="url(%23a)"/><circle cx="1500" cy="800" r="300" fill="url(%23b)"/></svg>');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            z-index: 1;
        }

        .shape {
            position: fixed;
            background: rgba(102, 126, 234, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.02);
            animation: morph 12s infinite ease-in-out;
            z-index: 2;
        }

        .shape-1 {
            width: 180px;
            height: 180px;
            top: 10%;
            left: 5%;
            border-radius: 50%;
        }

        .shape-2 {
            width: 120px;
            height: 120px;
            top: 60%;
            right: 8%;
            clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
            animation-delay: -3s;
        }

        .shape-3 {
            width: 90px;
            height: 90px;
            bottom: 15%;
            left: 15%;
            animation-delay: -6s;
        }

        @@keyframes morph {
            0%, 100% {
                transform: scale(1) rotate(0deg);
            }

            50% {
                transform: scale(1.15) rotate(180deg);
            }
        }

        .login-container {
            display: -webkit-box;
            display: -ms-flexbox;
            display: flex;
            -webkit-box-align: center;
            -ms-flex-align: center;
            align-items: center;
            -webkit-box-pack: center;
            -ms-flex-pack: center;
            justify-content: center;
            min-height: 100vh;
            min-height: -webkit-fill-available; /* ✅ iOS Safari fix */
            padding: 20px;
            position: relative;
            z-index: 10;
        }

        .login-card {
            background: rgba(15, 15, 25, 0.97);
            -webkit-backdrop-filter: blur(20px); /* ✅ Safari fix */
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 40px 30px;
            width: 100%;
            max-width: 360px;
            min-width: 300px; /* ✅ never shrinks too small */
            min-height: 500px; /* ✅ consistent height all browsers */
            height: auto; /* ✅ grows if content needs more */
            box-sizing: border-box; /* ✅ padding included in size */
            position: relative;
            animation: cardFloat 4s ease-in-out infinite;
            /* ✅ Golden border */
            border: 2px solid #f5c518 !important;
            box-shadow: 0 0 10px rgba(245, 197, 24, 0.6), 0 0 30px rgba(245, 197, 24, 0.3), 0 0 60px rgba(245, 197, 24, 0.15), 0 24px 48px rgba(0, 0, 0, 0.6) !important;
        }

        .card-glow {
            display: none !important;
        }

        @@keyframes cardFloat {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-6px);
            }
        }

        .logo-section {
            text-align: center;
            margin-bottom: 30px;
            width: 100%;
        }

        .logo-image {
            width: 100%;
            height: 120px;
            object-fit: contain;
            border-radius: 12px;
            display: block;
            margin: 0 auto;
            box-shadow: 0 12px 24px rgba(102, 126, 234, 0.4);
            background: rgba(102, 126, 234, 0.1);
            padding: 8px;
            transition: box-shadow 0.3s ease;
        }

            .logo-image:hover {
                box-shadow: 0 16px 32px rgba(102, 126, 234, 0.6);
            }

            .logo-image.fallback {
                background: linear-gradient(135deg, #667eea, #764ba2);
                font-size: 2.2rem;
                font-weight: 800;
                color: white;
                display: -webkit-box;
                display: -ms-flexbox;
                display: flex;
                -webkit-box-align: center;
                -ms-flex-align: center;
                align-items: center;
                -webkit-box-pack: center;
                -ms-flex-pack: center;
                justify-content: center;
            }

        .welcome {
            text-align: center;
            margin-bottom: 25px;
        }

            .welcome h1 {
                font-size: 1.4rem;
                font-weight: 700;
                color: #fff;
                margin-bottom: 4px;
                line-height: 1.3;
            }

            .welcome p {
                color: #a0a0a0;
                font-size: 0.9rem;
            }

        .alert {
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 0.9rem;
            font-weight: 500;
            animation: slideDown 0.3s ease;
        }

        .alert-danger {
            background: rgba(255, 107, 107, 0.15);
            border: 1px solid rgba(255, 107, 107, 0.3);
            color: #ff6b6b;
        }

        .alert-success {
            background: rgba(34, 197, 94, 0.15);
            border: 1px solid rgba(34, 197, 94, 0.3);
            color: #22c55e;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .input-group {
            margin-bottom: 18px;
            position: relative;
        }

        .input-field {
            width: 100%;
            padding: 14px 18px;
            background: rgba(255,255,255,0.04);
            border: 1.5px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            color: #fff;
            font-size: 0.95rem;
            font-weight: 500;
            transition: all 0.3s ease;
            -webkit-appearance: none; /* ✅ removes Safari default styling */
            -moz-appearance: none;
            appearance: none;
        }

            .input-field::placeholder {
                color: #777;
                opacity: 1; /* ✅ Firefox fix — Firefox makes placeholder transparent by default */
            }

            .input-field:focus {
                outline: none;
                border-color: #667eea;
                background: rgba(255,255,255,0.06);
                box-shadow: 0 0 0 3px rgba(102,126,234,0.15);
                transform: translateY(-1px);
            }

            .input-field.error {
                border-color: #ff6b6b;
                box-shadow: 0 0 0 3px rgba(255,107,107,0.2);
                animation: shake 0.5s ease-in-out;
            }

        @@keyframes shake {
            0%, 100% {
                transform: translateX(0);
            }

            25% {
                transform: translateX(-5px);
            }

            75% {
                transform: translateX(5px);
            }
        }

        .error-message {
            color: #ff6b6b;
            font-size: 0.8rem;
            margin-top: 5px;
            display: none;
        }

        .input-icon {
            position: absolute;
            right: 16px;
            top: 50%;
            -webkit-transform: translateY(-50%);
            transform: translateY(-50%);
            color: #888;
            font-size: 1rem;
            transition: 0.3s ease;
        }

        .input-field:focus + .input-icon {
            color: #667eea;
        }

        .checkbox-row {
            display: -webkit-box;
            display: -ms-flexbox;
            display: flex;
            -webkit-box-align: center;
            -ms-flex-align: center;
            align-items: center;
            -webkit-box-pack: justify;
            -ms-flex-pack: justify;
            justify-content: space-between;
            margin-bottom: 20px;
            font-size: 0.88rem;
        }

        .checkbox-container {
            display: -webkit-box;
            display: -ms-flexbox;
            display: flex;
            -webkit-box-align: center;
            -ms-flex-align: center;
            align-items: center;
        }

        .custom-checkbox {
            width: 18px;
            height: 18px;
            border: 1.5px solid rgba(255,255,255,0.3);
            border-radius: 4px;
            margin-right: 10px;
            position: relative;
            cursor: pointer;
        }

            .custom-checkbox input {
                opacity: 0;
                position: absolute;
                width: 100%; /* ✅ clickable area fix */
                height: 100%;
                cursor: pointer;
                margin: 0;
            }

        .checkmark {
            position: absolute;
            inset: 1.5px;
            border-radius: 3px;
            transition: 0.3s ease;
            background: transparent;
        }

        .custom-checkbox input:checked + .checkmark {
            background: linear-gradient(135deg, #667eea, #764ba2);
        }

        .checkbox-container label {
            color: #b0b0b0;
            cursor: pointer;
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
        }

        .forgot-link {
            color: #667eea;
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            transition: 0.3s ease;
        }

            .forgot-link:hover {
                color: #764ba2;
            }

        .login-button {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 24px rgba(102,126,234,0.3);
            position: relative;
            overflow: hidden;
            -webkit-appearance: none; /* ✅ Safari button fix */
            appearance: none;
        }

            .login-button:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 12px 32px rgba(102,126,234,0.4);
            }

            .login-button:disabled {
                opacity: 0.7;
                cursor: not-allowed;
            }

            .login-button::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
                transition: left 0.5s;
            }

            .login-button:hover::before {
                left: 100%;
            }

        /* ✅ Tablet */
        @@media (max-width: 768px) {
            .login-card {
                max-width: 380px;
                min-height: 490px;
            }
        }

        /* ✅ Mobile */
        @@media (max-width: 480px) {
            .login-card {
                padding: 35px 25px;
                max-width: 340px;
                min-height: 480px;
                width: 92vw;
            }
        }

        /* ✅ Very small screens */
        @@media (max-width: 320px) {
            .login-card {
                padding: 25px 18px;
                min-height: 460px;
                width: 95vw;
            }

            .welcome h1 {
                font-size: 1.2rem;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
   
    <div class="login-container">
        <div class="login-card">
          

            <div class="logo-section">
                <img src="~/image/a2r software.png" alt="A2R Logo" class="logo-image"
                     onerror="this.className='logo-image fallback'; this.innerHTML='A2R'">
            </div>

            <div class="welcome">
                <h1>Hello! Let's get started</h1>
                <p>Sign in to your account</p>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.errormessage as string))
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.errormessage
                </div>
            }

            @using (Html.BeginForm("Login", "AdminLogin", FormMethod.Post, new { id = "loginForm", novalidate = "novalidate" }))
            {
                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger d-none" })

                <div class="input-group">
                    @Html.TextBoxFor(model => model.UserName, new { @class = "input-field", @id = "username", @placeholder = "Username", @maxlength = "20", autocomplete = "username", required = "required", minlength = "3" })
                    <i class="fas fa-user input-icon"></i>
                    <div class="error-message" id="username-error">Username must be 3+ characters</div>
                </div>

                <div class="input-group">
                    @Html.PasswordFor(model => model.Password, new {
                    @class = "input-field",
                                @id = "password",
                                @placeholder = "Password"
                                })
                <i class="fas fa-eye input-icon" id="togglePassword"
                   style="cursor:pointer; right:16px; position:absolute; top:50%; transform:translateY(-50%); color:#888; font-size:1rem; z-index:10;"></i>
                <div class="error-message" id="password-error">Password must be 4+ characters</div>
            </div>

                <div class="checkbox-row">
                    <div class="checkbox-container">
                        <label class="custom-checkbox">
                            <input type="checkbox" id="rememberMe">
                            <div class="checkmark"></div>
                        </label>
                        <label for="rememberMe">Keep me signed in</label>
                    </div>
                    <a href="/AdminLogin/ForgotPassword" class="forgot-link">
                        <i class="fas fa-key me-1"></i>Forgot Password?
                    </a>
                </div>

                <button type="submit" class="login-button" id="loginBtn">
                    <span id="loginText">Sign In</span>
                    <span id="loginSpinner" style="display: none;">
                        <i class="fas fa-spinner fa-spin"></i> Signing In...
                    </span>
                </button>

            }

        </div>
      
    </div>


    <script>
        $(document).ready(function () {
            const usernameInput = $('#username');
            const passwordInput = $('#password');
            const loginForm = $('#loginForm');
            const loginBtn = $('#loginBtn');
            const loginText = $('#loginText');
            const loginSpinner = $('#loginSpinner');

            // Client-side validation
            function validateField(input, errorId, minLength, message) {
                input.on('input blur', function () {
                    const value = $(this).val().trim();
                    const errorEl = $(`#${errorId}`);
                    if (value.length < minLength) {
                        $(this).addClass('error');
                        errorEl.text(message).show();
                    } else {
                        $(this).removeClass('error');
                        errorEl.hide();
                    }
                });
            }

            validateField(usernameInput, 'username-error', 3, 'Username must be 3+ characters');
            validateField(passwordInput, 'password-error', 4, 'Password must be 4+ characters');

            // ✅ FIX 1: Clear errors on focus — OUTSIDE submit, using .on() not addEventListener
            usernameInput.on('focus', function () {
                $(this).removeClass('error');
                $('#username-error').hide();
                $('.alert-danger').fadeOut(300);
            });

            passwordInput.on('focus', function () {
                $(this).removeClass('error');
                $('#password-error').hide();
                $('.alert-danger').fadeOut(300);
            });

            // ✅ FIX 2: Submit handler — properly closed with }); at end
            loginForm.on('submit', function (e) {
                let isValid = true;

                if (usernameInput.val().trim().length < 3) {
                    usernameInput.addClass('error');
                    $('#username-error').show();
                    isValid = false;
                }

                if ($('#password').val().trim().length < 4) {
                    $('#password').addClass('error');
                    $('#password-error').show();
                    isValid = false;
                }

                if (!isValid) {
                    e.preventDefault();
                    return;
                }

                // ✅ FIX 3: Show spinner, then submit after small delay
                e.preventDefault();
                loginBtn.prop('disabled', true);
                loginText.hide();
                loginSpinner.show();

                setTimeout(function () {
                    loginForm[0].submit(); // native submit — bypasses jQuery to avoid loop
                }, 50);
            });

            // Remember me
            var rememberMeUsername = getCookie("rememberMeUsername");
            if (rememberMeUsername) {
                usernameInput.val(rememberMeUsername);
                $('#rememberMe').prop('checked', true);
            }

            $('#rememberMe').change(function () {
                if ($(this).is(':checked')) {
                    setCookie("rememberMeUsername", usernameInput.val().trim(), 365);
                } else {
                    setCookie("rememberMeUsername", "", -1);
                }
            });

        }); // ✅ end of $(document).ready

        // Password toggle
        var passwordVisible = false;
        $('#togglePassword').on('click', function () {
            passwordVisible = !passwordVisible;
            if (passwordVisible) {
                $('#password').attr('type', 'text');
                $(this).removeClass('fa-eye').addClass('fa-eye-slash').css('color', '#667eea');
            } else {
                $('#password').attr('type', 'password');
                $(this).removeClass('fa-eye-slash').addClass('fa-eye').css('color', '#888');
            }
        });

        function setCookie(name, value, days) {
            var expires = "";
            if (days) {
                var date = new Date();
                date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                expires = "; expires=" + date.toUTCString();
            }
            document.cookie = name + "=" + (value || "") + expires + "; path=/";
        }

        function getCookie(name) {
            var nameEQ = name + "=";
            var ca = document.cookie.split(';');
            for (var i = 0; i < ca.length; i++) {
                var c = ca[i];
                while (c.charAt(0) == ' ') c = c.substring(1, c.length);
                if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length, c.length);
            }
            return null;
        }

        // Forgot Password
        $('#forgotPasswordLink').click(async function (e) {
            e.preventDefault();

            var username = prompt('Enter your username (e.g. Admin):');
            if (!username || username.trim().length < 3) {
                alert('Please enter valid username (3+ chars)');
                return;
            }

            $(this).html('<i class="fas fa-spinner fa-spin me-1"></i>Processing...');

            try {
                var response = await fetch('/AdminLogin/ForgotPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'username=' + encodeURIComponent(username)
                });
                var data = await response.json();

                if (data.success) {
                    var token = data.token;
                    var newPass = prompt(
                        '🔑 TOKEN GENERATED!\n\nToken: `' + token + '`\n\nEnter NEW PASSWORD below:', ''
                    );

                    if (newPass && newPass.length >= 6) {
                        var resetResponse = await fetch('/AdminLogin/ResetPassword', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ NewPassword: newPass, ConfirmPassword: newPass })
                        });
                        var resetData = await resetResponse.json();

                        if (resetData.success) {
                            alert('🎉 Password reset complete!\nLogin: ' + username + ' / ' + newPass);
                            location.reload();
                        } else {
                            alert('❌ Reset failed: ' + resetData.message);
                        }
                    } else {
                        alert('Password must be 6+ characters');
                    }
                } else {
                    alert('❌ ' + data.message);
                }
            } catch (error) {
                alert('Error: ' + error.message);
            } finally {
                $('#forgotPasswordLink').html('<i class="fas fa-key me-1"></i>Forgot Password?');
            }
        });
    </script>


</body>
</html>