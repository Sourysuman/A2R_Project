@model A2R_Project.Models.StudentInquiries
@{
    ViewBag.Title = "Students List";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/@@mdi/font@6.5.95/css/materialdesignicons.min.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fbff);
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card-title {
        font-size: 20px;
        font-weight: 700;
        color: #2c3e50;
        letter-spacing: 0.5px;
    }

    .table {
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
    }

        .table thead th {
            border: none;
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            padding: 14px;
            text-align: center;
        }

        .table tbody td {
            font-size: 15px;
            font-weight: 600;
            color: #34495e;
            padding: 14px;
            vertical-align: middle;
            background-color:white !important;
            text-align: center;
        }

        .table tbody tr {
            transition: all 0.25s ease;
        }


    .badge-success {
        background: linear-gradient(135deg, #1cc88a, #17a673);
        padding: 7px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .badge-danger {
        background: linear-gradient(135deg, #e74a3b, #c0392b);
        padding: 7px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    /* ── Action column centred ── */
    .action-cell {
        text-align: center !important;
        white-space: nowrap;
    }

    .btn-sm {
        border-radius: 10px;
        padding: 6px 12px;
        margin: 0 2px;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.25s ease;
    }

        .btn-sm i {
            font-size: 15px;
        }

        .btn-sm:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.15);
        }

    .btn-primary {
        background: linear-gradient(135deg, #4e73df, #224abe);
        border: none;
    }

    .btn-info {
        background: linear-gradient(135deg, #36b9cc, #1f8ea3);
        border: none;
        color: #fff;
    }

    .btn-warning {
        background: linear-gradient(135deg, #f6c23e, #e0a800);
        border: none;
        color: #000;
    }

    .btn-admission {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        color: #fff;
        font-weight: 700;
        border-radius: 25px;
        padding: 6px 14px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-admission:hover {
            background: linear-gradient(135deg, #218838, #17a2b8);
            color: #fff;
            transform: scale(1.05);
        }

    /* ===== PAGINATION ===== */
    .pagination .page-link {
        border-radius: 10px;
        margin: 0 4px;
        font-weight: 600;
        color: #4e73df;
        border: none;
        cursor: pointer;
        user-select: none;
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: #fff;
    }

    .pagination .page-link:hover {
        background: #e8edff;
    }

    /* ===== MODAL SYSTEM ===== */
    .modal {
        backdrop-filter: blur(4px);
    }

    @@keyframes modalPop {
        from {
            transform: scale(0.93);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    #editStudent .modal-dialog,
    #viewStudent .modal-dialog,
    #followUpModal .modal-dialog,
    #admissionModal .modal-dialog {
        max-width: 1000px !important;
        width: 95vw !important;
        margin: 80px auto 1.75rem auto !important;
    }

    #editStudent .modal-content,
    #viewStudent .modal-content,
    #followUpModal .modal-content,
    #admissionModal .modal-content {
        min-height: 580px !important;
        max-height: 85vh !important;
        height: 580px !important;
        border-radius: 18px !important;
        overflow: hidden !important;
        display: flex !important;
        flex-direction: column !important;
        border: none !important;
        box-shadow: 0 12px 40px rgba(0,0,0,0.18) !important;
        animation: modalPop 0.28s ease;
    }

    #editStudent .modal-header,
    #viewStudent .modal-header,
    #followUpModal .modal-header,
    #admissionModal .modal-header {
        background: linear-gradient(135deg, #4e73df, #224abe) !important;
        color: #fff !important;
        padding: 18px 24px !important;
        border-bottom: none !important;
        border-radius: 18px 18px 0 0 !important;
        flex-shrink: 0 !important;
    }

    #editStudent .modal-title,
    #viewStudent .modal-title,
    #followUpModal .modal-title,
    #admissionModal .modal-title {
        color: #fff !important;
        font-size: 18px !important;
        font-weight: 700 !important;
        letter-spacing: 0.4px !important;
    }

    #editStudent .modal-header .close,
    #viewStudent .modal-header .close,
    #followUpModal .modal-header .close,
    #admissionModal .modal-header .close {
        color: #fff !important;
        opacity: 0.9 !important;
        font-size: 26px !important;
        text-shadow: none !important;
    }

        #editStudent .modal-header .close:hover,
        #viewStudent .modal-header .close:hover,
        #followUpModal .modal-header .close:hover,
        #admissionModal .modal-header .close:hover {
            opacity: 1 !important;
        }

    #editStudent .modal-body,
    #viewStudent .modal-body,
    #followUpModal .modal-body,
    #admissionModal .modal-body {
        flex: 1 !important;
        overflow-y: auto !important;
        padding: 24px 28px !important;
        background: #f9fbff !important;
        max-height: none !important;
    }

        #editStudent .modal-body::-webkit-scrollbar,
        #viewStudent .modal-body::-webkit-scrollbar,
        #followUpModal .modal-body::-webkit-scrollbar,
        #admissionModal .modal-body::-webkit-scrollbar {
            width: 5px !important;
        }

        #editStudent .modal-body::-webkit-scrollbar-thumb,
        #viewStudent .modal-body::-webkit-scrollbar-thumb,
        #followUpModal .modal-body::-webkit-scrollbar-thumb,
        #admissionModal .modal-body::-webkit-scrollbar-thumb {
            background: #4e73df !important;
            border-radius: 10px !important;
        }

    #editStudent .modal-footer,
    #viewStudent .modal-footer,
    #followUpModal .modal-footer,
    #admissionModal .modal-footer {
        background: #fff !important;
        border-top: 1px solid #eee !important;
        padding: 14px 24px !important;
        display: flex !important;
        justify-content: flex-end !important;
        gap: 10px !important;
        flex-shrink: 0 !important;
    }

        #editStudent .modal-footer .btn,
        #viewStudent .modal-footer .btn,
        #followUpModal .modal-footer .btn,
        #admissionModal .modal-footer .btn {
            border-radius: 10px !important;
            padding: 9px 22px !important;
            font-weight: 600 !important;
            font-size: 14px !important;
            border: none !important;
            transition: all 0.25s ease !important;
            letter-spacing: 0.3px;
        }

            #editStudent .modal-footer .btn:hover,
            #viewStudent .modal-footer .btn:hover,
            #followUpModal .modal-footer .btn:hover,
            #admissionModal .modal-footer .btn:hover {
                transform: translateY(-2px) !important;
                box-shadow: 0 6px 16px rgba(0,0,0,0.15) !important;
            }

        #editStudent .modal-footer .btn-secondary,
        #viewStudent .modal-footer .btn-secondary,
        #followUpModal .modal-footer .btn-secondary,
        #admissionModal .modal-footer .btn-secondary {
            background: #6c757d !important;
            color: #fff !important;
        }

        #editStudent .modal-footer .btn-warning,
        #viewStudent .modal-footer .btn-warning,
        #followUpModal .modal-footer .btn-warning,
        #admissionModal .modal-footer .btn-warning {
            background: linear-gradient(135deg, #f6c23e, #e0a800) !important;
            color: #000 !important;
        }

        #editStudent .modal-footer .btn-primary,
        #viewStudent .modal-footer .btn-primary,
        #followUpModal .modal-footer .btn-primary,
        #admissionModal .modal-footer .btn-primary {
            background: linear-gradient(135deg, #4e73df, #224abe) !important;
            color: #fff !important;
        }

        #editStudent .modal-footer .btn-success,
        #viewStudent .modal-footer .btn-success,
        #followUpModal .modal-footer .btn-success,
        #admissionModal .modal-footer .btn-success {
            background: linear-gradient(135deg, #28a745, #20c997) !important;
            color: #fff !important;
        }

    /* ===== MODAL FORM STYLES ===== */
    .modal .form-group {
        margin-bottom: 18px;
    }

        .modal .form-group label {
            font-size: 13px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 6px;
            display: block;
        }

    .modal .form-control {
        height: 42px;
        border-radius: 10px;
        border: 1.5px solid #dce3f0;
        font-size: 14px;
        font-weight: 600;
        padding: 8px 12px;
        transition: all 0.25s ease;
    }

    .modal textarea.form-control {
        height: auto;
        min-height: 70px;
    }

    .modal .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 3px rgba(78,115,223,0.15);
        background: #fff;
    }

    .modal h6 {
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 14px;
        color: #4e73df;
        padding-bottom: 8px;
        border-bottom: 2px solid #e3f2fd;
        margin-top: 20px;
    }

        .modal h6:first-child {
            margin-top: 0;
        }

    .form-control.is-invalid {
        border-color: #e74c3c !important;
    }

    .invalid-feedback {
        font-size: 12px;
        color: #e74c3c;
        margin-top: 3px;
        display: block;
    }

    /* ===== VIEW MODAL PLAINTEXT ===== */
    #viewStudent .form-control-plaintext {
        font-size: 14px;
        font-weight: 600;
        color: #2c3e50;
        background: linear-gradient(135deg, #fff, #f8fbff);
        border: 1.5px solid #e8f0fe;
        border-radius: 10px;
        padding: 10px 14px;
        min-height: 42px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.04);
        transition: all 0.25s ease;
        display: block;
    }

        #viewStudent .form-control-plaintext:hover {
            border-color: #4e73df;
            box-shadow: 0 4px 12px rgba(78,115,223,0.12);
        }

    /* ===== FOLLOW UP MODAL CARDS ===== */
    #followUpModal .card {
        border-radius: 12px;
        overflow: hidden;
    }

    #followUpModal .card-header {
        font-weight: 700;
        padding: 10px 16px;
    }

    /* ===== ADMISSION READONLY FIELDS ===== */
    #admissionModal .form-control[readonly],
    #admissionModal .form-control.bg-light {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef) !important;
        color: #28a745;
        font-weight: 700;
        cursor: not-allowed;
    }

    /* ===== ROW FLASH ON INSTANT UPDATE ===== */
    @@keyframes rowFlash {
        0% {
            background-color: #b8f5d4 !important;
        }

        100% {
            background-color: #FFFFDE !important;
        }
    }

    .row-updated td {
        animation: rowFlash 1.4s ease forwards !important;
    }

    @@media (max-width: 768px) {
        #editStudent .modal-dialog,
        #viewStudent .modal-dialog,
        #followUpModal .modal-dialog,
        #admissionModal .modal-dialog {
            width: calc(100vw - 20px) !important;
            margin: 10px auto !important;
        }

        #editStudent .modal-content,
        #viewStudent .modal-content,
        #followUpModal .modal-content,
        #admissionModal .modal-content {
            height: auto !important;
            min-height: auto !important;
            max-height: 92vh !important;
        }
    }
</style>


<!-- ===== MAIN TABLE ===== -->
<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px">
                <strong class="card-title">Inquiry List</strong>
            </div>

            <div id="tableWrapper">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead class="thead-dark">
                            <tr>
                                <th>Student Name</th>
                                <th>Education</th>
                                <th>Status</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.StudentInquiry != null && Model.StudentInquiry.Any())
                            {
                                foreach (var item in Model.StudentInquiry)
                                {
                                    <tr data-student-id="@item.StudentInquiryID">
                                        <td class="col-student-name">@item.NameOfStudent</td>
                                        <td class="col-education">@item.Education</td>
                                        <td class="col-status">
                                            @if (item.IsActive == 1)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Inactive</span>
                                            }
                                        </td>
                                        <td class="action-cell">
                                            @if (ViewBag.CanUpdate == true)
                                            {
                                                <button class="btn btn-sm btn-primary editByStudentInquiryId"
                                                        data-edstudent-id="@item.StudentInquiryID" title="Edit">
                                                    <i class="mdi mdi-pencil"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-secondary"
                                                        title="No Edit Permission"
                                                        onclick="noAccess('Update')">
                                                    <i class="mdi mdi-pencil"></i>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-info viewByStudentInquiryId" data-vwstudent-id="@item.StudentInquiryID" title="View">
                                                <i class="mdi mdi-eye"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-warning followUp"
                                                    data-follow-up-id="@item.StudentInquiryID" title="Follow Up">
                                                <i class="mdi mdi-clock-outline"></i>
                                            </button>
                                            @if (ViewBag.CanInsert == true)
                                            {
                                                <button type="button" class="btn btn-sm btn-admission admission"
                                                        data-admissionId="@item.StudentInquiryID" title="Admission">
                                                    <i class="mdi mdi-account-check"></i> Admission
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-secondary"
                                                        title="No Admission Permission"
                                                        onclick="noAccess('Insert')">
                                                    <i class="mdi mdi-account-check"></i> Admission
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center">No students found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (ViewBag.TotalCount != null && (int)ViewBag.TotalCount > (int)ViewBag.PageSize)
                {
                    int totalPages = (int)Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize);
                    int currentPage = (int)ViewBag.CurrentPage;
                    int pageSize = (int)ViewBag.PageSize;

                    <nav>
                        <ul class="pagination justify-content-center" id="ajaxPagination">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" data-page="@(currentPage - 1)">Previous</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" data-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" data-page="@(currentPage + 1)">Next</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>


<!-- ===================================================
     EDIT MODAL
=================================================== -->
<div class="modal fade" id="editStudent" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="mdi mdi-pencil mr-2"></i> Edit Student</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editStudentForm">
                    <input type="hidden" id="hdnStudentId">
                    <h6><i class="mdi mdi-account mr-1"></i> Student Information</h6>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtEditStudentName" required />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Contact No. <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtEditContactNo" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Company</label>
                                <input type="text" class="form-control" id="txtEditCompanyName" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Education <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtEditEducation" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="txtEditEmail" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Enrolled Date</label>
                                <input type="date" class="form-control" id="enrolledDateEdit" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Completion Date</label>
                                <input type="date" class="form-control" id="completionDateEdit" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Course <span class="text-danger">*</span></label>
                                @Html.DropDownList("courseID", new SelectList(Model.course, "CourseID", "CourseName"), "-- Select --", new { @class = "form-control", @id = "ddlEditCourseId" })
                            </div>
                        </div>
                    </div>
                    <h6><i class="mdi mdi-map-marker mr-1"></i> Address Information</h6>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Address 1</label>
                                <input type="text" class="form-control" id="txtEditStudentAddress1" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Address 2</label>
                                <input type="text" class="form-control" id="txtEditAddress2" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>City <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtEditCity" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Postcode</label>
                                <input type="text" class="form-control" id="txtEditPincode" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Father's Name</label>
                                <input type="text" class="form-control" id="txtEditFatherName" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Designation</label>
                                <input type="text" class="form-control" id="txtEditDesignation" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>State <span class="text-danger">*</span></label>
                                @Html.DropDownList("stateID", new SelectList(Model.state, "StateID", "StateName"), "-- Select --", new { @class = "form-control", @id = "ddlEditStateId" })
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Country <span class="text-danger">*</span></label>
                                @Html.DropDownList("countryID", new SelectList(Model.country, "CountryID", "CountryName"), "-- Select --", new { @class = "form-control", @id = "ddlEditCountryId" })
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning btnStudentReset">Reset</button>
                <button type="button" class="btn btn-primary" id="btnEditStudentSave">Save Changes</button>
            </div>
        </div>
    </div>
</div>


<!-- ===================================================
     VIEW MODAL
=================================================== -->
<div class="modal fade" id="viewStudent" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="mdi mdi-eye mr-2"></i> Student Details</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <h6><i class="mdi mdi-account mr-1"></i> Student Information</h6>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Name</label>
                            <p id="lblvwStudentName" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Father's Name</label>
                            <p id="lblvwFathersName" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Contact No</label>
                            <p id="lblvwContactNo" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Email</label>
                            <p id="lblvwEmail" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Education</label>
                            <p id="lblvwEducation" class="form-control-plaintext"></p>
                        </div>
                    </div>
                </div>

                <h6><i class="mdi mdi-map-marker mr-1"></i> Address Information</h6>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Address 1</label>
                            <p id="lblvwAddress1" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>City</label>
                            <p id="lblvwCity" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Post Code</label>
                            <p id="lblvwPincode" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>State</label>
                            <p id="lblvwState" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Country</label>
                            <p id="lblvwCountry" class="form-control-plaintext"></p>
                        </div>
                    </div>
                </div>

                <h6><i class="mdi mdi-clock-outline mr-1"></i> Follow-Up Details</h6>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Follow-Up 1 Description</label>
                            <p id="lblvwFollowUpDesc1" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Follow-Up 1 Date</label>
                            <p id="lblvwFollowUpDate1" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Follow-Up 2 Description</label>
                            <p id="lblvwFollowUpDesc2" class="form-control-plaintext"></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Follow-Up 2 Date</label>
                            <p id="lblvwFollowUpDate2" class="form-control-plaintext"></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>


