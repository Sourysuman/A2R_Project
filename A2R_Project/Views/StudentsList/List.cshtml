        let isValid = true;

        $('.form-control').removeClass('is-invalid');
        $('.invalid-feedback').remove();

        let actual = parseFloat($('#actualAmount').val()) || 0;
        let discount = parseFloat($('#discountAmount').val()) || 0;
        let paid = parseFloat($('#paidAmount').val()) || 0;
        let fine = parseFloat($('#fineAmount').val()) || 0;

        // Admission Date
        if (!$('#admissionDate').val()) {
            showError('#admissionDate', 'Select date');
            isValid = false;
        }

        // Course
        if (!$('#ddlCourseId').val()) {
            showError('#ddlCourseId', 'Select course');
            isValid = false;
        }

        // Actual Amount
        if (actual <= 0) {
            showError('#actualAmount', 'Enter valid amount');
            isValid = false;
        }

        // Discount
        if (discount < 0) {
            showError('#discountAmount', 'Invalid discount');
            isValid = false;
        }

        // Paid > Net check
        let net = actual - discount + fine;
        if (paid > net) {
            showError('#paidAmount', 'Paid cannot exceed net amount');
            isValid = false;
        }

        // Payment Method
        if (!$('#paymentMethod').val()) {
            showError('#paymentMethod', 'Select payment method');
            isValid = false;
        }

        // Sequence No (optional but validate length)
        let seq = $('#sequenceNo').val().trim();
        if (seq && seq.length < 3) {
            showError('#sequenceNo', 'Too short');
            isValid = false;
        }

        if (!isValid) return;

