    });


        // ✅ ADMISSION BUTTON - PERFECTLY WORKING
    $(document).on('click', '.admission', function() {
        var studentId = $(this).data('admissionId') || $(this).attr('data-admissionId');
        console.log('🎓 Admission ID:', studentId);

        $.get('@Url.Action("GetStudentInquiry", "StudentsList")', { studentInquiryID: studentId })
        .done(function(data) {
            console.log('🎓 Student Data:', data);
            $('#hdnAdmissionStudentInquiryID').val(data.studentInquiryID);

            // Auto-fill student info (optional)
            // $('#studentNameDisplay').text(data.nameOfStudent);

            $('#admissionModal').modal('show');
        })
        .fail(function() {
            alert('Error loading student data');
        });
    });


        // ✅ AUTO-CALCULATE AMOUNTS (Real-time)
    $(document).on('input', '#actualAmount, #discountAmount, #paidAmount, #fineAmount', function() {
        calculateAmounts();
    });

    function calculateAmounts() {
        var actual = parseFloat($('#actualAmount').val()) || 0;
        var discount = parseFloat($('#discountAmount').val()) || 0;
        var fine = parseFloat($('#fineAmount').val()) || 0;
        var paid = parseFloat($('#paidAmount').val()) || 0;

        var net = actual - discount + fine;
        var pending = net - paid;

        $('#netAmount').val(net.toFixed(2));
        $('#pendingAmount').val(pending.toFixed(2));
    }

    // ✅ ADMISSION BUTTON
    $(document).on('click', '.admission', function() {
        var studentId = $(this).attr('data-admissionId');
        console.log('🎓 Admission Student ID:', studentId);

        $.get('@Url.Action("GetStudentInquiry", "StudentsList")', { studentInquiryID: studentId })
        .done(function(data) {
            console.log('🎓 Student Data:', data);
            $('#hdnAdmissionStudentInquiryID').val(data.studentInquiryID);
            $('#admissionStudentName').text(data.nameOfStudent + ' (' + data.contactNo + ')');

            // Reset form
            $('#addAdmissionForm')[0].reset();
            $('#actualAmount').val('');
            calculateAmounts();

            $('#admissionModal').modal('show');
        })
        .fail(function(xhr) {
            alert('Error loading student: ' + xhr.responseText);
        });
    });

    // ✅ SAVE ADMISSION
    $(document).on('click', '#btnAdmissionSave', function() {
        // Validation
        if (!$('#admissionDate').val() || !$('#ddlCourseId').val() || !$('#actualAmount').val()) {
            alert('Please fill mandatory fields: Date, Course, Course Fee');
            return;
        }

          var data = {
        StudentInquiryID: parseInt($('#hdnAdmissionStudentInquiryID').val()),
        Admission_Date: $('#admissionDate').val(),
        CourseID: parseInt($('#ddlCourseId').val()),
        Actual_Amount: parseInt($('#actualAmount').val()),
        Discount_Amount: parseInt($('#discountAmount').val()) || 0,
        Fine_Amount: parseInt($('#fineAmount').val()) || 0,
        Net_Amount: parseFloat($('#netAmount').val()) || 0,
        Pending_Amount: parseFloat($('#pendingAmount').val()) || 0,
        Paid_Amount: parseInt($('#paidAmount').val()) || 0,
        Payment_Method: $('#paymentMethod').val(),
        Payment_Remark: $('#paymentRemark').val().trim(),
        SequenceNo: $('#sequenceNo').val().trim(),
        Created_By: "StudentsList",
        Updated_By: "StudentsList"
    };
        console.log('💰 Saving Admission:', data);
        $(this).prop('disabled', true).html('<i class="mdi mdi-loading mdi-spin"></i> Saving...');

        $.ajax({
              url: '@Url.Action("SaveStudentAdmission", "StudentsList")',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function(result) {
                console.log('✅ Result:', result);
                if (result.toLowerCase() === "success") {
                    alert('✅ Admission saved successfully!');
                    $('#admissionModal').modal('hide');
                    setTimeout(() => location.reload(), 500);
                } else if (result.toLowerCase() === "duplicate") {
                    alert('⚠️ Admission already exists for this student!');
                } else {
                    alert('❌ ' + result);
                }
            },
            error: function(xhr) {
                console.error('❌ Error:', xhr.responseText);
                alert('❌ Error: ' + xhr.responseText);
            },
            complete: function() {
                $('#btnAdmissionSave').prop('disabled', false).html('<i class="mdi mdi-check"></i> Save Admission');
            }
        });
    });

    // ✅ RESET FORM
    $(document).on('click', '.btnAdmissionReset', function() {
        $('#addAdmissionForm')[0].reset();
        $('#netAmount, #pendingAmount').val('');
        $('#hdnAdmissionStudentInquiryID').val('');
        $('#admissionStudentName').text('');
    });
        // ✅ ENHANCE VIEW MODAL ANIMATION
    $('#viewStudent').on('shown.bs.modal', function () {
        $(this).find('.form-control-plaintext').each(function() {
            $(this).addClass('animate__animated animate__fadeInUp');
        });
    });
    // ✅ ENHANCE ADMISSION MODAL
    $('#admissionModal').on('shown.bs.modal', function () {
        $('#admissionDate').focus();
        $('.form-control').addClass('animate__animated animate__fadeInUp');
    });
    
  
</script>