<!-- ===================================================
     ADMISSION MODAL
=================================================== -->
<div class="modal fade" id="admissionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="mdi mdi-account-check mr-2"></i> Add Admission</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="hdnAdmissionStudentInquiryID">
                <form id="addAdmissionForm">
                    <h6><i class="mdi mdi-calendar mr-1"></i> Admission Details</h6>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Admission Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="admissionDate" required>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Course <span class="text-danger">*</span></label>
                                @Html.DropDownList("CourseID", new SelectList(Model.course, "CourseID", "CourseName"), "-- Select Course --", new { @class = "form-control", @id = "ddlCourseId" })
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Course Fee <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="actualAmount" min="0" required>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Discount</label>
                                <input type="text" class="form-control" id="discountAmount" min="0" value="0">
                            </div>
                        </div>
                    </div>
                    <h6><i class="mdi mdi-currency-inr mr-1"></i> Payment Details</h6>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Paid Amount</label>
                                <input type="text" class="form-control" id="paidAmount" min="0" value="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Net Amount</label>
                                <input type="text" class="form-control bg-light" id="netAmount" readonly>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Pending Amount</label>
                                <input type="text" class="form-control bg-light" id="pendingAmount" readonly>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Fine Amount</label>
                                <input type="text" class="form-control" id="fineAmount" min="0" value="0">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Payment Method <span class="text-danger">*</span></label>
                                <select class="form-control" id="paymentMethod">
                                    <option value="">-- Select --</option>
                                    <option value="UPI">UPI</option>
                                    <option value="Cash">Cash</option>
                                    <option value="PhonePe">PhonePe</option>
                                    <option value="GooglePay">GooglePay</option>
                                    <option value="Bank">Bank Transfer</option>
                                    <option value="Card">Card</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>UTR No</label>
                                <input type="text" class="form-control" id="sequenceNo">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Payment Remark</label>
                                <input type="text" class="form-control" id="paymentRemark" placeholder="Transaction ID, cheque no...">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning btnAdmissionReset">Reset</button>
                <button type="button" class="btn btn-success" id="btnAdmissionSave">Save Admission</button>
            </div>
        </div>
    </div>
</div>


<!-- ===== SCRIPTS ===== -->
<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/js/bootstrap-datepicker.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
        function noAccess(type) {
        Swal.fire({
            icon: 'error',
            title: 'Access Denied',
            text: 'You do not have ' + type + ' permission for Student Inquiry module.',
            confirmButtonColor: '#dc2626'
        });
    }
    $(document).ready(function () {

        // ── HELPERS ──────────────────────────────────────────
        function showError(input, message) {
            $(input).addClass('is-invalid');
            if (!$(input).next('.invalid-feedback').length) {
                $(input).after('<div class="invalid-feedback">' + message + '</div>');
            }
        }

        function clearErrors() {
            $('.form-control').removeClass('is-invalid');
            $('.invalid-feedback').remove();
        }

        function isValidEmail(email) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
        }

        function isValidPhone(phone) {
            return /^[6-9]\d{9}$/.test(phone);
        }

        // Flash the updated table row green for 1.4 s
        function flashRow(studentId) {
            var $row = $('tr[data-student-id="' + studentId + '"]');
            $row.addClass('row-updated');
            setTimeout(function () { $row.removeClass('row-updated'); }, 1500);
        }

        // Toast notification (top-right, no button)
        function toast(icon, title, text) {
            Swal.fire({
                icon: icon,
                title: title,
                text: text,
                timer: 1800,
                showConfirmButton: false,
                toast: true,
                position: 'top-end'
            });
        }

        $(document).on('input change', '.form-control', function () {
            $(this).removeClass('is-invalid');
            $(this).next('.invalid-feedback').remove();
        });

        // ── AJAX PAGINATION ──────────────────────────────────
        var _pageSize = @(ViewBag.PageSize ?? 10);

        $(document).on('click', '#ajaxPagination .page-link', function (e) {
            e.preventDefault();
            var $item = $(this).closest('.page-item');
            if ($item.hasClass('disabled') || $item.hasClass('active')) return;
            var page = $(this).data('page');

            $.get('@Url.Action("List", "StudentsList")', { page: page, pageSize: _pageSize })
            .done(function (html) {
                var $newWrapper = $($.parseHTML(html, document, true)).find('#tableWrapper');
                if ($newWrapper.length) { $('#tableWrapper').html($newWrapper.html()); }
            })
            .fail(function () { Swal.fire('Error', 'Failed to load page.', 'error'); });
        });

        // ── EDIT — open modal ────────────────────────────────
        $(document).on('click', '.editByStudentInquiryId', function () {
            var id = $(this).data('edstudent-id');

            $.get('@Url.Action("GetStudentInquiry", "StudentsList")', { studentInquiryID: id })
            .done(function (data) {
                if (data && !data.error) {
                    $('#hdnStudentId').val(data.studentInquiryID);
                    $('#txtEditStudentName').val(data.nameOfStudent);
                    $('#txtEditContactNo').val(data.contactNo);
                    $('#txtEditCompanyName').val(data.companyName);
                    $('#txtEditEducation').val(data.education);
                    $('#txtEditEmail').val(data.email);
                    $('#txtEditFatherName').val(data.fathersName);
                    $('#txtEditDesignation').val(data.designation);
                    $('#ddlEditStateId').val(data.stateID);
                    $('#ddlEditCountryId').val(data.countryID);
                    $('#ddlEditCourseId').val(data.courseID);
                    $('#txtEditStudentAddress1').val(data.address1);
                    $('#txtEditAddress2').val(data.address2);
                    $('#txtEditCity').val(data.city);
                    $('#txtEditPincode').val(data.postcode);
                    if (data.enrolledDate)   { $('#enrolledDateEdit').val(new Date(data.enrolledDate).toISOString().split('T')[0]); }
                    if (data.completionDate) { $('#completionDateEdit').val(new Date(data.completionDate).toISOString().split('T')[0]); }
                    $('#editStudent').modal('show');
                }
            })
            .fail(function () { Swal.fire('Error', 'Failed to load student data.', 'error'); });
        });

        // ── EDIT SAVE — instant row update, NO page reload ───
        $(document).on('click', '#btnEditStudentSave', function () {
            clearErrors();
            var isValid = true;

            if (!$('#txtEditStudentName').val().trim())  { showError('#txtEditStudentName', 'Name is required'); isValid = false; }

            var contact = $('#txtEditContactNo').val().trim();
            if (!contact)                { showError('#txtEditContactNo', 'Contact No. is required'); isValid = false; }
            else if (!isValidPhone(contact)) { showError('#txtEditContactNo', 'Enter valid 10-digit mobile number'); isValid = false; }

            var email = $('#txtEditEmail').val().trim();
            if (!email)                  { showError('#txtEditEmail', 'Email is required'); isValid = false; }
            else if (!isValidEmail(email)) { showError('#txtEditEmail', 'Enter a valid email address'); isValid = false; }

            if (!$('#txtEditEducation').val().trim()) { showError('#txtEditEducation', 'Education is required'); isValid = false; }
            if (!$('#ddlEditCourseId').val())         { showError('#ddlEditCourseId', 'Please select a course'); isValid = false; }
            if (!$('#ddlEditStateId').val())          { showError('#ddlEditStateId', 'Please select a state'); isValid = false; }
            if (!$('#ddlEditCountryId').val())        { showError('#ddlEditCountryId', 'Please select a country'); isValid = false; }
            if (!$('#txtEditCity').val().trim())      { showError('#txtEditCity', 'City is required'); isValid = false; }

            var pin = $('#txtEditPincode').val().trim();
            if (pin && !/^\d{6}$/.test(pin)) { showError('#txtEditPincode', 'Enter valid 6-digit pincode'); isValid = false; }

            if (!isValid) {
                Swal.fire({ icon: 'warning', title: 'Validation Error', text: 'Please fix the highlighted fields.', confirmButtonColor: '#4e73df' });
                return;
            }

            var studentId = parseInt($('#hdnStudentId').val()) || 0;
            var newName   = $('#txtEditStudentName').val().trim();
            var newEdu    = $('#txtEditEducation').val().trim();

            var payload = {
                studentInquiryID: studentId,
                nameOfStudent:    newName,
                fathersName:      $('#txtEditFatherName').val().trim(),
                companyName:      $('#txtEditCompanyName').val().trim(),
                education:        newEdu,
                contactNo:        contact,
                designation:      $('#txtEditDesignation').val().trim(),
                email:            email,
                stateID:          parseInt($('#ddlEditStateId').val()) || 0,
                countryID:        parseInt($('#ddlEditCountryId').val()) || 0,
                courseID:         parseInt($('#ddlEditCourseId').val()) || 0,
                address1:         $('#txtEditStudentAddress1').val().trim(),
                address2:         $('#txtEditAddress2').val().trim(),
                city:             $('#txtEditCity').val().trim(),
                postcode:         pin,
                enrolledDate:     $('#enrolledDateEdit').val() || null,
                completionDate:   $('#completionDateEdit').val() || null,
                isActive: 1,
                isDeleted: 0
            };

            $('#btnEditStudentSave').prop('disabled', true).text('Saving...');

            $.ajax({
                url: '@Url.Action("Edit", "StudentsList")',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function (result) {
                    if (result === "success") {
                        // 1. Update the row in-place
                        var $row = $('tr[data-student-id="' + studentId + '"]');
                        $row.find('.col-student-name').text(newName);
                        $row.find('.col-education').text(newEdu);

                        // 2. Close modal instantly
                        $('#editStudent').modal('hide');

                        // 3. Flash the row
                        flashRow(studentId);

                        // 4. Small toast — no page reload
                        toast('success', 'Updated!', 'Student updated successfully.');
                    } else {
                        Swal.fire('Error', result, 'error');
                    }
                },
                error: function (xhr) { Swal.fire('Error', 'Server error: ' + xhr.responseText, 'error'); },
                complete: function () { $('#btnEditStudentSave').prop('disabled', false).text('Save Changes'); }
            });
        });

        $(document).on('click', '.btnStudentReset', function () {
            clearErrors();
            $('#editStudentForm')[0].reset();
            $('#hdnStudentId').val('');
        });

        // ── VIEW ─────────────────────────────────────────────
        $(document).on('click', '.viewByStudentInquiryId', function () {
            var id = $(this).data('vwstudent-id');

            $.get('@Url.Action("GetStudentInquiry", "StudentsList")', { studentInquiryID: id })
            .done(function (data) {
                if (data && !data.error) {
                    $('#lblvwStudentName').text(data.nameOfStudent  || 'N/A');
                    $('#lblvwFathersName').text(data.fathersName    || 'N/A');
                    $('#lblvwContactNo').text(data.contactNo        || 'N/A');
                    $('#lblvwEmail').text(data.email                || 'N/A');
                    $('#lblvwEducation').text(data.education        || 'N/A');
                    $('#lblvwAddress1').text(data.address1          || 'N/A');
                    $('#lblvwCity').text(data.city                  || 'N/A');
                    $('#lblvwPincode').text(data.postcode           || 'N/A');
                    $('#lblvwState').text(data.state                || 'N/A');
                    $('#lblvwCountry').text(data.country            || 'N/A');
                    $('#lblvwFollowUpDesc1').text(data.followUpDesc1 || 'N/A');
                    $('#lblvwFollowUpDate1').text(data.followUpDate1 || 'N/A');
                    $('#lblvwFollowUpDesc2').text(data.followUpDesc2 || 'N/A');
                    $('#lblvwFollowUpDate2').text(data.followUpDate2 || 'N/A');
                    $('#viewStudent').modal('show');
                }
            })
            .fail(function () { Swal.fire('Error', 'Failed to load student details.', 'error'); });
        });

        // ── FOLLOW UP — open modal ───────────────────────────
        $(document).on('click', '.followUp', function () {
            var studentId = $(this).data('follow-up-id');
            if (!studentId) { Swal.fire('Error', 'Invalid Student ID', 'error'); return; }

            $.get('@Url.Action("GetStudentInquiry", "StudentsList")', { studentInquiryID: studentId })
            .done(function (data) {
                $('#hdnFollowupStudentId').val(data.studentInquiryID);
                $('#followUpDesc1').val(data.followUpDesc1 || '');
                $('#followUpDate1').val(data.followUpDate1 ? new Date(data.followUpDate1).toISOString().split('T')[0] : '');
                $('#followUpDesc2').val(data.followUpDesc2 || '');
                $('#followUpDate2').val(data.followUpDate2 ? new Date(data.followUpDate2).toISOString().split('T')[0] : '');
                $('#followUpModal').modal('show');
            })
            .fail(function () { Swal.fire('Error', 'Failed to load follow-up data.', 'error'); });
        });

        // ── FOLLOW UP SAVE — instant close, NO page reload ───
        $(document).on('click', '#saveFollowUp', function () {
            clearErrors();
            var isValid = true;

            if (!$('#followUpDesc1').val().trim()) { showError('#followUpDesc1', 'Follow-Up 1 description required'); isValid = false; }
            if (!$('#followUpDate1').val())         { showError('#followUpDate1', 'Follow-Up 1 date required');       isValid = false; }

            var desc2 = $('#followUpDesc2').val().trim();
            var date2 = $('#followUpDate2').val();
            if (desc2 && !date2) { showError('#followUpDate2', 'Select date for Follow-Up 2');      isValid = false; }
            if (date2 && !desc2) { showError('#followUpDesc2', 'Enter description for Follow-Up 2'); isValid = false; }

            if (!isValid) {
                Swal.fire({ icon: 'warning', title: 'Validation Error', text: 'Please fix the highlighted fields.', confirmButtonColor: '#f6c23e' });
                return;
            }

            var studentId = parseInt($('#hdnFollowupStudentId').val());
            if (!studentId) { Swal.fire('Error', 'Student ID missing', 'error'); return; }

            var followUpData = {
                StudentInquiryID: studentId,
                FollowUpDesc1:    $('#followUpDesc1').val().trim(),
                FollowUpDate1:    $('#followUpDate1').val() || null,
                FollowUpDesc2:    $('#followUpDesc2').val().trim(),
                FollowUpDate2:    $('#followUpDate2').val() || null
            };

            $('#saveFollowUp').prop('disabled', true).text('Saving...');

            $.ajax({
                url: '@Url.Action("SaveFollowUp", "StudentsList")',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(followUpData),
                dataType: 'json',
                success: function (response) {
                    if (response === "success") {
                        $('#followUpModal').modal('hide');
                        flashRow(studentId);
                        toast('success', 'Saved!', 'Follow-up saved successfully.');
                    } else {
                        Swal.fire('Error', response, 'error');
                    }
                },
                error: function (xhr) { Swal.fire('Error', xhr.responseText, 'error'); },
                complete: function () { $('#saveFollowUp').prop('disabled', false).text('Save Follow Up'); }
            });
        });

        $(document).on('click', '.btnFollowUpReset', function () {
            clearErrors();
            $('#followUpForm')[0].reset();
        });

        // ── ADMISSION — open modal ───────────────────────────
        $(document).on('click', '.admission', function () {
            var studentId = $(this).attr('data-admissionId');

            $.get('@Url.Action("GetStudentInquiry", "StudentsList")', { studentInquiryID: studentId })
            .done(function (data) {
                $('#hdnAdmissionStudentInquiryID').val(data.studentInquiryID);
                $('#addAdmissionForm')[0].reset();
                calculateAmounts();
                $('#admissionModal').modal('show');
            })
            .fail(function () { Swal.fire('Error', 'Failed to load student data.', 'error'); });
        });

        $(document).on('input', '#actualAmount, #discountAmount, #paidAmount, #fineAmount', calculateAmounts);

        function calculateAmounts() {
            var actual   = parseFloat($('#actualAmount').val())   || 0;
            var discount = parseFloat($('#discountAmount').val()) || 0;
            var fine     = parseFloat($('#fineAmount').val())     || 0;
            var paid     = parseFloat($('#paidAmount').val())     || 0;
            var net      = actual - discount + fine;
            $('#netAmount').val(net.toFixed(2));
            $('#pendingAmount').val((net - paid).toFixed(2));
        }

        // ── ADMISSION SAVE — instant close, NO page reload ───
        $(document).on('click', '#btnAdmissionSave', function () {
            clearErrors();
            var isValid = true;

            var actual   = parseFloat($('#actualAmount').val())   || 0;
            var discount = parseFloat($('#discountAmount').val()) || 0;
            var paid     = parseFloat($('#paidAmount').val())     || 0;
            var fine     = parseFloat($('#fineAmount').val())     || 0;
            var net      = actual - discount + fine;

            if (!$('#admissionDate').val()) { showError('#admissionDate', 'Select admission date'); isValid = false; }
            if (!$('#ddlCourseId').val())   { showError('#ddlCourseId', 'Select a course');         isValid = false; }
            if (actual <= 0)                { showError('#actualAmount', 'Enter valid course fee'); isValid = false; }
            if (discount < 0)               { showError('#discountAmount', 'Invalid discount');     isValid = false; }
            if (!$('#paymentMethod').val()) { showError('#paymentMethod', 'Select payment method'); isValid = false; }
            if (paid > net)                 { showError('#paidAmount', 'Paid amount cannot exceed net amount'); isValid = false; }

            if (!isValid) {
                Swal.fire({ icon: 'warning', title: 'Validation Error', text: 'Please fix the highlighted fields.', confirmButtonColor: '#28a745' });
                return;
            }

            var studentId = parseInt($('#hdnAdmissionStudentInquiryID').val());

            var payload = {
                StudentInquiryID: studentId,
                Admission_Date:   $('#admissionDate').val(),
                CourseID:         parseInt($('#ddlCourseId').val()),
                Actual_Amount:    actual,
                Discount_Amount:  discount,
                Fine_Amount:      fine,
                Net_Amount:       net,
                Pending_Amount:   net - paid,
                Paid_Amount:      paid,
                Payment_Method:   $('#paymentMethod').val(),
                Payment_Remark:   $('#paymentRemark').val().trim(),
                SequenceNo:       $('#sequenceNo').val().trim(),
                Created_By:       "StudentsList",
                Updated_By:       "StudentsList"
            };

            $('#btnAdmissionSave').prop('disabled', true).text('Saving...');

            $.ajax({
                url: '@Url.Action("SaveStudentAdmission", "StudentsList")',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function (result) {
                    if (result.toLowerCase() === "success") {
                        $('#admissionModal').modal('hide');
                        flashRow(studentId);
                        toast('success', 'Admitted!', 'Admission saved successfully.');
                    } else if (result.toLowerCase() === "duplicate") {
                        Swal.fire('Duplicate', 'Admission already exists for this student!', 'warning');
                    } else {
                        Swal.fire('Error', result, 'error');
                    }
                },
                error: function (xhr) { Swal.fire('Error', xhr.responseText, 'error'); },
                complete: function () { $('#btnAdmissionSave').prop('disabled', false).text('Save Admission'); }
            });
        });

        $(document).on('click', '.btnAdmissionReset', function () {
            clearErrors();
            $('#addAdmissionForm')[0].reset();
            $('#netAmount, #pendingAmount').val('');
        });

    });
</script>
