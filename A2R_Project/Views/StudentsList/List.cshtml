
@model A2R_Project.Models.StudentInquiries
@{
    ViewBag.Title = "Students List";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/@@mdi/font@6.5.95/css/materialdesignicons.min.css" rel="stylesheet">

<style>
    /* ================= GLOBAL ================= */
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fbff);
        font-family: 'Segoe UI', sans-serif;
    }

    /* ================= CARD ================= */
    .card {
        border-radius: 18px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card-title {
        font-size: 20px;
        font-weight: 700;
        color: #2c3e50;
        letter-spacing: 0.5px;
    }

    /* ================= TABLE ================= */
    .table {
        border-radius: 14px;
        overflow: hidden;
        background: #fff;
    }

        .table thead {
            background: linear-gradient(135deg, #4e73df, #224abe);
        }

            .table thead th {
                border: none;
                color: #fff;
                font-size: 14px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.6px;
                padding: 14px;
            }

        .table tbody td {
            font-size: 15px;
            font-weight: 600;
            color: #34495e;
            padding: 14px;
            vertical-align: middle;
        }

        /* ================= ROW HOVER ================= */
        .table tbody tr {
            transition: all 0.25s ease;
        }

            .table tbody tr:hover {
                background: #eef4ff;
                transform: translateY(-2px);
                box-shadow: 0 6px 14px rgba(0,0,0,0.08);
            }

    /* ================= BADGES ================= */
    .badge-success {
        background: linear-gradient(135deg, #1cc88a, #17a673);
        padding: 7px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .badge-danger {
        background: linear-gradient(135deg, #e74a3b, #c0392b);
        padding: 7px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    /* ================= BUTTON BASE ================= */
    .btn-sm {
        border-radius: 10px;
        padding: 6px 12px;
        margin-right: 5px;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.25s ease;
    }

        .btn-sm i {
            font-size: 15px;
        }

        .btn-sm:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.15);
        }

    /* ================= ICON BUTTON ================= */
    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* ================= ACTION BUTTON COLORS ================= */
    .btn-primary {
        background: linear-gradient(135deg, #4e73df, #224abe);
        border: none;
    }

    .btn-info {
        background: linear-gradient(135deg, #36b9cc, #1f8ea3);
        border: none;
        color: #fff;
    }

    .btn-warning {
        background: linear-gradient(135deg, #f6c23e, #e0a800);
        border: none;
        color: #000;
    }

    /* ================= 🔥 ADMISSION BUTTON FIX ================= */
    .btn-admission {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        color: #fff;
        font-weight: 700;
        border-radius: 25px;
        padding: 6px 14px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-admission i {
            font-size: 16px;
        }

        .btn-admission:hover {
            background: linear-gradient(135deg, #218838, #17a2b8);
            color: #fff;
            transform: scale(1.05);
        }

    /* ================= TABLE EMPTY TEXT ================= */
    .text-center {
        font-size: 16px;
        font-weight: 600;
        color: #888;
    }

    /* ================= PAGINATION ================= */
    .pagination .page-link {
        border-radius: 10px;
        margin: 0 4px;
        font-weight: 600;
        color: #4e73df;
        border: none;
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: #fff;
    }

    .pagination .page-link:hover {
        background: #e8edff;
    }

</style>
<style>

    /* ================= MODAL CONTAINER ================= */
    .modal-content {
        border-radius: 18px;
        border: none;
        box-shadow: 0 12px 35px rgba(0,0,0,0.15);
        overflow: hidden;
    }

    /* ================= MODAL HEADER ================= */
    .modal-header {
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: #fff;
        padding: 16px 20px;
    }

    .modal-title {
        font-size: 20px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .modal-header .close {
        color: #fff;
        opacity: 1;
        font-size: 24px;
    }

    /* ================= MODAL BODY ================= */
    .modal-body {
        padding: 25px;
        background: #f9fbff;
    }

    /* ================= FORM GROUP ================= */
    .form-group {
        margin-bottom: 20px;
    }

        /* ================= LABEL ================= */
        .form-group label {
            font-size: 14px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 6px;
            display: block;
        }

    /* ================= INPUT FIELDS ================= */
    .form-control {
        height: 42px;
        border-radius: 10px;
        border: 1px solid #dce3f0;
        font-size: 15px;
        font-weight: 600;
        padding: 8px 12px;
        transition: all 0.25s ease;
    }

    /* TEXTAREA */
    textarea.form-control {
        height: auto;
        min-height: 80px;
    }

    /* ================= INPUT FOCUS ================= */
    .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 3px rgba(78,115,223,0.15);
        background: #fff;
    }

    /* ================= ROW SPACING ================= */
    .modal-body .row {
        margin-bottom: 10px;
    }

    .modal-body .col-md-3,
    .modal-body .col-md-6 {
        padding-bottom: 10px;
    }

    /* ================= DROPDOWN ================= */
    select.form-control {
        cursor: pointer;
    }

    /* ================= FOOTER ================= */
    .modal-footer {
        padding: 15px 20px;
        background: #fff;
        border-top: 1px solid #eee;
    }

        /* ================= BUTTONS ================= */
        .modal-footer .btn {
            border-radius: 10px;
            padding: 8px 18px;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.25s ease;
        }

            .modal-footer .btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,0,0,0.15);
            }

    /* PRIMARY */
    .btn-primary {
        background: linear-gradient(135deg, #4e73df, #224abe);
        border: none;
    }

    /* WARNING */
    .btn-warning {
        background: linear-gradient(135deg, #f6c23e, #e0a800);
        border: none;
        color: #000;
    }

    /* SECONDARY */
    .btn-secondary {
        background: #858796;
        border: none;
        color: #fff;
    }

    /* ================= SECTION HEADINGS ================= */
    .modal-body h6 {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 12px;
        color: #4e73df;
    }

    /* ================= VIEW POPUP TEXT ================= */
    .form-control-plaintext {
        font-size: 15px;
        font-weight: 600;
        color: #2c3e50;
        background: #f4f6fb;
        border-radius: 8px;
    }

    .modal-dialog {
        max-width: 900px;
        margin: 1.75rem auto;
    }
    /* ================= VIEW MODAL - PERFECT MATCHING STYLE ================= */
    #viewStudent .modal-dialog {
        max-width: 550px;
        margin: 1.75rem auto;
        max-height:550px;
    }

    #viewStudent .modal-content {
        border-radius: 18px;
        border: none;
        box-shadow: 0 12px 35px rgba(0,0,0,0.15);
    }

    #viewStudent .modal-header {
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: #fff;
        padding: 20px;
        border-radius: 18px 18px 0 0;
    }

    #viewStudent .modal-title {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    #viewStudent .close {
        color: #fff;
        opacity: 1;
        font-size: 28px;
        font-weight: 300;
    }

    #viewStudent .modal-body {
        padding: 30px;
        background: #f9fbff;
    }

    #viewStudent h6 {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 20px;
        color: #4e73df;
        padding-bottom: 10px;
        border-bottom: 2px solid #e3f2fd;
        margin-top: 25px;
    }

        #viewStudent h6:first-child {
            margin-top: 0;
        }

    #viewStudent .form-group {
        margin-bottom: 22px;
    }

        #viewStudent .form-group label {
            font-size: 15px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 10px;
            display: block;
        }

    #viewStudent .form-control-plaintext {
        font-size: 16px;
        font-weight: 600;
        color: #2c3e50;
        background: linear-gradient(135deg, #fff, #f8fbff);
        border: 2px solid #e8f0fe;
        border-radius: 12px;
        padding: 15px 18px;
        min-height: 52px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: all 0.25s ease;
    }

        #viewStudent .form-control-plaintext:hover {
            border-color: #4e73df;
            box-shadow: 0 4px 15px rgba(78,115,223,0.15);
        }

    #viewStudent .row {
        margin-bottom: 25px;
    }

    #viewStudent .col-md-6 {
        padding-bottom: 20px;
    }

    /* ================= ADMISSION MODAL - ENHANCED STYLE ================= */
    #admissionModal .modal-dialog {
        max-width: 1000px;
        margin: 1.75rem auto;
    }

    #admissionModal .modal-content {
        border-radius: 18px;
        border: none;
        box-shadow: 0 12px 35px rgba(0,0,0,0.15);
    }

    #admissionModal .modal-header {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: #fff;
        padding: 22px 25px;
        border-radius: 18px 18px 0 0;
    }

    #admissionModal .modal-title {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    #admissionModal .close {
        color: #fff;
        opacity: 1;
        font-size: 28px;
    }

    #admissionModal .modal-body {
        padding: 35px;
        background: #f9fbff;
    }

    #admissionModal .alert-info {
        background: linear-gradient(135deg, #4e73df, #224abe);
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 18px 22px;
        margin-bottom: 30px;
        font-size: 16px;
        font-weight: 600;
    }

    #admissionModal .form-group {
        margin-bottom: 25px;
    }

        #admissionModal .form-group label {
            font-size: 15px;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 10px;
            display: block;
        }

    #admissionModal .form-control,
    #admissionModal select.form-control,
    #admissionModal textarea.form-control {
        height: 50px;
        border-radius: 12px;
        border: 2px solid #e8f0fe;
        font-size: 16px;
        font-weight: 600;
        padding: 12px 16px;
        background: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: all 0.25s ease;
    }

    #admissionModal textarea.form-control {
        height: 85px;
        resize: vertical;
    }

    #admissionModal .form-control:focus,
    #admissionModal select.form-control:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 4px rgba(40,167,69,0.2);
        transform: translateY(-1px);
    }

    #admissionModal .form-control.bg-light {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef) !important;
        color: #495057;
        font-weight: 700;
        border-color: #dee2e6;
    }

    /* ================= READONLY FIELDS ================= */
    #admissionModal .form-control[readonly] {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        color: #28a745;
        font-weight: 700;
        cursor: not-allowed;
    }

    /* ================= COL POSITIONING ================= */
    #admissionModal .col-md-2,
    #admissionModal .col-md-3 {
        padding-bottom: 20px;
    }

    /* ================= MODAL FOOTER - ENHANCED ================= */
    #admissionModal .modal-footer,
    #viewStudent .modal-footer,
    #editStudent .modal-footer,
    #followUpModal .modal-footer {
        padding: 20px 30px;
        background: #fff;
        border-top: 1px solid #e9ecef;
        border-radius: 0 0 18px 18px;
    }

    .modal-footer .btn {
        border-radius: 12px;
        padding: 12px 24px;
        font-weight: 700;
        font-size: 15px;
        margin-left: 10px;
        min-width: 120px;
        height: 48px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.25s ease;
    }

        .modal-footer .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    /* ================= RESPONSIVE ================= */
    @@media (max-width: 768px) {
        .modal-dialog

    {
        margin: 1rem;
        max-width: calc(100% - 2rem);
    }

    #viewStudent .modal-body,
    #admissionModal .modal-body {
        padding: 20px;
    }

    .col-md-2, .col-md-3 {
        margin-bottom: 15px;
    }

    }


</style>


<div class="col-lg-12 stretch-card">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center" style="padding: 10px !important">
                <strong class="card-title">Students List</strong>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead class="thead-dark">
                        <tr>
                            <th>Student Name</th>
                            <th>Education</th>
                            <th>Courses</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.StudentInquiry != null && Model.StudentInquiry.Any())
                        {
                            foreach (var item in Model.StudentInquiry)
                            {
                                <tr>
                                    <td>@item.NameOfStudent</td>
                                    <td>@item.Education</td>
                                    <td>@item.Course</td>
                                    <td>
                                        @if (item.IsActive == 1)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <!-- ✅ FIXED BUTTONS -->
                                        <button class="btn btn-sm btn-primary editByStudentInquiryId" data-edstudent-id="@item.StudentInquiryID">
                                            <i class="mdi mdi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-info viewByStudentInquiryId" data-vwstudent-id="@item.StudentInquiryID">
                                            <i class="mdi mdi-eye"></i>
                                        </button>

                                        <!-- ✅ FIXED Follow Up Button -->
                                        <button type="button" class="btn btn-sm btn-warning followUp"
                                                data-follow-up-id="@item.StudentInquiryID"
                                                title="Follow Up">
                                            <i class="mdi mdi-clock-outline"></i>
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-admission admission"
                                                data-admissionId='@item.StudentInquiryID'
                                                title="Admission"
                                                data-toggle="modal"
                                                data-target="#admissionModal">
                                            <i class="mdi mdi-account-check"></i> Admission
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">No students found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (ViewBag.TotalCount != null && (int)ViewBag.TotalCount > (int)ViewBag.PageSize)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("List", new { page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })">Previous</a>
                        </li>
                        @for (int i = 1; i <= Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize); i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("List", new { page = i, pageSize = ViewBag.PageSize })">@i</a>
                            </li>
                        }
                        <li class="page-item @(((int)ViewBag.CurrentPage == Math.Ceiling((double)(int)ViewBag.TotalCount / (int)ViewBag.PageSize)) ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("List", new { page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editStudent" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Student</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editStudentForm">
                    <input type="hidden" id="hdnStudentId">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtEditStudentName" required />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Contact No.</label>
                                <input type="text" class="form-control" id="txtEditContactNo" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Company</label>
                                <input type="text" class="form-control" id="txtEditCompanyName" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Education</label>
                                <input type="text" class="form-control" id="txtEditEducation" />
                            </div>
                        </div>
                    </div>
                    <!-- Rest of your form fields stay SAME -->
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" class="form-control" id="txtEditEmail" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Enrolled Date</label>
                                <input type="date" class="form-control" id="enrolledDateEdit" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Completion Date</label>
                                <input type="date" class="form-control" id="completionDateEdit" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Course</label>
                                @Html.DropDownList("courseID", new SelectList(Model.course, "CourseID", "CourseName"), "-- Select --", new { @class = "form-control", @id = "ddlEditCourseId" })
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Address 1</label>
                                <input type="text" class="form-control" id="txtEditStudentAddress1" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Address 2</label>
                                <input type="text" class="form-control" id="txtEditAddress2" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>City</label>
                                <input type="text" class="form-control" id="txtEditCity" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Postcode</label>
                                <input type="text" class="form-control" id="txtEditPincode" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Father's Name</label>
                                <input type="text" class="form-control" id="txtEditFatherName" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Designation</label>
                                <input type="text" class="form-control" id="txtEditDesignation" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>State</label>
                                @Html.DropDownList("stateID", new SelectList(Model.state, "StateID", "StateName"), "-- Select --", new { @class = "form-control", @id = "ddlEditStateId" })
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Country</label>
                                @Html.DropDownList("countryID", new SelectList(Model.country, "CountryID", "CountryName"), "-- Select --", new { @class = "form-control", @id = "ddlEditCountryId" })
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-warning btnStudentReset">Reset</button>
                <button type="button" class="btn btn-primary" id="btnEditStudentSave">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- ✅ View Modal -->
<div class="modal fade" id="viewStudent" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Student Details</h5>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-primary"><strong>👤 Student Information</strong></h6>
